"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"flight_id\": \"FL-8821\",\n        \"available_classes\": [\n          \"Economy\",\n          \"Business\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'Resultado básico de uma busca de voo'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Identificador único do voo'\\n          example: 'FL-8821'\\n        available_classes:\\n          type: array\\n          description: 'Lista de classes de assento disponíveis'\\n          items:\\n            type: string\\n          example: ['Economy', 'Business']\"\n    },\n    {\n      \"raw_json\": {\n        \"flight_id\": \"FL-4490\",\n        \"available_classes\": [\n          \"Economy\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'Resultado básico de uma busca de voo'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Identificador único do voo'\\n          example: 'FL-4490'\\n        available_classes:\\n          type: array\\n          description: 'Lista de classes de assento disponíveis'\\n          items:\\n            type: string\\n          example: ['Economy']\"\n    },\n    {\n      \"raw_json\": {\n        \"flight_id\": \"FL-1023\",\n        \"available_classes\": [\n          \"Economy\",\n          \"Premium Economy\",\n          \"Business\",\n          \"First\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'Resultado básico de uma busca de voo'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Identificador único do voo'\\n          example: 'FL-1023'\\n        available_classes:\\n          type: array\\n          description: 'Lista de classes de assento disponíveis'\\n          items:\\n            type: string\\n          example: ['Economy', 'Premium Economy', 'Business', 'First']\"\n    }\n  ]\n}"
