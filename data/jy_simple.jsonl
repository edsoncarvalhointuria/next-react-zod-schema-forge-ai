"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"session_token\": \"abc123xyz789\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Standard Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LogoutRequest:\\n      type: object\\n      description: 'Request body for standard user logout'\\n      properties:\\n        session_token:\\n          type: string\\n          description: 'The unique session identifier to be invalidated'\\n          example: 'abc123xyz789'\"\n    },\n    {\n      \"raw_json\": {\n        \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Token-based Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    TokenLogoutRequest:\\n      type: object\\n      description: 'Request body for JWT-based logout'\\n      properties:\\n        token:\\n          type: string\\n          description: 'The bearer token to be revoked'\\n          example: 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9'\"\n    },\n    {\n      \"raw_json\": {\n        \"auth_token\": \"session_id_998877\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Legacy Auth Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LegacyLogoutRequest:\\n      type: object\\n      description: 'Request body for legacy authentication system logout'\\n      properties:\\n        auth_token:\\n          type: string\\n          description: 'The legacy authentication token'\\n          example: 'session_id_998877'\"\n    }\n  ]\n}"
