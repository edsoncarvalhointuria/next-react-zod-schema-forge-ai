"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"city\": \"London\",\n        \"weather_data\": {\n          \"temperature\": 15.5,\n          \"humidity\": 82\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherData:\\n      type: object\\n      description: 'Current meteorological observations'\\n      properties:\\n        temperature:\\n          type: number\\n          description: 'Current temperature in Celsius'\\n          example: 15.5\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 82\\n    WeatherResponse:\\n      type: object\\n      description: 'Root object for weather widget data'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'London'\\n        weather_data:\\n          $ref: '#/components/schemas/WeatherData'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"Tokyo\",\n        \"weather_data\": {\n          \"temperature\": 22.0,\n          \"humidity\": 60\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherData:\\n      type: object\\n      description: 'Current meteorological observations'\\n      properties:\\n        temperature:\\n          type: number\\n          description: 'Current temperature in Celsius'\\n          example: 22.0\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 60\\n    WeatherResponse:\\n      type: object\\n      description: 'Root object for weather widget data'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'Tokyo'\\n        weather_data:\\n          $ref: '#/components/schemas/WeatherData'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"New York\",\n        \"weather_data\": {\n          \"temperature\": 12.3,\n          \"humidity\": 45\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherData:\\n      type: object\\n      description: 'Current meteorological observations'\\n      properties:\\n        temperature:\\n          type: number\\n          description: 'Current temperature in Celsius'\\n          example: 12.3\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 45\\n    WeatherResponse:\\n      type: object\\n      description: 'Root object for weather widget data'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'New York'\\n        weather_data:\\n          $ref: '#/components/schemas/WeatherData'\"\n    }\n  ]\n}"
