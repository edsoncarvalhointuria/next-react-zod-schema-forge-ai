"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_12345\",\n        \"is_liked\": true\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Like Toggle API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LikeRequest:\\n      type: object\\n      description: Request body for toggling a post like status\\n      properties:\\n        post_id:\\n          type: string\\n          description: The unique identifier of the post being liked\\n          example: \\\"post_12345\\\"\\n        is_liked:\\n          type: boolean\\n          description: The target like status to set\\n          example: true\"\n    },\n    {\n      \"raw_json\": {\n        \"postId\": 98765,\n        \"liked\": false\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Post Interaction API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PostLikeToggle:\\n      type: object\\n      description: Payload to update the like state of a specific post\\n      properties:\\n        postId:\\n          type: integer\\n          description: The numeric ID of the post\\n          example: 98765\\n        liked:\\n          type: boolean\\n          description: Indicates if the post should be marked as liked\\n          example: false\"\n    },\n    {\n      \"raw_json\": {\n        \"id\": \"uuid-abc-123\",\n        \"like_status\": true\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Social Engagement API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LikeToggle:\\n      type: object\\n      description: Data required to toggle a like action\\n      properties:\\n        id:\\n          type: string\\n          description: The UUID of the target post\\n          example: \\\"uuid-abc-123\\\"\\n        like_status:\\n          type: boolean\\n          description: The updated boolean status of the like action\\n          example: true\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"userId\": \"user_882194\",\n        \"authCode\": \"492013\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"2FA Submission API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TwoFactorSubmission\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Basic request for 2FA code verification\\\",\\n        \\\"properties\\\": {\\n          \\\"userId\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The unique identifier of the user attempting to authenticate\\\",\\n            \\\"example\\\": \\\"user_882194\\\"\\n          },\\n          \\\"authCode\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The 6-digit security code sent to the user's device\\\",\\n            \\\"example\\\": \\\"492013\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"userId\\\", \\\"authCode\\\"]\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"userId\": \"user_882194\",\n        \"authCode\": \"105532\",\n        \"deviceContext\": {\n          \"deviceId\": \"dev_ios_9921\",\n          \"osVersion\": \"17.4.1\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"2FA Submission API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TwoFactorSubmission\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"2FA request including device context\\\",\\n        \\\"properties\\\": {\\n          \\\"userId\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The unique identifier of the user\\\",\\n            \\\"example\\\": \\\"user_882194\\\"\\n          },\\n          \\\"authCode\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The 6-digit security code\\\",\\n            \\\"example\\\": \\\"105532\\\"\\n          },\\n          \\\"deviceContext\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/DeviceContext\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"userId\\\", \\\"authCode\\\"]\\n      },\\n      \\\"DeviceContext\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Information about the device used for submission\\\",\\n        \\\"properties\\\": {\\n          \\\"deviceId\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique hardware identifier\\\",\\n            \\\"example\\\": \\\"dev_ios_9921\\\"\\n          },\\n          \\\"osVersion\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Operating system version of the device\\\",\\n            \\\"example\\\": \\\"17.4.1\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"userId\": \"user_882194\",\n        \"authCode\": \"772104\",\n        \"session\": {\n          \"sessionId\": \"sess_abc123xyz\",\n          \"issuedAt\": \"2023-11-01T10:00:00Z\"\n        },\n        \"securityAudit\": {\n          \"ipAddress\": \"192.168.1.45\",\n          \"userAgent\": \"Mozilla/5.0 (Windows NT 10.0; Win64; x64)\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"2FA Submission API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TwoFactorSubmission\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Comprehensive 2FA request with session and audit data\\\",\\n        \\\"properties\\\": {\\n          \\\"userId\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The unique identifier of the user\\\",\\n            \\\"example\\\": \\\"user_882194\\\"\\n          },\\n          \\\"authCode\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The 6-digit security code\\\",\\n            \\\"example\\\": \\\"772104\\\"\\n          },\\n          \\\"session\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/SessionInfo\\\"\\n          },\\n          \\\"securityAudit\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/SecurityAudit\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\\"userId\\\", \\\"authCode\\\", \\\"session\\\"]\\n      },\\n      \\\"SessionInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Session tracking details\\\",\\n        \\\"properties\\\": {\\n          \\\"sessionId\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique session token\\\",\\n            \\\"example\\\": \\\"sess_abc123xyz\\\"\\n          },\\n          \\\"issuedAt\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Timestamp when the session was created\\\",\\n            \\\"example\\\": \\\"2023-11-01T10:00:00Z\\\"\\n          }\\n        }\\n      },\\n      \\\"SecurityAudit\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Network and client audit information\\\",\\n        \\\"properties\\\": {\\n          \\\"ipAddress\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The originating IP address of the request\\\",\\n            \\\"example\\\": \\\"192.168.1.45\\\"\\n          },\\n          \\\"userAgent\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The browser or client user agent string\\\",\\n            \\\"example\\\": \\\"Mozilla/5.0 (Windows NT 10.0; Win64; x64)\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Operation completed successfully\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Generic Success Response\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    SuccessResponse:\\n      type: object\\n      description: 'Standard success response for API operations'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'Indicates if the request was processed successfully'\\n          example: true\\n        message:\\n          type: string\\n          description: 'A human-readable message describing the outcome'\\n          example: 'Operation completed successfully'\"\n    },\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"OK\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Simple Success Response\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    SimpleSuccess:\\n      type: object\\n      description: 'Minimal success response for lightweight requests'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'Boolean flag indicating success status'\\n          example: true\\n        message:\\n          type: string\\n          description: 'Short status confirmation message'\\n          example: 'OK'\"\n    },\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Resource created successfully\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Action Success Response\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ActionSuccess:\\n      type: object\\n      description: 'Response confirming a specific action was successful'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'Whether the specific action was completed'\\n          example: true\\n        message:\\n          type: string\\n          description: 'Detailed confirmation message of the action performed'\\n          example: 'Resource created successfully'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"email\": \"jane.doe@example.com\",\n        \"opt_in\": true\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Email Subscription API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"EmailSubscription\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Payload for subscribing a user to a mailing list\\\",\\n        \\\"properties\\\": {\\n          \\\"email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"email\\\",\\n            \\\"description\\\": \\\"The email address of the subscriber\\\",\\n            \\\"example\\\": \\\"jane.doe@example.com\\\"\\n          },\\n          \\\"opt_in\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Whether the user has consented to receive emails\\\",\\n            \\\"example\\\": true\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"email\": \"support@techcorp.net\",\n        \"subscribed\": false\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Newsletter Management API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SubscriptionRequest\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Request to update subscription status\\\",\\n        \\\"properties\\\": {\\n          \\\"email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"email\\\",\\n            \\\"description\\\": \\\"The user's registered email address\\\",\\n            \\\"example\\\": \\\"support@techcorp.net\\\"\\n          },\\n          \\\"subscribed\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"The desired subscription state\\\",\\n            \\\"example\\\": false\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"email\": \"marketing.lead@webmail.com\",\n        \"marketing_consent\": true\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Lead Capture API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"NewsletterSignup\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Data for a new newsletter signup lead\\\",\\n        \\\"properties\\\": {\\n          \\\"email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"email\\\",\\n            \\\"description\\\": \\\"The contact email for the lead\\\",\\n            \\\"example\\\": \\\"marketing.lead@webmail.com\\\"\\n          },\\n          \\\"marketing_consent\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Indicates if the user agrees to marketing communications\\\",\\n            \\\"example\\\": true\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"session_token\": \"abc123xyz789\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LogoutRequest:\\n      type: object\\n      description: Requisição para encerrar a sessão do usuário\\n      properties:\\n        session_token:\\n          type: string\\n          description: Token de sessão utilizado para autenticar a requisição de logout\\n          example: abc123xyz789\"\n    },\n    {\n      \"raw_json\": {\n        \"auth_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIn0\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Session Management API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    SessionTermination:\\n      type: object\\n      description: Payload para a terminação de sessão via JWT\\n      properties:\\n        auth_token:\\n          type: string\\n          description: Token de autenticação JWT para encerrar a sessão do usuário\\n          example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIn0\"\n    },\n    {\n      \"raw_json\": {\n        \"access_token\": \"tok_live_9876543210abcdef\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Auth Service API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LogoutPayload:\\n      type: object\\n      description: Dados necessários para invalidar o token de acesso\\n      properties:\\n        access_token:\\n          type: string\\n          description: Token de acesso ativo que deve ser invalidado no servidor\\n          example: tok_live_9876543210abcdef\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"feature_name\": \"dark_mode_ui\",\n        \"enabled\": true\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Feature Flag API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"FeatureFlag\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Representa o estado de ativação de uma funcionalidade específica\\\",\\n        \\\"properties\\\": {\\n          \\\"feature_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"O nome identificador da funcionalidade\\\",\\n            \\\"example\\\": \\\"dark_mode_ui\\\"\\n          },\\n          \\\"enabled\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Indica se a funcionalidade está habilitada para o usuário\\\",\\n            \\\"example\\\": true\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"flag_id\": \"beta_payment_gateway\",\n        \"is_active\": false\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Feature Toggle API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"FeatureToggle\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Configuração de alternância de funcionalidade do sistema\\\",\\n        \\\"properties\\\": {\\n          \\\"flag_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"O ID único da flag de controle\\\",\\n            \\\"example\\\": \\\"beta_payment_gateway\\\"\\n          },\\n          \\\"is_active\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Define se a flag está ativa ou inativa\\\",\\n            \\\"example\\\": false\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"feature_key\": \"new_onboarding_flow\",\n        \"status\": true\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Feature Status API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"FeatureStatus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Status de disponibilidade de uma chave de funcionalidade\\\",\\n        \\\"properties\\\": {\\n          \\\"feature_key\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"A chave técnica da funcionalidade\\\",\\n            \\\"example\\\": \\\"new_onboarding_flow\\\"\\n          },\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Estado booleano de ativação da chave\\\",\\n            \\\"example\\\": true\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_12345\",\n        \"reason\": \"Não utilizo mais o serviço\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Account Deletion API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AccountDeletionRequest:\\n      type: object\\n      description: 'Solicitação de exclusão de conta do usuário'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Identificador único do usuário'\\n          example: 'usr_12345'\\n        reason:\\n          type: string\\n          description: 'Motivo fornecido para a exclusão da conta'\\n          example: 'Não utilizo mais o serviço'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_67890\",\n        \"reason\": \"Preocupações com a privacidade\",\n        \"confirmed_at\": \"2023-10-27T10:00:00Z\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Account Deletion API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AccountDeletionConfirmation:\\n      type: object\\n      description: 'Confirmação detalhada de exclusão de conta'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Identificador único do usuário'\\n          example: 'usr_67890'\\n        reason:\\n          type: string\\n          description: 'Motivo da exclusão da conta'\\n          example: 'Preocupações com a privacidade'\\n        confirmed_at:\\n          type: string\\n          format: date-time\\n          description: 'Data e hora em que a exclusão foi confirmada'\\n          example: '2023-10-27T10:00:00Z'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_abcde\",\n        \"reason\": \"Criei outra conta\",\n        \"permanent_deletion\": true\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Account Deletion API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    DeletionPayload:\\n      type: object\\n      description: 'Payload para processamento de exclusão de conta'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Identificador único do usuário'\\n          example: 'usr_abcde'\\n        reason:\\n          type: string\\n          description: 'Justificativa para a remoção dos dados'\\n          example: 'Criei outra conta'\\n        permanent_deletion:\\n          type: boolean\\n          description: 'Indica se a exclusão deve ser permanente e irreversível'\\n          example: true\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"status\": \"ok\",\n        \"uptime\": 3600\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Health Check API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"HealthCheck\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Basic health check response\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The current health status of the system\\\",\\n            \\\"example\\\": \\\"ok\\\"\\n          },\\n          \\\"uptime\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"The system uptime in seconds\\\",\\n            \\\"example\\\": 3600\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"status\": \"healthy\",\n        \"uptime\": 86400\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Ping API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PingResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response to a ping request\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Operational status of the service\\\",\\n            \\\"example\\\": \\\"healthy\\\"\\n          },\\n          \\\"uptime\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Total seconds since last restart\\\",\\n            \\\"example\\\": 86400\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"status\": \"up\",\n        \"uptime\": 120\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"System Status API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SystemStatus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Minimal system status check\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Availability status\\\",\\n            \\\"example\\\": \\\"up\\\"\\n          },\\n          \\\"uptime\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Uptime duration in seconds\\\",\\n            \\\"example\\\": 120\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"email\": \"usuario@exemplo.com.br\",\n        \"reset_code\": \"482910\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Password Reset API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PasswordResetRequest:\\n      type: object\\n      description: 'Requisição para redefinição de senha utilizando e-mail e código'\\n      properties:\\n        email:\\n          type: string\\n          format: email\\n          description: 'Endereço de e-mail do usuário que solicita a redefinição'\\n          example: 'usuario@exemplo.com.br'\\n        reset_code:\\n          type: string\\n          description: 'Código numérico temporário enviado para validação'\\n          example: '482910'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_email\": \"contato@empresa.com\",\n        \"verification_code\": \"AX-9921\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Verification API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ResetVerification:\\n      type: object\\n      description: 'Payload de verificação de identidade para troca de senha'\\n      properties:\\n        user_email:\\n          type: string\\n          format: email\\n          description: 'E-mail cadastrado do usuário no sistema'\\n          example: 'contato@empresa.com'\\n        verification_code:\\n          type: string\\n          description: 'Código alfanumérico de verificação temporário'\\n          example: 'AX-9921'\"\n    },\n    {\n      \"raw_json\": {\n        \"email_address\": \"admin@portal.net\",\n        \"temp_code\": \"773311\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Account Recovery API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AccountRecoveryRequest:\\n      type: object\\n      description: 'Dados necessários para a recuperação de acesso à conta'\\n      properties:\\n        email_address:\\n          type: string\\n          format: email\\n          description: 'Endereço de e-mail associado à conta a ser recuperada'\\n          example: 'admin@portal.net'\\n        temp_code:\\n          type: string\\n          description: 'Código de acesso temporário gerado pelo sistema'\\n          example: '773311'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"message\": \"Too many requests. Please try again later.\",\n        \"retry_after\": 60\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Rate Limit API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"RateLimitWarning\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta de aviso de limite de taxa de requisições\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Mensagem informativa sobre o limite excedido\\\",\\n            \\\"example\\\": \\\"Too many requests. Please try again later.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Tempo de espera necessário em segundos antes de realizar uma nova tentativa\\\",\\n            \\\"example\\\": 60\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"message\": \"Limite de requisições excedido para o seu plano atual.\",\n        \"retry_after\": 3600\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Rate Limit API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"RateLimitError\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Erro de cota de requisições excedida\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Descrição detalhada do erro de limite de taxa\\\",\\n            \\\"example\\\": \\\"Limite de requisições excedido para o seu plano atual.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Quantidade de segundos para aguardar a reinicialização da cota\\\",\\n            \\\"example\\\": 3600\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"message\": \"Rate limit exceeded\",\n        \"retry_after\": 15\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Rate Limit API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"QuotaExceeded\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Alerta técnico de limite de chamadas de API\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Mensagem curta de erro de limite\\\",\\n            \\\"example\\\": \\\"Rate limit exceeded\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Intervalo de tempo em segundos para a próxima tentativa permitida\\\",\\n            \\\"example\\\": 15\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"postId\": \"post_12345\",\n        \"isLiked\": true\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Like Toggle API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LikeRequest:\\n      type: object\\n      description: 'Request body for toggling a post like status'\\n      properties:\\n        postId:\\n          type: string\\n          description: 'The unique identifier of the post'\\n          example: 'post_12345'\\n        isLiked:\\n          type: boolean\\n          description: 'The desired like state (true for liked, false for unliked)'\\n          example: true\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": 987654,\n        \"liked\": false\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Like Toggle API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LikeToggleRequest:\\n      type: object\\n      description: 'Payload to update the like status of a specific post'\\n      properties:\\n        post_id:\\n          type: integer\\n          description: 'The numeric ID of the post'\\n          example: 987654\\n        liked:\\n          type: boolean\\n          description: 'Boolean flag indicating if the post is liked'\\n          example: false\"\n    },\n    {\n      \"raw_json\": {\n        \"id\": \"uuid-abc-123-def\",\n        \"status\": true\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Like Toggle API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PostLikeStatus:\\n      type: object\\n      description: 'Schema for updating a post like status'\\n      properties:\\n        id:\\n          type: string\\n          description: 'The UUID of the post'\\n          example: 'uuid-abc-123-def'\\n        status:\\n          type: boolean\\n          description: 'The new like status to be applied'\\n          example: true\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"user_id\": \"user_882194\",\n        \"auth_code\": \"449201\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"2FA Submission API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TwoFactorAuth\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Request body for submitting a two-factor authentication code\\\",\\n        \\\"properties\\\": {\\n          \\\"user_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The unique identifier of the user attempting to authenticate\\\",\\n            \\\"example\\\": \\\"user_882194\\\"\\n          },\\n          \\\"auth_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The 6-digit verification code sent to the user\\\",\\n            \\\"example\\\": \\\"449201\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_77210\",\n        \"auth_code\": \"102938\",\n        \"attempt_count\": 1\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"2FA Submission API Extended\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TwoFactorAuthExtended\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Request body for submitting a 2FA code with attempt tracking\\\",\\n        \\\"properties\\\": {\\n          \\\"user_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The unique identifier of the user\\\",\\n            \\\"example\\\": \\\"usr_77210\\\"\\n          },\\n          \\\"auth_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The 6-digit verification code\\\",\\n            \\\"example\\\": \\\"102938\\\"\\n          },\\n          \\\"attempt_count\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"The current attempt number for this specific code\\\",\\n            \\\"example\\\": 1\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"auth_payload\": {\n          \"user_id\": \"uuid-9901-x2\",\n          \"auth_code\": \"556677\"\n        },\n        \"request_metadata\": {\n          \"ip_address\": \"192.168.1.45\",\n          \"device_fingerprint\": \"dfp_z98y7x6w\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"2FA Submission API Complex\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TwoFactorSubmission\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Complex request body for 2FA submission including metadata\\\",\\n        \\\"properties\\\": {\\n          \\\"auth_payload\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/AuthPayload\\\"\\n          },\\n          \\\"request_metadata\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/RequestMetadata\\\"\\n          }\\n        }\\n      },\\n      \\\"AuthPayload\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"The core authentication credentials\\\",\\n        \\\"properties\\\": {\\n          \\\"user_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The unique identifier of the user\\\",\\n            \\\"example\\\": \\\"uuid-9901-x2\\\"\\n          },\\n          \\\"auth_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The 6-digit verification code\\\",\\n            \\\"example\\\": \\\"556677\\\"\\n          }\\n        }\\n      },\\n      \\\"RequestMetadata\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Contextual information about the request source\\\",\\n        \\\"properties\\\": {\\n          \\\"ip_address\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The IP address of the client making the request\\\",\\n            \\\"example\\\": \\\"192.168.1.45\\\"\\n          },\\n          \\\"device_fingerprint\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"A unique identifier for the client device\\\",\\n            \\\"example\\\": \\\"dfp_z98y7x6w\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
