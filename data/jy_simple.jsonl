    preferences:\\n          $ref: '#/components/schemas/Preferences'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_1029\",\n        \"preferences\": {\n          \"theme\": \"system\",\n          \"language\": \"es-ES\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Settings Fetch\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Preferences:\\n      type: object\\n      description: 'Configurações de preferência do usuário'\\n      properties:\\n        theme:\\n          type: string\\n          description: 'Tema visual selecionado'\\n          example: 'system'\\n        language:\\n          type: string\\n          description: 'Código do idioma preferido'\\n          example: 'es-ES'\\n    UserSettings:\\n      type: object\\n      description: 'Resposta contendo as configurações do usuário'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Identificador único do usuário'\\n          example: 'usr_1029'\\n        preferences:\\n          $ref: '#/components/schemas/Preferences'\"\n    }\n  ]\n}"
