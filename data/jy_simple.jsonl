"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_987\",\n        \"comment_details\": {\n          \"author_name\": \"Alice Smith\",\n          \"text\": \"Great insights on API architecture!\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'Nested object containing author and content'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The name of the person posting the comment'\\n          example: 'Alice Smith'\\n        text:\\n          type: string\\n          description: 'The body content of the comment'\\n          example: 'Great insights on API architecture!'\\n    CommentSubmission:\\n      type: object\\n      description: 'Root object for comment submission'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Unique identifier of the blog post'\\n          example: 'post_987'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_456\",\n        \"comment_details\": {\n          \"author_name\": \"Bob Jones\",\n          \"text\": \"Could you elaborate more on the security aspects?\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'Nested object containing author and content'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The name of the person posting the comment'\\n          example: 'Bob Jones'\\n        text:\\n          type: string\\n          description: 'The body content of the comment'\\n          example: 'Could you elaborate more on the security aspects?'\\n    CommentSubmission:\\n      type: object\\n      description: 'Root object for comment submission'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Unique identifier of the blog post'\\n          example: 'post_456'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_111\",\n        \"comment_details\": {\n          \"author_name\": \"Charlie Brown\",\n          \"text\": \"Very helpful tutorial, thanks for sharing.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'Nested object containing author and content'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The name of the person posting the comment'\\n          example: 'Charlie Brown'\\n        text:\\n          type: string\\n          description: 'The body content of the comment'\\n          example: 'Very helpful tutorial, thanks for sharing.'\\n    CommentSubmission:\\n      type: object\\n      description: 'Root object for comment submission'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Unique identifier of the blog post'\\n          example: 'post_111'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    }\n  ]\n}"
