" },\\n          \\\"software\\\": { \\\"$ref\\\": \\\"#/components/schemas/SoftwareInfo\\\" }\\n        }\\n      },\\n      \\\"SoftwareInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"os_version\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"OS platform and version string\\\", \\\"example\\\": \\\"Android 13\\\" },\\n          \\\"app_version\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Application build version\\\", \\\"example\\\": \\\"1.8.0-beta\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"device_id\": \"serial-554-xyz\",\n        \"software\": {\n          \"os_version\": \"16.5\",\n          \"app_version\": \"3.1.0\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Device Registration\\\", \\\"version\\\": \\\"1.2.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"DeviceRegistration\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"device_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Device serial number\\\", \\\"example\\\": \\\"serial-554-xyz\\\" },\\n          \\\"software\\\": { \\\"$ref\\\": \\\"#/components/schemas/SoftwareInfo\\\" }\\n        }\\n      },\\n      \\\"SoftwareInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"os_version\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Operating system release version\\\", \\\"example\\\": \\\"16.5\\\" },\\n          \\\"app_version\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Application release version\\\", \\\"example\\\": \\\"3.1.0\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"flight_id\": \"FL-8821\",\n        \"available_classes\": [\n          \"Economy\",\n          \"Business\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'A basic flight search result'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Unique identifier for the flight'\\n          example: 'FL-8821'\\n        available_classes:\\n          type: array\\n          description: 'List of available seat classes'\\n          items:\\n            type: string\\n          example: ['Economy', 'Business']\"\n    },\n    {\n      \"raw_json\": {\n        \"flight_id\": \"FL-9902\",\n        \"available_classes\": [\n          \"Economy\",\n          \"Premium Economy\",\n          \"First\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'A basic flight search result'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Unique identifier for the flight'\\n          example: 'FL-9902'\\n        available_classes:\\n          type: array\\n          description: 'List of available seat classes'\\n          items:\\n            type: string\\n          example: ['Economy', 'Premium Economy', 'First']\"\n    },\n    {\n      \"raw_json\": {\n        \"flight_id\": \"FL-1144\",\n        \"available_classes\": [\n          \"Economy\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'A basic flight search result'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Unique identifier for the flight'\\n          example: 'FL-1144'\\n        available_classes:\\n          type: array\\n          description: 'List of available seat classes'\\n          items:\\n            type: string\\n          example: ['Economy']\"\n    }\n  ]\n}"
