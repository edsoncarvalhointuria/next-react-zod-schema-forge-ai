"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"status\": \"success\",\n        \"message\": \"Código enviado para o e-mail informado.\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Password Reset Success\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ResetSuccessResponse:\\n      type: object\\n      description: Resposta de sucesso após solicitação de reset.\\n      properties:\\n        status:\\n          type: string\\n          description: Status da operação.\\n          example: success\\n        message:\\n          type: string\\n          description: Mensagem informativa para o usuário.\\n          example: Código enviado para o e-mail informado.\"\n    },\n    {\n      \"raw_json\": {\n        \"error\": {\n          \"code\": \"AUTH_001\",\n          \"message\": \"E-mail não encontrado\",\n          \"context\": {\n            \"field\": \"email\",\n            \"timestamp\": \"2023-10-27T10:00:00Z\"\n          }\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Password Reset Error\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ErrorResponse:\\n      type: object\\n      description: Resposta de erro durante o processo de reset.\\n      properties:\\n        error:\\n          $ref: '#/components/schemas/ErrorDetails'\\n    ErrorDetails:\\n      type: object\\n      description: Detalhes técnicos do erro.\\n      properties:\\n        code:\\n          type: string\\n          description: Código de erro único.\\n          example: AUTH_001\\n        message:\\n          type: string\\n          description: Descrição legível do erro.\\n          example: E-mail não encontrado\\n        context:\\n          $ref: '#/components/schemas/ErrorContext'\\n    ErrorContext:\\n      type: object\\n      description: Contexto adicional do erro.\\n      properties:\\n        field:\\n          type: string\\n          description: Campo que causou o erro.\\n          example: email\\n        timestamp:\\n          type: string\\n          description: Momento em que o erro ocorreu.\\n          example: '2023-10-27T10:00:00Z'\"\n    },\n    {\n      \"raw_json\": {\n        \"session\": {\n          \"id\": \"abc-123\",\n          \"expires_at\": \"2023-10-27T11:00:00Z\"\n        },\n        \"verification\": {\n          \"is_valid\": true,\n          \"attempts_left\": 2\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Password Reset Verification\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    VerificationResponse:\\n      type: object\\n      description: Resposta sobre o estado da verificação do código.\\n      properties:\\n        session:\\n          $ref: '#/components/schemas/SessionInfo'\\n        verification:\\n          $ref: '#/components/schemas/VerificationStatus'\\n    SessionInfo:\\n      type: object\\n      description: Informações da sessão de reset.\\n      properties:\\n        id:\\n          type: string\\n          description: Identificador único da sessão.\\n          example: abc-123\\n        expires_at:\\n          type: string\\n          description: Data de expiração da sessão.\\n          example: '2023-10-27T11:00:00Z'\\n    VerificationStatus:\\n      type: object\\n      description: Status da validação do código.\\n      properties:\\n        is_valid:\\n          type: boolean\\n          description: Indica se o código é válido.\\n          example: true\\n        attempts_left:\\n          type: integer\\n          description: Tentativas restantes para o código.\\n          example: 2\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"message\": \"Rate limit exceeded. Please try again later.\",\n        \"retry_after\": 60\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Rate Limit API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"RateLimitWarning\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Standard rate limit warning\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The error message explaining the rate limit status\\\",\\n            \\\"example\\\": \\\"Rate limit exceeded. Please try again later.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"The number of seconds to wait before retrying the request\\\",\\n            \\\"example\\\": 60\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"message\": \"Too many requests. Account temporarily throttled.\",\n        \"retry_after\": 3600\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Throttling API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ThrottlingError\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Error response for account throttling\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Detailed explanation of the throttling event\\\",\\n            \\\"example\\\": \\\"Too many requests. Account temporarily throttled.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Wait time in seconds\\\",\\n            \\\"example\\\": 3600\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"message\": \"Quota exhausted.\",\n        \"retry_after\": 300\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Quota API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"QuotaExhaustedResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response when quota is reached\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Notification of quota depletion\\\",\\n            \\\"example\\\": \\\"Quota exhausted.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Seconds until quota resets\\\",\\n            \\\"example\\\": 300\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
