"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"user_id\": \"user_8821\",\n        \"preferences\": {\n          \"theme\": \"dark\",\n          \"language\": \"en-US\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Settings API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Preferences:\\n      type: object\\n      description: 'User interface and localization settings'\\n      properties:\\n        theme:\\n          type: string\\n          description: 'The visual theme mode'\\n          example: 'dark'\\n        language:\\n          type: string\\n          description: 'The ISO language code'\\n          example: 'en-US'\\n    UserSettings:\\n      type: object\\n      description: 'Root object for user settings'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'user_8821'\\n        preferences:\\n          $ref: '#/components/schemas/Preferences'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_550\",\n        \"preferences\": {\n          \"theme\": \"light\",\n          \"language\": \"fr-FR\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Settings API\\n  version: 1.1.0\\ncomponents:\\n  schemas:\\n    Preferences:\\n      type: object\\n      description: 'User interface and localization settings'\\n      properties:\\n        theme:\\n          type: string\\n          description: 'The visual theme mode'\\n          example: 'light'\\n        language:\\n          type: string\\n          description: 'The ISO language code'\\n          example: 'fr-FR'\\n    UserSettings:\\n      type: object\\n      description: 'Root object for user settings'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'usr_550'\\n        preferences:\\n          $ref: '#/components/schemas/Preferences'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"acc_9912\",\n        \"preferences\": {\n          \"theme\": \"system\",\n          \"language\": \"de-DE\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Settings API\\n  version: 1.2.0\\ncomponents:\\n  schemas:\\n    Preferences:\\n      type: object\\n      description: 'User interface and localization settings'\\n      properties:\\n        theme:\\n          type: string\\n          description: 'The visual theme mode'\\n          example: 'system'\\n        language:\\n          type: string\\n          description: 'The ISO language code'\\n          example: 'de-DE'\\n    UserSettings:\\n      type: object\\n      description: 'Root object for user settings'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'acc_9912'\\n        preferences:\\n          $ref: '#/components/schemas/Preferences'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"deviceId\": \"dev-9982-abc\",\n        \"software\": {\n          \"osVersion\": \"14.2.1\",\n          \"appVersion\": \"2.5.0\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Device Registration\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SoftwareInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações sobre o sistema operacional e a versão do aplicativo\\\",\\n        \\\"properties\\\": {\\n          \\\"osVersion\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Versão do sistema operacional instalado\\\", \\\"example\\\": \\\"14.2.1\\\" },\\n          \\\"appVersion\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Versão atual do aplicativo\\\", \\\"example\\\": \\\"2.5.0\\\" }\\n        }\\n      },\\n      \\\"DeviceRegistration\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Payload de registro de dispositivo\\\",\\n        \\\"properties\\\": {\\n          \\\"deviceId\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Identificador único do dispositivo\\\", \\\"example\\\": \\\"dev-9982-abc\\\" },\\n          \\\"software\\\": { \\\"$ref\\\": \\\"#/components/schemas/SoftwareInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"deviceId\": \"uuid-5541-xyz\",\n        \"software\": {\n          \"osVersion\": \"Android 13\",\n          \"appVersion\": \"1.0.8-beta\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Device Registration\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SoftwareInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\"