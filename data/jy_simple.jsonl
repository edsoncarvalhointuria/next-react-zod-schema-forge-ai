"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"message\": \"You have exceeded the API rate limit.\",\n        \"retry_after\": 60\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"API Rate Limit Warning\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"RateLimitWarning\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Warning response when API rate limit is exceeded.\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Warning message about the rate limit.\\\",\\n            \\\"example\\\": \\\"You have exceeded the API rate limit.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Seconds to wait before retrying.\\\",\\n            \\\"example\\\": 60\\n          }\\n        },\\n        \\\"required\\\": [\\\"message\\\", \\\"retry_after\\\"]\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"message\": \"Rate limit reached, please wait before retrying.\",\n        \"retry_after\": 120\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"API Rate Limit Warning\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"RateLimitWarning\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Warning response indicating the API rate limit has been exceeded.\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Notification message about rate limit breach.\\\",\\n            \\\"example\\\": \\\"Rate limit reached, please wait before retrying.\\\"\\n          },\\n  