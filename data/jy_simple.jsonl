"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_8821\",\n        \"skus\": [\"PROD-001\", \"PROD-005\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Simple\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'Resumo simples do carrinho de compras contendo o ID e a lista de SKUs'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Identificador único da sessão do carrinho'\\n          example: 'cart_8821'\\n        skus:\\n          type: array\\n          description: 'Lista de códigos de estoque dos produtos'\\n          items:\\n            type: string\\n            example: 'PROD-001'\"\n    },\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_9932\",\n        \"skus\": [\"BOOK-12\", \"PEN-04\", \"NOTE-09\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Simple\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'Resumo simples do carrinho de compras contendo o ID e a lista de SKUs'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Identificador único da sessão do carrinho'\\n          example: 'cart_9932'\\n        skus:\\n          type: array\\n          description: 'Lista de códigos de estoque dos produtos'\\n          items:\\n            type: string\\n            example: 'BOOK-12'\"\n    },\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_4450\",\n        \"skus\": [\"ELEC-99\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Simple\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'Resumo simples do carrinho de compras contendo o ID e a lista de SKUs'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Identificador úni