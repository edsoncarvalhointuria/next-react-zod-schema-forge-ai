"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"product_id\": \"PROD-9921\",\n        \"price_details\": {\n          \"amount\": 150.50,\n          \"currency\": \"BRL\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Product Price Update\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PriceInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"amount\\\": { \\\"type\\\": \\\"number\\\", \\\"description\\\": \\\"Valor numérico do preço do produto\\\", \\\"example\\\": 150.50 },\\n          \\\"currency\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código da moeda (ISO 4217)\\\", \\\"example\\\": \\\"BRL\\\" }\\n        }\\n      },\\n      \\\"ProductUpdate\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"product_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Identificador único do produto\\\", \\\"example\\\": \\\"PROD-9921\\\" },\\n          \\\"price_details\\\": { \\\"$ref\\\": \\\"#/components/schemas/PriceInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"product_id\": \"SKU-8842\",\n        \"price_details\": {\n          \"amount\": 29.99,\n          \"currency\": \"USD\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Product Price Update\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PriceInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"amount\\\": { \\\"type\\\": \\\"number\\\", \\\"description\\\": \\\"Valor monetário do item\\\", \\\"example\\\": 29.99 },\\n          \\\"currency\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Moeda in