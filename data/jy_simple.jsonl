"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"user_id\": \"user_88291\",\n        \"reason\": \"Privacy concerns\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Basic Deletion Confirmation\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    DeletionConfirmation:\\n      type: object\\n      description: 'A simple confirmation of account deletion'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'The unique identifier of the deleted user'\\n          example: 'user_88291'\\n        reason:\\n          type: string\\n          description: 'The reason provided by the user for deletion'\\n          example: 'Privacy concerns'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"user_44521\",\n        \"reason\": \"I no longer use this service\",\n        \"deleted_at\": \"2023-11-15T08:30:00Z\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Timestamped Deletion Confirmation\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    DeletionConfirmationWithTimestamp:\\n      type: object\\n      description: 'Confirmation of account deletion including the time of action'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'The unique identifier of the deleted user'\\n          example: 'user_44521'\\n        reason:\\n          type: string\\n          description: 'The reason provided by the user for deletion'\\n          example: 'I no longer use this service'\\n        deleted_at:\\n          type: string\\n          description: 'The ISO 8601 timestamp when the deletion was processed'\\n          example: '2023-11-15T08:30:00Z'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"user_00923\",\n        \"reason\": \"Too many notifications\",\n        \"status\": \"completed\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Status-based Deletion Confirmation\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    DeletionConfirmationWithStatus:\\n      type: object\\n      description: 'Confirmation of account deletion including the final status'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'The unique identifier of the deleted user'\\n          example: 'user_00923'\\n        reason:\\n          type: string\\n          description: 'The reason provided by the user for deletion'\\n          example: 'Too many notifications'\\n        status:\\n          type: string\\n          description: 'The current state of the deletion process'\\n          example: 'completed'\"\n    }\n  ]\n}"
