"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"email\": \"user@example.com\",\n        \"reset_code\": \"123456\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Password Reset API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PasswordResetRequest:\\n      type: object\\n      description: 'Request to reset password using email and code'\\n      properties:\\n        email:\\n          type: string\\n          format: email\\n          description: 'The user email address'\\n          example: 'user@example.com'\\n        reset_code:\\n          type: string\\n          description: 'The temporary reset code'\\n          example: '123456'\"\n    },\n    {\n      \"raw_json\": {\n        \"email_address\": \"contact@provider.net\",\n        \"otp_code\": \"882910\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: OTP Verification API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    OtpVerification:\\n      type: object\\n      description: 'Payload for OTP verification'\\n      properties:\\n        email_address:\\n          type: string\\n          format: email\\n          description: 'The email address for verification'\\n          example: 'contact@provider.net'\\n        otp_code:\\n          type: string\\n          description: 'The one-time password code'\\n          example: '882910'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_email\": \"security@corp.com\",\n        \"temp_code\": \"A1B2C3\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Security Recovery API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    SecurityRecovery:\\n      type: object\\n      description: 'Payload for security-based account recovery'\\n      properties:\\n        user_email:\\n          type: string\\n          format: email\\n          description: 'The user email address'\\n          example: 'security@corp.com'\\n        temp_code:\\n          type: string\\n          description: 'The temporary security code'\\n          example: 'A1B2C3'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"message\": \"Too many requests. Please slow down.\",\n        \"retry_after\": 60\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Rate Limit API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"RateLimitWarning\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Standard rate limit warning response\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The error message explaining the rate limit\\\",\\n            \\\"example\\\": \\\"Too many requests. Please slow down.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Seconds to wait before retrying\\\",\\n            \\\"example\\\": 60\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"message\": \"Rate limit exceeded. Account temporarily suspended.\",\n        \"retry_after\": 3600\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Rate Limit API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"CriticalRateLimitError\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Critical rate limit error response\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The error message explaining the rate limit\\\",\\n            \\\"example\\\": \\\"Rate limit exceeded. Account temporarily suspended.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n    