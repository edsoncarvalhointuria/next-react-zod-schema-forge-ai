"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Operation completed successfully\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Success Response\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    SuccessResponse:\\n      type: object\\n      description: 'A standard response for successful operations'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'Indicates if the operation was successful'\\n          example: true\\n        message:\\n          type: string\\n          description: 'A descriptive message about the result'\\n          example: 'Operation completed successfully'\"\n    },\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Data updated successfully\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Success Response\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    StatusResponse:\\n      type: object\\n      description: 'A response indicating the status of a data update'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'Flag indicating the success of the update'\\n          example: true\\n        message:\\n          type: string\\n          description: 'Message confirming the update status'\\n          example: 'Data updated successfully'\"\n    },\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Task finished\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Success Response\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ActionResponse:\\n      type: object\\n      description: 'A response confirming the completion of a task'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'Whether the task was completed successfully'\\n          example: true\\n        message:\\n          type: string\\n          description: 'A brief message regarding the task completion'\\n          example: 'Task finished'\"\n    }\n  ]\n}"
