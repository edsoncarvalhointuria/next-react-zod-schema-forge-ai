"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_99281\",\n        \"skus\": [\n          \"SHIRT-BLU-L\",\n          \"PANT-BLK-32\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Identificador único do carrinho de compras'\\n          example: 'cart_99281'\\n        skus:\\n          type: array\\n          items:\\n            type: string\\n          description: 'Lista de SKUs dos produtos adicionados ao carrinho'\\n          example: ['SHIRT-BLU-L', 'PANT-BLK-32']\"\n    },\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_44502\",\n        \"skus\": [\n          \"BOOK-TECH-001\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Identificador único do carrinho de compras'\\n          example: 'cart_44502'\\n        skus:\\n          type: array\\n          items:\\n            type: string\\n          description: 'Lista de SKUs dos produtos adicionados ao carrinho'\\n          example: ['BOOK-TECH-001']\"\n    },\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_11239\",\n        \"skus\": [\n          \"ELEC-PHN-X\",\n          \"ELEC-CHG-W\",\n          \"ELEC-CS-PRO\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Identificador único do carrinho de compras'\\n          example: 'cart_11239'\\n        skus:\\n          type: array\\n          items:\\n            type: string\\n          description: 'Lista de SKUs dos produtos adicionados ao carrinho'\\n          example: ['ELEC-PHN-X', 'ELEC-CHG-W', 'ELEC-CS-PRO']\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"product_id\": \"PROD-9921\",\n        \"price_details\": {\n          \"amount\": 150.50,\n          \"currency\": \"BRL\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Product Price Update\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PriceInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"amount\\\": { \\\"type\\\": \\\"number\\\", \\\"description\\\": \\\"Valor monetário do produto\\\", \\\"example\\\": 150.50 },\\n          \\\"currency\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código da moeda (ISO 4217)\\\", \\\"example\\\": \\\"BRL\\\" }\\n        }\\n      },\\n      \\\"ProductPriceUpdate\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"product_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Identificador único do produto\\\", \\\"example\\\": \\\"PROD-9921\\\" },\\n          \\\"price_details\\\": { \\\"$ref\\\": \\\"#/components/schemas/PriceInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"product_id\": \"SKU-8842\",\n        \"price_details\": {\n          \"amount\": 29.99,\n          \"currency\": \"USD\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Product Price Update\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PriceInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"amount\\\": { \\\"type\\\": \\\"number\\\", \\\"description\\\": \\\"Valor monetário do produto\\\", \\\"example\\\": 29.99 },\\n          \\\"currency\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código d