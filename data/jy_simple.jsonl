"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_882\",\n        \"author_info\": {\n          \"name\": \"Alice Smith\",\n          \"comment_text\": \"Great insights on API design!\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AuthorInfo:\\n      type: object\\n      description: 'Details about the comment author'\\n      properties:\\n        name:\\n          type: string\\n          description: 'The display name of the author'\\n          example: 'Alice Smith'\\n        comment_text:\\n          type: string\\n          description: 'The body content of the comment'\\n          example: 'Great insights on API design!'\\n    CommentSubmission:\\n      type: object\\n      description: 'Request payload for submitting a blog comment'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Unique identifier of the blog post'\\n          example: 'post_882'\\n        author_info:\\n          $ref: '#/components/schemas/AuthorInfo'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_104\",\n        \"author_info\": {\n          \"name\": \"Bob Johnson\",\n          \"comment_text\": \"Could you elaborate more on the security aspects?\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AuthorInfo:\\n      type: object\\n      description: 'Details about the comment author'\\n      properties:\\n        name:\\n          type: string\\n          description: 'The display name of the author'\\n          example: 'Bob Johnson'\\n        comment_text:\\n          type: string\\n          description: 'The body content of the comment'\\n          example: 'Could you elaborate more on the security aspects?'\\n    CommentSubmission:\\n      type: object\\n      description: 'Request payload for submitting a blog comment'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Unique identifier of the blog post'\\n          example: 'post_104'\\n        author_info:\\n          $ref: '#/components/schemas/AuthorInfo'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_559\",\n        \"author_info\": {\n          \"name\": \"Charlie Davis\",\n          \"comment_text\": \"This tutorial was very helpful, thanks!\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AuthorInfo:\\n      type: object\\n      description: 'Details about the comment author'\\n      properties:\\n        name:\\n          type: string\\n          description: 'The display name of the author'\\n          example: 'Charlie Davis'\\n        comment_text:\\n          type: string\\n          description: 'The body content of the comment'\\n          example: 'This tutorial was very helpful, thanks!'\\n    CommentSubmission:\\n      type: object\\n      description: 'Request payload for submitting a blog comment'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Unique identifier of the blog post'\\n          example: 'post_559'\\n        author_info:\\n          $ref: '#/components/schemas/AuthorInfo'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"order_id\": \"ORD-7721\",\n        \"tracking\": {\n          \"status\": \"in_transit\",\n          \"estimated_delivery\": \"2023-11-15\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Order Status API\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TrackingInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações de rastreamento do pedido\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Status atual do envio\\\", \\\"example\\\": \\\"in_transit\\\" },\\n          \\\"estimated_delivery\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Data prevista para entrega\\\", \\\"example\\\": \\\"2023-11-15\\\" }\\n        }\\n      },\\n      \\\"OrderStatus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta contendo o status do pedido\\\",\\n        \\\"properties\\\": {\\n          \\\"order_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Identificador único do pedido\\\", \\\"example\\\": \\\"ORD-7721\\\" },\\n          \\\"tracking\\\": { \\\"$ref\\\": \\\"#/components/schemas/TrackingInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"order_id\": \"ORD-9902\",\n        \"tracking\": {\n          \"status\": \"delivered\",\n          \"estimated_delivery\": \"2023-10-20\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Order Status API\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TrackingInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações de rastreamento do pedid