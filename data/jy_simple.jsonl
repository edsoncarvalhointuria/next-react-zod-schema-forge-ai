"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_8821\",\n        \"comment_details\": {\n          \"author_name\": \"Carlos Silva\",\n          \"content\": \"Excelente artigo, muito esclarecedor!\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'Detalhes do autor e o corpo do comentário'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'Nome do autor do comentário'\\n          example: 'Carlos Silva'\\n        content:\\n          type: string\\n          description: 'Texto do comentário enviado'\\n          example: 'Excelente artigo, muito esclarecedor!'\\n    CommentSubmission:\\n      type: object\\n      description: 'Payload para envio de comentário em um post'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Identificador único do post'\\n          example: 'post_8821'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_4492\",\n        \"comment_details\": {\n          \"author_name\": \"Ana Oliveira\",\n          \"content\": \"Poderia detalhar mais sobre a seção de segurança?\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'Estrutura contendo os dados do autor e a mensagem'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'Nome completo do autor'\\n          example: 'Ana Oliveira'\\n        content:\\n          type: string\\n          description: 'Conteúdo da mensagem do usuário'\\n          example: 'Poderia detalhar mais sobre a seção de segurança?'\\n    CommentSubmission:\\n      type: object\\n      description: 'Objeto de envio de comentário'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'ID do post alvo'\\n          example: 'post_4492'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_1023\",\n        \"comment_details\": {\n          \"author_name\": \"Ricardo Souza\",\n          \"content\": \"Obrigado pelo tutorial, funcionou perfeitamente.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'Dados do autor e texto do comentário'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'Nome do autor'\\n          example: 'Ricardo Souza'\\n        content:\\n          type: string\\n          description: 'Texto do comentário'\\n          example: 'Obrigado pelo tutorial, funcionou perfeitamente.'\\n    CommentSubmission:\\n      type: object\\n      description: 'Requisição de submissão de comentário'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'ID do post relacionado'\\n          example: 'post_1023'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    }\n  ]\n}"
