"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"success\": true\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LogoutResponse:\\n      type: object\\n      description: 'Simple confirmation of session termination'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'Indicates whether the session token was successfully invalidated'\\n          example: true\"\n    },\n    {\n      \"raw_json\": {\n        \"message\": \"Successfully logged out\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LogoutResponse:\\n      type: object\\n      description: 'Response containing a human-readable logout message'\\n      properties:\\n        message:\\n          type: string\\n          description: 'The confirmation message returned after logout'\\n          example: 'Successfully logged out'\"\n    },\n    {\n      \"raw_json\": {\n        \"status\": \"terminated\",\n        \"timestamp\": \"2023-11-01T15:30:00Z\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LogoutResponse:\\n      type: object\\n      description: 'Detailed response providing session status and termination time'\\n      properties:\\n        status:\\n          type: string\\n          description: 'The current state of the session token'\\n          example: 'terminated'\\n        timestamp:\\n          type: string\\n          format: date-time\\n          description: 'The ISO 8601 timestamp when the logout occurred'\\n          example: '2023-11-01T15:30:00Z'\"\n    }\n  ]\n}"
