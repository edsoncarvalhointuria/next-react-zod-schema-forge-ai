"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_8821\",\n        \"skus\": [\n          \"PROD-001\",\n          \"PROD-005\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'Resumo do carrinho de compras contendo identificador e produtos'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Identificador único do carrinho'\\n          example: 'cart_8821'\\n        skus:\\n          type: array\\n          description: 'Lista de SKUs dos produtos adicionados ao carrinho'\\n          items:\\n            type: string\\n          example: ['PROD-001', 'PROD-005']\"\n    },\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_9942\",\n        \"skus\": [\n          \"ELEC-99\",\n          \"HOME-12\",\n          \"BOOK-04\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'Resumo do carrinho de compras contendo identificador e produtos'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Identificador único do carrinho'\\n          example: 'cart_9942'\\n        skus:\\n          type: array\\n          description: 'Lista de SKUs dos produtos adicionados ao carrinho'\\n          items:\\n            type: string\\n          example: ['ELEC-99', 'HOME-12', 'BOOK-04']\"\n    },\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_1103\",\n        \"skus\": [\n          \"TOY-55\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'Resumo do carrinho de compras contendo identificador e