"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"product_id\": \"PROD-9921\",\n        \"price_details\": {\n          \"amount\": 150.50,\n          \"currency\": \"BRL\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Product Price Update\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PriceInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"amount\\\": { \\\"type\\\": \\\"number\\\", \\\"description\\\": \\\"Valor numérico do preço\\\", \\\"example\\\": 150.50 },\\n          \\\"currency\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código da moeda (ISO 4217)\\\", \\\"example\\\": \\\"BRL\\\" }\\n        }\\n      },\\n      \\\"ProductUpdate\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"product_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Identificador único do produto\\\", \\\"example\\\": \\\"PROD-9921\\\" },\\n          \\\"price_details\\\": { \\\"$ref\\\": \\\"#/components/schemas/PriceInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"product_id\": \"SKU-8842\",\n        \"price_details\": {\n          \"amount\": 29.99,\n          \"currency\": \"USD\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Product Price Update\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PriceInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"amount\\\": { \\\"type\\\": \\\"number\\\", \\\"description\\\": \\\"Valor do produto\\\", \\\"example\\\": 29.99 },\\n          \\\"currency\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Moeda da transação\\\", \\\"example\\\": \\\"USD\\\" }\\n        }\\n      },\\n      \\\"ProductUpdate\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"product_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"ID do produto no sistema\\\", \\\"example\\\": \\\"SKU-8842\\\" },\\n          \\\"price_details\\\": { \\\"$ref\\\": \\\"#/components/schemas/PriceInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"product_id\": \"ITEM-001\",\n        \"price_details\": {\n          \"amount\": 5000,\n          \"currency\": \"EUR\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Product Price Update\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PriceInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"amount\\\": { \\\"type\\\": \\\"number\\\", \\\"description\\\": \\\"Preço atualizado\\\", \\\"example\\\": 5000 },\\n          \\\"currency\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Símbolo da moeda\\\", \\\"example\\\": \\\"EUR\\\" }\\n        }\\n      },\\n      \\\"ProductUpdate\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"product_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código identificador do item\\\", \\\"example\\\": \\\"ITEM-001\\\" },\\n          \\\"price_details\\\": { \\\"$ref\\\": \\\"#/components/schemas/PriceInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"city\": \"London\",\n        \"weather_data\": {\n          \"temperature\": 15.5,\n          \"humidity\": 82\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherData:\\n      type: object\\n      description: 'Current atmospheric conditions'\\n      properties:\\n        temperature:\\n          type: number\\n          description: 'Temperature in Celsius'\\n          example: 15.5\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 82\\n    WeatherResponse:\\n      type: object\\n      description: 'Weather widget data payload'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'London'\\n        weather_data:\\n          $ref: '#/components/schemas/WeatherData'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"Tokyo\",\n        \"weather_data\": {\n          \"temperature\": 22.0,\n          \"humidity\": 60\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherData:\\n      type: object\\n      description: 'Current atmospheric conditions'\\n      properties:\\n        temperature:\\n          type: number\\n          description: 'Temperature in Celsius'\\n          example: 22.0\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 60\\n    WeatherResponse:\\n      type: object\\n      description: 'Weather widget data payload'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'Tokyo'\\n        weather_data:\\n          $ref: '#/components/schemas/WeatherData'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"New York\",\n        \"weather_data\": {\n          \"temperature\": 10.2,\n          \"humidity\": 45\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherData:\\n      type: object\\n      description: 'Current atmospheric conditions'\\n      properties:\\n        temperature:\\n          type: number\\n          description: 'Temperature in Celsius'\\n          example: 10.2\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 45\\n    WeatherResponse:\\n      type: object\\n      description: 'Weather widget data payload'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'New York'\\n        weather_data:\\n          $ref: '#/components/schemas/WeatherData'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"error_code\": \"AUTH_FAILURE\",\n        \"details\": {\n          \"messages\": [\"Token expirado\", \"Sessão inválida\"]\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Error Response\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorDetail\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"messages\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de mensagens de erro detalhadas\\\",\\n            \\\"items\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Descrição do erro\\\", \\\"example\\\": \\\"Token expirado\\\" }\\n          }\\n        }\\n      },\\n      \\\"ErrorResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código identificador do erro\\\", \\\"example\\\": \\\"AUTH_FAILURE\\\" },\\n          \\\"details\\\": { \\\"$ref\\\": \\\"#/components/schemas/ErrorDetail\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"error_code\": \"DATABASE_TIMEOUT\",\n        \"details\": {\n          \"messages\": [\"Conexão excedeu o tempo limite\", \"Tente novamente mais tarde\"]\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Database Error\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorDetail\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"messages\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de mensagens de erro do sistema\\\",\\n            \\\"items\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Mensagem de erro\\\", \\\"example\\\": \\\"Conexão excedeu o tempo limite\\\" }\\n          }\\n        }\\n      },\\n      \\\"ErrorResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código do erro de banco de dados\\\", \\\"example\\\": \\\"DATABASE_TIMEOUT\\\" },\\n          \\\"details\\\": { \\\"$ref\\\": \\\"#/components/schemas/ErrorDetail\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"error_code\": \"PAYMENT_REJECTED\",\n        \"details\": {\n          \"messages\": [\"Saldo insuficiente\", \"Cartão bloqueado\"]\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Payment Error\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorDetail\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"messages\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de motivos da falha no pagamento\\\",\\n            \\\"items\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Motivo da falha\\\", \\\"example\\\": \\\"Saldo insuficiente\\\" }\\n          }\\n        }\\n      },\\n      \\\"ErrorResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código de erro da transação\\\", \\\"example\\\": \\\"PAYMENT_REJECTED\\\" },\\n          \\\"details\\\": { \\\"$ref\\\": \\\"#/components/schemas/ErrorDetail\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_987\",\n        \"comment_details\": {\n          \"author_name\": \"Alice Johnson\",\n          \"text\": \"This is a very insightful article!\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'The content and author information of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The display name of the comment author'\\n          example: 'Alice Johnson'\\n        text:\\n          type: string\\n          description: 'The body text of the comment'\\n          example: 'This is a very insightful article!'\\n    CommentSubmission:\\n      type: object\\n      description: 'The root object for a blog comment submission'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Unique identifier of the blog post'\\n          example: 'post_987'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_456\",\n        \"comment_details\": {\n          \"author_name\": \"Bob Smith\",\n          \"text\": \"I disagree with the third point.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'The content and author information of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The display name of the comment author'\\n          example: 'Bob Smith'\\n        text:\\n          type: string\\n          description: 'The body text of the comment'\\n          example: 'I disagree with the third point.'\\n    CommentSubmission:\\n      type: object\\n      description: 'The root object for a blog comment submission'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Unique identifier of the blog post'\\n          example: 'post_456'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_111\",\n        \"comment_details\": {\n          \"author_name\": \"Charlie Davis\",\n          \"text\": \"Great read, thanks for sharing.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'The content and author information of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The display name of the comment author'\\n          example: 'Charlie Davis'\\n        text:\\n          type: string\\n          description: 'The body text of the comment'\\n          example: 'Great read, thanks for sharing.'\\n    CommentSubmission:\\n      type: object\\n      description: 'The root object for a blog comment submission'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Unique identifier of the blog post'\\n          example: 'post_111'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"order_id\": \"ORD-7721\",\n        \"tracking\": {\n          \"status\": \"in_transit\",\n          \"estimated_delivery\": \"2023-11-15\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Order Status API\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TrackingInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Shipping and delivery details\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Current shipment status\\\", \\\"example\\\": \\\"in_transit\\\" },\\n          \\\"estimated_delivery\\\": { \\\"type\\\": \\\"string\\\", \\\"format\\\": \\\"date\\\", \\\"description\\\": \\\"Expected arrival date\\\", \\\"example\\\": \\\"2023-11-15\\\" }\\n        }\\n      },\\n      \\\"OrderResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Order status response\\\",\\n        \\\"properties\\\": {\\n          \\\"order_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Unique identifier for the order\\\", \\\"example\\\": \\\"ORD-7721\\\" },\\n          \\\"tracking\\\": { \\\"$ref\\\": \\\"#/components/schemas/TrackingInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"order_id\": \"ORD-9902\",\n        \"tracking\": {\n          \"status\": \"delivered\",\n          \"estimated_delivery\": \"2023-10-20\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Order Status API\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TrackingInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Shipping and delivery detail