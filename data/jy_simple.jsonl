"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"email\": \"usuario@exemplo.com.br\",\n        \"reset_code\": \"482910\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Password Reset API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PasswordResetRequest:\\n      type: object\\n      description: 'Solicitação de redefinição de senha contendo e-mail e código'\\n      properties:\\n        email:\\n          type: string\\n          format: email\\n          description: 'Endereço de e-mail do usuário'\\n          example: 'usuario@exemplo.com.br'\\n        reset_code:\\n          type: string\\n          description: 'Código temporário de redefinição'\\n          example: '482910'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_email\": \"contato@empresa.io\",\n        \"verification_code\": \"XP-9921\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Password Reset API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ResetPasswordPayload:\\n      type: object\\n      description: 'Payload para verificação de recuperação de senha'\\n      properties:\\n        user_email:\\n          type: string\\n          format: email\\n          description: 'E-mail do usuário solicitante'\\n          example: 'contato@empresa.io'\\n        verification_code:\\n          type: string\\n          description: 'Código de verificação alfanumérico'\\n          example: 'XP-9921'\"\n    },\n    {\n      \"raw_json\": {\n        \"email\": \"admin@sistema.net\",\n        \"code\": 883721\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Password Reset API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PasswordRecovery:\\n      type: object\\n      description: 'Dados necessários para recuperar a senha do usuário'\\n      properties:\\n        email:\\n          type: string\\n          format: email\\n          description: 'E-mail cadastrado no sistema'\\n          example: 'admin@sistema.ne