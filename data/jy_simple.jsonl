"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_99281\",\n        \"items\": [\n          \"SKU-A100\",\n          \"SKU-B200\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'A summary of the current shopping cart'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Unique identifier for the shopping cart'\\n          example: 'cart_99281'\\n        items:\\n          type: array\\n          description: 'List of product SKUs currently in the cart'\\n          items:\\n            type: string\\n          example: ['SKU-A100', 'SKU-B200']\"\n    },\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_55432\",\n        \"items\": [\n          \"LAPTOP-PRO-15\",\n          \"MOUSE-WL-01\",\n          \"KEYBOARD-MECH-05\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'A summary of the current shopping cart'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Unique identifier for the shopping cart'\\n          example: 'cart_55432'\\n        items:\\n          type: array\\n          description: 'List of product SKUs currently in the cart'\\n          items:\\n            type: string\\n          example: ['LAPTOP-PRO-15', 'MOUSE-WL-01', 'KEYBOARD-MECH-05']\"\n    },\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_11009\",\n        \"items\": [\n          \"BOOK-SCI-FI-09\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'A summary of the current shopping cart'\\n      