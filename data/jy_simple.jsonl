"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"email\": \"usuario@exemplo.com\",\n        \"newsletter_opt_in\": true\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"API de Assinatura de Newsletter\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SubscriptionPayload\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Payload para inscrição de e-mail em newsletter\\\",\\n        \\\"properties\\\": {\\n          \\\"email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"email\\\",\\n            \\\"description\\\": \\\"Endereço de e-mail do usuário para cadastro\\\",\\n            \\\"example\\\": \\\"usuario@exemplo.com\\\"\\n          },\\n          \\\"newsletter_opt_in\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Indica se o usuário concorda em receber a newsletter\\\",\\n            \\\"example\\\": true\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"email\": \"contato@empresa.com.br\",\n        \"newsletter_opt_in\": false\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"API de Assinatura de Newsletter\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SubscriptionPayload\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Payload para inscrição de e-mail em newsletter\\\",\\n        \\\"properties\\\": {\\n          \\\"email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"email\\\",\\n            \\\"description\\\": \\\"Endereço de e-mail do usuário para cadastro\\\",\\n            \\\"example\\\": \\\"contato@empresa.com.br\\\"\\n          },\\n          \\\"newsletter_opt_in\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Indica se o usuário concorda em receber a newsletter\\\",\\n            \\\"example\\\": false\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"email\": \"dev.senior@tech.io\",\n        \"newsletter_opt_in\": true\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"API de Assinatura de Newsletter\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SubscriptionPayload\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Payload para inscrição de e-mail em newsletter\\\",\\n        \\\"properties\\\": {\\n          \\\"email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"email\\\",\\n            \\\"description\\\": \\\"Endereço de e-mail do usuário para cadastro\\\",\\n            \\\"example\\\": \\\"dev.senior@tech.io\\\"\\n          },\\n          \\\"newsletter_opt_in\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Indica se o usuário concorda em receber a newsletter\\\",\\n            \\\"example\\\": true\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"session_token\": \"abc123xyz789\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LogoutRequest:\\n      type: object\\n      description: Requisição de logout do usuário\\n      properties:\\n        session_token:\\n          type: string\\n          description: Token de sessão utilizado para invalidar o acesso do usuário\\n          example: abc123xyz789\"\n    },\n    {\n      \"raw_json\": {\n        \"auth_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Auth Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AuthLogout:\\n      type: object\\n      description: Requisição de encerramento de sessão autenticada\\n      properties:\\n        auth_token:\\n          type: string\\n          description: Token de autenticação JWT para encerramento da sessão\\n          example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9\"\n    },\n    {\n      \"raw_json\": {\n        \"access_token\": \"token_987654321_secure\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Session Termination API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    SessionTermination:\\n      type: object\\n      description: Requisição para terminação de sessão\\n      properties:\\n        access_token:\\n          type: string\\n          description: Token de acesso utilizado para deslogar o dispositivo atual\\n          example: token_987654321_secure\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"feature_name\": \"dark_mode_ui\",\n        \"enabled\": true\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Feature Flag API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"FeatureFlag\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response indicating the status of a specific feature flag\\\",\\n        \\\"properties\\\": {\\n          \\\"feature_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The unique identifier of the feature\\\",\\n            \\\"example\\\": \\\"dark_mode_ui\\\"\\n          },\\n          \\\"enabled\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Whether the feature is currently active\\\",\\n            \\\"example\\\": true\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"flag_id\": \"beta_payment_gateway\",\n        \"is_active\": false\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Feature Toggle API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"FeatureToggle\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"A simple toggle state for a system feature\\\",\\n        \\\"properties\\\": {\\n          \\\"flag_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The internal ID of the feature flag\\\",\\n            \\\"example\\\": \\\"beta_payment_gateway\\\"\\n          },\\n          \\\"is_active\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"The current activation state of the flag\\\",\\n            \\\"example\\\": false\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"feature_key\": \"ai_chat_assistant\",\n        \"status\": true\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Feature Status API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"FeatureStatus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"The operational status of a specific feature key\\\",\\n        \\\"properties\\\": {\\n          \\\"feature_key\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The key used to look up the feature configuration\\\",\\n            \\\"example\\\": \\\"ai_chat_assistant\\\"\\n          },\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"True if the feature is enabled, false otherwise\\\",\\n            \\\"example\\\": true\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_882194\",\n        \"reason\": \"I no longer use this service.\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Account Deletion API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AccountDeletionRequest:\\n      type: object\\n      description: 'Simple payload for account deletion confirmation'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'The unique identifier of the user account to be deleted'\\n          example: 'usr_882194'\\n        reason:\\n          type: string\\n          description: 'The reason provided by the user for deleting their account'\\n          example: 'I no longer use this service.'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_441023\",\n        \"reason\": \"Privacy concerns regarding data usage\",\n        \"confirmed\": true,\n        \"request_timestamp\": \"2023-11-15T14:30:00Z\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Account Deletion API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AccountDeletionConfirmation:\\n      type: object\\n      description: 'Detailed account deletion confirmation payload'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'The unique identifier of the user account'\\n          example: 'usr_441023'\\n        reason:\\n          type: string\\n          description: 'The reason for the deletion request'\\n          example: 'Privacy concerns regarding data usage'\\n        confirmed:\\n          type: boolean\\n          description: 'Indicates if the user has explicitly confirmed the action'\\n          example: true\\n        request_timestamp:\\n          type: string\\n          format: date-time\\n          description: 'The ISO 8601 timestamp when the request was made'\\n          example: '2023-11-15T14:30:00Z'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_990122\",\n        \"deletion_details\": {\n          \"reason\": \"Switching to a competitor\",\n          \"category\": \"Competitive\",\n          \"feedback\": \"The pricing is too high for the current feature set.\"\n        },\n        \"metadata\": {\n          \"ip_address\": \"192.168.1.45\",\n          \"user_agent\": \"Mozilla/5.0 (Windows NT 10.0; Win64; x64)\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Account Deletion API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AccountDeletionPayload:\\n      type: object\\n      description: 'Complex account deletion payload with nested metadata'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'The unique identifier of the user account'\\n          example: 'usr_990122'\\n        deletion_details:\\n          $ref: '#/components/schemas/DeletionDetails'\\n        metadata:\\n          $ref: '#/components/schemas/RequestMetadata'\\n    DeletionDetails:\\n      type: object\\n      description: 'Specific details regarding the reason for deletion'\\n      properties:\\n        reason:\\n          type: string\\n          description: 'The textual reason for deletion'\\n          example: 'Switching to a competitor'\\n        category:\\n          type: string\\n          description: 'The categorized reason for analysis'\\n          example: 'Competitive'\\n        feedback:\\n          type: string\\n          description: 'Additional qualitative feedback from the user'\\n          example: 'The pricing is too high for the current feature set.'\\n    RequestMetadata:\\n      type: object\\n      description: 'Technical metadata associated with the deletion request'\\n      properties:\\n        ip_address:\\n          type: string\\n          description: 'The IP address from which the request originated'\\n          example: '192.168.1.45'\\n        user_agent:\\n          type: string\\n          description: 'The browser or client user agent string'\\n          example: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)'\"\n    }\n  ]\n}"
