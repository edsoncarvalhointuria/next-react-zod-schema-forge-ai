}\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"status\": \"degraded\",\n        \"uptime\": 120\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Health Check API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"HealthResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta de verificação de saúde do sistema\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"O estado atual de operação do serviço\\\",\\n            \\\"example\\\": \\\"degraded\\\"\\n          },\\n          \\\"uptime\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Tempo de atividade do servidor em segundos\\\",\\n            \\\"example\\\": 120\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"email\": \"user@example.com\",\n        \"reset_code\": \"123456\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Password Reset API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PasswordResetRequest:\\n      type: object\\n      description: Request payload for resetting a user password\\n      properties:\\n        email:\\n          type: string\\n          format: email\\n          description: The email address of the user requesting the reset\\n          example: user@example.com\\n        reset_code:\\n          type: string\\n          description: The temporary numeric reset code sent to the user\\n          example: '123456'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_email\": \"admin@company.org\",\n        \"verification_code\": \"AB-9921\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Account Recovery API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ResetPasswordPayload:\\n      type: object\\n      description: Payload to verify password reset identity\\n      properties:\\n        user_email:\\n          type: string\\n          format: email\\n          description: Registered email address of the account holder\\n          example: admin@company.org\\n        verification_code:\\n          type: string\\n          description: Alphanumeric verification token for identity confirmation\\n          example: AB-9921\"\n    },\n    {\n      \"raw_json\": {\n        \"email_address\": \"support@service.net\",\n        \"temp_code\": \"887766\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Security API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PasswordRecoveryRequest:\\n      type: object\\n      description: Request to recover account password using a temporary code\\n      properties:\\n        email_address:\\n          type: string\\n          format: email\\n          description: User's contact email address\\n          example: support@service.net\\n        temp_code:\\n          type: string\\n          description: Temporary security code for password override\\n          example: '887766'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"message\": \"Rate limit exceeded. Please try again later.\",\n        \"retry_after\": 60\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Rate Limit API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"RateLimitWarning\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response returned when the client has hit the rate limit\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Human-readable warning message\\\",\\n            \\\"example\\\": \\\"Rate limit exceeded. Please try again later.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Number of seconds to wait before retrying the request\\\",\\n            \\\"example\\\": 60\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"message\": \"Too many requests. Your hourly quota has been exhausted.\",\n        \"retry_after\": 3600\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Quota Management API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"QuotaExceededWarning\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response returned when the API quota is exhausted\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Detailed explanation of the quota limit breach\\\",\\n            \\\"example\\\": \\\"Too many requests. Your hourly quota has been exhausted.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Seconds remaining until the quota resets\\\",\\n            \\\"example\\\": 3600\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"message\": \"Slow down! You are sending requests too quickly.\",\n        \"retry_after\": 10\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Traffic Throttling API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ThrottlingWarning\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response returned during temporary traffic throttling\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Short warning message regarding request velocity\\\",\\n            \\\"example\\\": \\\"Slow down! You are sending requests too quickly.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Wait time in seconds before the next allowed request\\\",\\n            \\\"example\\\": 10\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"postId\": \"post_12345\",\n        \"isLiked\": true\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Like Toggle API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LikeResponse:\\n      type: object\\n      description: Resposta simples de alteração de curtida\\n      properties:\\n        postId:\\n          type: string\\n          description: Identificador único da postagem\\n          example: 'post_12345'\\n        isLiked:\\n          type: boolean\\n          description: Indica se a postagem está curtida (true) ou não (false)\\n          example: true\"\n    },\n    {\n      \"raw_json\": {\n        \"postId\": \"post_67890\",\n        \"isLiked\": false,\n        \"likeCount\": 142\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Like Toggle API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LikeToggleResponse:\\n      type: object\\n      description: Resposta de alteração de curtida com contador atualizado\\n      properties:\\n        postId:\\n          type: string\\n          description: Identificador único da postagem\\n          example: 'post_67890'\\n        isLiked:\\n          type: boolean\\n          description: Estado atual da curtida do usuário\\n          example: false\\n        likeCount:\\n          type: integer\\n          description: Quantidade total de curtidas da postagem\\n          example: 142\"\n    },\n    {\n      \"raw_json\": {\n        \"postId\": \"post_abcde\",\n        \"isLiked\": true,\n        \"updatedAt\": \"2023-11-15T10:30:00Z\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Like Toggle API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LikeUpdateResponse:\\n      type: object\\n      description: Resposta de alteração de curtida com timestamp de atualização\\n      properties:\\n        postId:\\n          type: string\\n          description: Identificador único da postagem\\n          example: 'post_abcde'\\n        isLiked:\\n          type: boolean\\n          description: Estado atual da curtida do usuário\\n          example: true\\n        updatedAt:\\n          type: string\\n          format: date-time\\n          description: Data e hora em que a ação de curtir foi processada\\n          example: '2023-11-15T10:30:00Z'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"userId\": \"user_88219\",\n        \"authCode\": \"482910\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"2FA Submission API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TwoFactorSubmission\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Request payload for submitting a two-factor authentication code\\\",\\n        \\\"properties\\\": {\\n          \\\"userId\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The unique identifier of the user attempting to authenticate\\\",\\n            \\\"example\\\": \\\"user_88219\\\"\\n          },\\n          \\\"authCode\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The 6-digit verification code sent to the user\\\",\\n            \\\"example\\\": \\\"482910\\\"\\n          }\\n        },\\n        \\\"required\\\": [\\n          \\\"userId\\\",\\n          \\\"authCode\\\"\\n        ]\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"userId\": \"u_773102\",\n        \"verificationCode\": \"105932\",\n        \"sessionId\": \"sess_992104857\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"2FA Verification API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TwoFactorVerification\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Verification request containing user identity and session context\\\",\\n        \\\"properties\\\": {\\n          \\\"userId\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique user account identifier\\\",\\n            \\\"example\\\": \\\