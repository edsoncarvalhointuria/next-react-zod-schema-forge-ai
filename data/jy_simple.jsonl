"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_8829\",\n        \"skus\": [\"PROD-001\", \"PROD-005\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'A simple summary of a shopping cart containing an ID and a list of product SKUs'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Unique identifier for the shopping cart'\\n          example: 'cart_8829'\\n        skus:\\n          type: array\\n          description: 'List of product stock keeping unit strings'\\n          items:\\n            type: string\\n            example: 'PROD-001'\"\n    },\n    {\n      \"raw_json\": {\n        \"cart_id\": \"session_abc_99\",\n        \"skus\": [\"BOOK-123\", \"PEN-456\", \"NOTE-789\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'A simple summary of a shopping cart containing an ID and a list of product SKUs'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Unique identifier for the shopping cart'\\n          example: 'session_abc_99'\\n        skus:\\n          type: array\\n          description: 'List of product stock keeping unit strings'\\n          items:\\n            type: string\\n            example: 'BOOK-123'\"\n    },\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_xyz_000\",\n        \"skus\": [\"TECH-999\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'A simple summary of a shopping cart containing an ID and a list of product SKUs'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Unique identifier for the shopping cart'\\n          example: 'cart_xyz_000'\\n        skus:\\n          type: array\\n          description: 'List of product stock keeping unit strings'\\n          items:\\n            type: string\\n            example: 'TECH-999'\"\n    }\n  ]\n}"
