\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Motivo da falha\\\", \\\"example\\\": \\\"Token expirado\\\" }\\n          }\\n        }\\n      },\\n      \\\"AuthError\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código da falha de segurança\\\", \\\"example\\\": \\\"AUTH_FAILURE\\\" },\\n          \\\"details\\\": { \\\"$ref\\\": \\\"#/components/schemas/MessageContainer\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"error_code\": \"LIMIT_EXCEEDED\",\n        \"details\": {\n          \"messages\": [\"Limite de requisições atingido\", \"Tente novamente em 60 segundos\"]\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Rate Limit Error\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorList\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"messages\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de avisos sobre limites\\\",\\n            \\\"items\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Mensagem de aviso\\\", \\\"example\\\": \\\"Limite de requisições atingido\\\" }\\n          }\\n        }\\n      },\\n      \\\"RateLimitResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código de limitação de taxa\\\", \\\"example\\\": \\\"LIMIT_EXCEEDED\\\" },\\n          \\\"details\\\": { \\\"$ref\\\": \\\"#/components/schemas/ErrorList\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
