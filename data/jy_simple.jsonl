"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"email\": \"user@example.com\",\n        \"reset_code\": \"123456\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Simple Password Reset Request\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PasswordResetRequest:\\n      type: object\\n      description: 'A simple request containing email and code.'\\n      properties:\\n        email:\\n          type: string\\n          description: 'The user email address.'\\n          example: 'user@example.com'\\n        reset_code:\\n          type: string\\n          description: 'The temporary reset code.'\\n          example: '123456'\"\n    },\n    {\n      \"raw_json\": {\n        \"request_id\": \"req-9988\",\n        \"payload\": {\n          \"email\": \"dev@test.com\",\n          \"reset_code\": \"ABC-DEF\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Envelope Password Reset Request\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Envelope:\\n      type: object\\n      description: 'A request wrapped in a metadata envelope.'\\n      properties:\\n        request_id:\\n          type: string\\n          description: 'Unique identifier for the request.'\\n          example: 'req-9988'\\n        payload:\\n          $ref: '#/components/schemas/ResetPayload'\\n    ResetPayload:\\n      type: object\\n      description: 'The actual reset credentials.'\\n      properties:\\n        email:\\n          type: string\\n          description: 'The user email address.'\\n          example: 'dev@test.com'\\n        reset_code:\\n          type: string\\n          description: 'The temporary reset code.'\\n          example: 'ABC-DEF'\"\n    },\n    {\n      \"raw_json\": {\n        \"data\": {\n          \"email\": \"admin@corp.com\",\n          \"reset_code\": \"999\"\n        },\n        \"context\": {\n          \"ip_address\": \"192.168.1.1\",\n          \"device_id\": \"mobile-01\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Secure Password Reset Request\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    SecureResetRequest:\\n      type: object\\n      description: 'A reset request with security context.'\\n      properties:\\n        data:\\n          $ref: '#/components/schemas/ResetData'\\n        context:\\n          $ref: '#/components/schemas/SecurityContext'\\n    ResetData:\\n      type: object\\n      description: 'The core reset information.'\\n      properties:\\n        email:\\n          type: string\\n          description: 'The user email address.'\\n          example: 'admin@corp.com'\\n        reset_code:\\n          type: string\\n          description: 'The temporary reset code.'\\n          example: '999'\\n    SecurityContext:\\n      type: object\\n      description: 'Metadata about the request origin.'\\n      properties:\\n        ip_address:\\n          type: string\\n          description: 'Originating IP address.'\\n          example: '192.168.1.1'\\n        device_id:\\n          type: string\\n          description: 'Device identifier.'\\n          example: 'mobile-01'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"message\": \"Too many requests. Please slow down.\",\n        \"retry_after\": 60\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Rate Limit API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"RateLimitWarning\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Standard rate limit warning response\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Human-readable error message\\\",\\n            \\\"example\\\": \\\"Too many requests. Please slow down.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Seconds to wait before retrying\\\",\\n            \\\"example\\\": 60\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"message\": \"Rate limit exceeded. Account temporarily suspended.\",\n        \"retry_after\": 3600\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Rate Limit API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"CriticalRateLimit\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Critical rate limit warning response\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Detailed error message for critical limits\\\",\\n            \\\"example\\\": \\\"Rate limit exceeded. Account temporarily suspended.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Seconds to wait before retrying\\\",\\n            \\\"example\\\": 3600\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"message\": \"You are approaching your limit.\",\n        \"retry_after\": 5\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Rate Limit API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SoftRateLimitWarning\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Soft warning for approaching limits\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Warning message for approaching limits\\\",\\n            \\\"example\\\": \\\"You are approaching your limit.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Seconds to wait before retrying\\\",\\n            \\\"example\\\": 5\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": 1024,\n        \"is_liked\": true\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Like Toggle API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LikeRequest:\\n      type: object\\n      description: 'Requisição para alternar o status de curtida de um post usando ID numérico'\\n      properties:\\n        post_id:\\n          type: integer\\n          description: 'O identificador numérico único do post'\\n          example: 1024\\n        is_liked:\\n          type: boolean\\n          description: 'Indica se o usuário curtiu ou descurtiu o post'\\n          example: true\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"a1b2c3d4-e5f6-4a5b-8c9d-0e1f2a3b4c5d\",\n        \"is_liked\": false\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Like Toggle API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LikeRequest:\\n      type: object\\n      description: 'Requisição para alternar o status de curtida usando um UUID'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'O identificador único universal (UUID) do post'\\n          example: 'a1b2c3d4-e5f6-4a5b-8c9d-0e1f2a3b4c5d'\\n        is_liked:\\n          type: boolean\\n          description: 'Indica se o usuário curtiu ou descurtiu o post'\\n          example: false\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"noticia-importante-hoje\",\n        \"is_liked\": true\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Like Toggle API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LikeRequest:\\n      type: object\\n      description: 'Requisição para alternar o status de curtida usando um slug de texto'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'O identificador amigável (slug) do post'\\n          example: 'noticia-importante-hoje'\\n        is_liked:\\n          type: boolean\\n          description: 'Indica se o usuário curtiu ou descurtiu o post'\\n          example: true\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_99283\",\n        \"code\": \"482910\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Standard 2FA Submission\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TwoFactorRequest\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"A standard request containing user identification and the verification code.\\\",\\n        \\\"properties\\\": {\\n          \\\"user_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The unique identifier for the user attempting authentication.\\\",\\n            \\\"example\\\": \\\"usr_99283\\\"\\n          },\\n          \\\"code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The 6-digit numeric code provided to the user.\\\",\\n            \\\"example\\\": \\\"482910\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"userId\": \"auth_user_77\",\n        \"verificationCode\": \"001928\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"CamelCase 2FA Submission\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TwoFactorRequest\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"A camelCase formatted 2FA submission object.\\\",\\n        \\\"properties\\\": {\\n          \\\"userId\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The unique identifier for the user.\\\",\\n            \\\"example\\\": \\\"auth_user_77\\\"\\n          },\\n          \\\"verificationCode\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The 6-digit verification code string.\\\",\\n            \\\"example\\\": \\\"001928\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"user_alpha_9\",\n        \"code\": \"554433\",\n        \"device_id\": \"ios_device_v1\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Extended 2FA Submission\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TwoFactorRequest\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"An extended 2FA submission including device context.\\\",\\n        \\\"properties\\\": {\\n          \\\"user_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The unique identifier for the user.\\\",\\n            \\\"example\\\": \\\"user_alpha_9\\\"\\n          },\\n          \\\"code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The 6-digit verification code.\\\",\\n            \\\"example\\\": \\\"554433\\\"\\n          },\\n          \\\"device_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The identifier of the device used for the request.\\\",\\n            \\\"example\\\": \\\"ios_device_v1\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Operation successful\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Success API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    SuccessResponse:\\n      type: object\\n      description: 'Standard success response'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'Indicates if the operation was successful'\\n          example: true\\n        message:\\n          type: string\\n          description: 'A message describing the outcome'\\n          example: 'Operation successful'\"\n    },\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Request processed\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Success API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ProcessResponse:\\n      type: object\\n      description: 'Response for processed requests'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'Status of the request'\\n          example: true\\n        message:\\n          type: string\\n          description: 'Status message'\\n          example: 'Request processed'\"\n    },\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Task completed\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Success API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    TaskResponse:\\n      type: object\\n      description: 'Response for task completion'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'Task success status'\\n          example: true\\n        message:\\n          type: string\\n          description: 'Task result message'\\n          example: 'Task completed'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"email\": \"jane.doe@example.com\",\n        \"opt_in\": true\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Email Subscription API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SubscriptionRequest\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Standard payload for email subscription requests\\\",\\n        \\\"properties\\\": {\\n          \\\"email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The user's primary email address\\\",\\n            \\\"example\\\": \\\"jane.doe@example.com\\\"\\n          },\\n          \\\"opt_in\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Indicates if the user agrees to receive emails\\\",\\n            \\\"example\\\": true\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"email_address\": \"contact@service.org\",\n        \"newsletter_consent\": false\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Marketing Consent API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"NewsletterConsent\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Payload for managing marketing newsletter preferences\\\",\\n        \\\"properties\\\": {\\n          \\\"email_address\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The contact email address for marketing communications\\\",\\n            \\\"example\\\": \\\"contact@service.org\\\"\\n          },\\n          \\\"newsletter_consent\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Whether the user has consented to the newsletter\\\",\\n            \\\"example\\\": false\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"user_email\": \"subscriber@provider.net\",\n        \"is_subscribed\": true\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"User Preference API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"UserSubscriptionStatus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Payload representing a user's subscription state\\\",\\n        \\\"properties\\\": {\\n          \\\"user_email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The unique email identifier for the user\\\",\\n            \\\"example\\\": \\\"subscriber@provider.net\\\"\\n          },\\n          \\\"is_subscribed\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"The current subscription status of the user\\\",\\n            \\\"example\\\": true\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"session_token\": \"abc123xyz789\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LogoutRequest:\\n      type: object\\n      description: 'Requisição de logout contendo o token da sessão'\\n      properties:\\n        session_token:\\n          type: string\\n          description: 'O token de sessão único para invalidar'\\n          example: 'abc123xyz789'\"\n    },\n    {\n      \"raw_json\": {\n        \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.payload.signature\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LogoutRequest:\\n      type: object\\n      description: 'Requisição de logout contendo o token JWT'\\n      properties:\\n        token:\\n          type: string\\n          description: 'O token JWT para encerrar a sessão'\\n          example: 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.payload.signature'\"\n    },\n    {\n      \"raw_json\": {\n        \"access_token\": \"sess_987654321\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LogoutRequest:\\n      type: object\\n      description: 'Requisição de logout contendo o token de acesso'\\n      properties:\\n        access_token:\\n          type: string\\n          description: 'O token de acesso utilizado para autenticação'\\n          example: 'sess_987654321'\"\n    }\n  ]\n}"
