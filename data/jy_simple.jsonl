"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"session_token\": \"abc123xyz789_session_id\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LogoutRequest:\\n      type: object\\n      description: Request payload to invalidate a user session\\n      properties:\\n        session_token:\\n          type: string\\n          description: The unique session identifier to be revoked\\n          example: 'abc123xyz789_session_id'\"\n    },\n    {\n      \"raw_json\": {\n        \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIn0\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Session Termination API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    SessionTokenPayload:\\n      type: object\\n      description: Payload containing the authentication token for termination\\n      properties:\\n        token:\\n          type: string\\n          description: The JWT or bearer token used to identify the active session\\n          example: 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIn0'\"\n    },\n    {\n      \"raw_json\": {\n        \"authToken\": \"sess_9876543210_auth_key\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Auth Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AuthLogoutRequest:\\n      type: object\\n      description: Request to log out a user using an auth token\\n      properties:\\n        authToken:\\n          type: string\\n          description: The active authentication token to be revoked from the system\\n          example: 'sess_9876543210_auth_key'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"feature_name\": \"dark_mode\",\n        \"enabled\": true\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Feature Flag API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"FeatureFlag\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Representa o estado de ativação de uma funcionalidade específica\\\",\\n        \\\"properties\\\": {\\n          \\\"feature_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"O nome identificador da funcionalidade\\\",\\n            \\\"example\\\": \\\"dark_mode\\\"\\n          },\\n          \\\"enabled\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Indica se a funcionalidade está habilitada ou desabilitada\\\",\\n            \\\"example\\\": true\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"flag_id\": \"beta_checkout_v2\",\n        \"is_active\": false\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Feature Flag API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"FeatureToggle\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Configuração de alternância para controle de funcionalidades\\\",\\n        \\\"properties\\\": {\\n          \\\"flag_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"ID único da flag de funcionalidade\\\",\\n            \\\"example\\\": \\\"beta_checkout_v2\\\"\\n          },\\n          \\\"is_active\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Estado atual de ativação da flag\\\",\\n            \\\"example\\\": false\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"feature_key\": \"new_user_onboarding\",\n        \"status\": true\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Feature Flag API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"FeatureStatus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta de status de ativação de recurso\\\",\\n        \\\"properties\\\": {\\n          \\\"feature_key\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Chave de referência da funcionalidade no sistema\\\",\\n            \\\"example\\\": \\\"new_user_onboarding\\\"\\n          },\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Status booleano de ativação do recurso\\\",\\n            \\\"example\\\": true\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
