"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Operation completed successfully\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Success Response API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    SuccessResponse:\\n      type: object\\n      description: 'A standard success response structure.'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'Indicates if the operation was successful.'\\n          example: true\\n        message:\\n          type: string\\n          description: 'A descriptive message regarding the operation status.'\\n          example: 'Operation completed successfully'\"\n    },\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Resource created\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Resource API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ResourceCreationResponse:\\n      type: object\\n      description: 'Response returned after a successful resource creation.'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'The status of the creation process.'\\n          example: true\\n        message:\\n          type: string\\n          description: 'Confirmation message for the user.'\\n          example: 'Resource created'\"\n    },\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Update successful\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Update API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    UpdateStatusResponse:\\n      type: object\\n      description: 'Response for update operations.'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'Whether the update was applied successfully.'\\n          example: true\\n        message:\\n          type: string\\n          description: 'Message confirming the update stat