"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"email\": \"usuario@exemplo.com\",\n        \"reset_code\": \"123456\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Password Reset Request - Numeric Code\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PasswordResetRequest:\\n      type: object\\n      description: 'Solicitação de redefinição de senha simples usando um código numérico'\\n      properties:\\n        email:\\n          type: string\\n          format: email\\n          description: 'Endereço de e-mail do usuário'\\n          example: 'usuario@exemplo.com'\\n        reset_code:\\n          type: string\\n          description: 'Código de redefinição temporário de seis dígitos'\\n          example: '123456'\"\n    },\n    {\n      \"raw_json\": {\n        \"email\": \"cliente.teste@provedor.com\",\n        \"verification_code\": \"A7B9C2\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Password Reset Request - Alphanumeric Code\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PasswordResetRequest:\\n      type: object\\n      description: 'Solicitação de redefinição de senha com código alfanumérico'\\n      properties:\\n        email:\\n          type: string\\n          format: email\\n          description: 'Endereço de e-mail do usuário'\\n          example: 'cliente.teste@provedor.com'\\n        verification_code:\\n          type: string\\n          description: 'Código de verificação alfanumérico'\\n          example: 'A7B9C2'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_email\": \"admin@sistema.com.br\",\n        \"temp_token\": \"token-xyz-123\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Password Reset Request - Token Based\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PasswordResetRequest:\\n      type: object\\n      description: 'Solicitação de redefinição de senha utilizando um token temporário'\\n      properties:\\n        user_email:\\