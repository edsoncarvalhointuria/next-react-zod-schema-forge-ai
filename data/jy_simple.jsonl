"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"city\": \"London\",\n        \"weather\": {\n          \"temperature\": 15.5,\n          \"humidity\": 72\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherMetrics:\\n      type: object\\n      description: 'Current atmospheric conditions'\\n      properties:\\n        temperature:\\n          type: number\\n          format: float\\n          description: 'Current temperature in Celsius'\\n          example: 15.5\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 72\\n    WeatherResponse:\\n      type: object\\n      description: 'Root response object for weather data'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'London'\\n        weather:\\n          $ref: '#/components/schemas/WeatherMetrics'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"Tokyo\",\n        \"weather\": {\n          \"temperature\": 22.0,\n          \"humidity\": 55\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherMetrics:\\n      type: object\\n      description: 'Current atmospheric conditions'\\n      properties:\\n        temperature:\\n          type: number\\n          format: float\\n          description: 'Current temperature in Celsius'\\n          example: 22.0\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 55\\n    WeatherResponse:\\n      type: object\\n      description: 'Root response object for weather data'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'Tokyo'\\n        weather:\\n          $ref: '#/components/schemas/WeatherMetrics'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"New York\",\n        \"weather\": {\n          \"temperature\": 8.2,\n          \"humidity\": 40\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherMetrics:\\n      type: object\\n      description: 'Current atmospheric conditions'\\n      properties:\\n        temperature:\\n          type: number\\n          format: float\\n          description: 'Current temperature in Celsius'\\n          example: 8.2\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 40\\n    WeatherResponse:\\n      type: object\\n      description: 'Root response object for weather data'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'New York'\\n        weather:\\n          $ref: '#/components/schemas/WeatherMetrics'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"error_code\": \"ERR_VALIDATION_FAILED\",\n        \"messages\": [\n          \"O campo email é obrigatório.\",\n          \"O formato da senha é inválido.\"\n        ]\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Error Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Código identificador único do erro ocorrido\\\",\\n            \\\"example\\\": \\\"ERR_VALIDATION_FAILED\\\"\\n          },\\n          \\\"messages\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de mensagens detalhando os erros encontrados\\\",\\n            \\\"items\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"Mensagem individual de erro\\\",\\n              \\\"example\\\": \\\"O campo email é obrigatório.\\\"\\n            }\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"error_code\": \"ERR_AUTH_UNAUTHORIZED\",\n        \"messages\": [\n          \"Token de acesso expirado.\",\n          \"Por favor, realize o login novamente.\"\n        ]\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Error Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Código identificador único do erro oco