"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_987\",\n        \"comment_data\": {\n          \"author_name\": \"João Silva\",\n          \"text\": \"Excelente artigo, muito esclarecedor!\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'Detalhes do autor e o conteúdo do comentário'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'Nome completo do autor do comentário'\\n          example: 'João Silva'\\n        text:\\n          type: string\\n          description: 'O texto do comentário enviado'\\n          example: 'Excelente artigo, muito esclarecedor!'\\n    CommentSubmission:\\n      type: object\\n      description: 'Estrutura de envio de um comentário para um post'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Identificador único da postagem'\\n          example: 'post_987'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_456\",\n        \"comment_data\": {\n          \"author_name\": \"Maria Oliveira\",\n          \"text\": \"Poderia detalhar mais sobre a seção de segurança?\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'Dados do autor e corpo do comentário'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'Nome do autor'\\n          example: 'Maria Oliveira'\\n        text:\\n          type: string\\n          description: 'Conteúdo da mensagem'\\n          example: 'Poderia detalhar mais sobre a seção de segurança?'\\n    CommentSubmission:\\n      type: object\\n      description: 'Objeto de submissão de comentário'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'ID do post alvo'\\n          example: 'post_456'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_101\",\n        \"comment_data\": {\n          \"author_name\": \"Carlos Souza\",\n          \"text\": \"Concordo plenamente com os pontos levantados.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'Informações do autor e texto'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'Nome do usuário'\\n          example: 'Carlos Souza'\\n        text:\\n          type: string\\n          description: 'Comentário escrito'\\n          example: 'Concordo plenamente com os pontos levantados.'\\n    CommentSubmission:\\n      type: object\\n      description: 'Payload de submissão de comentário'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Identificador do post'\\n          example: 'post_101'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    }\n  ]\n}"
