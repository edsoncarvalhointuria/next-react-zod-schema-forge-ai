"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_8829\",\n        \"preferences\": {\n          \"theme\": \"dark\",\n          \"language\": \"en-US\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Settings API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    UserPreferences:\\n      type: object\\n      description: 'User interface and localization settings'\\n      properties:\\n        theme:\\n          type: string\\n          description: 'The visual theme mode'\\n          example: 'dark'\\n        language:\\n          type: string\\n          description: 'The ISO language code'\\n          example: 'en-US'\\n    UserSettingsResponse:\\n      type: object\\n      description: 'Response containing user identification and preferences'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'usr_8829'\\n        preferences:\\n          $ref: '#/components/schemas/UserPreferences'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_9910\",\n        \"preferences\": {\n          \"theme\": \"light\",\n          \"language\": \"fr-FR\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Settings API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    UserPreferences:\\n      type: object\\n      description: 'User interface and localization settings'\\n      properties:\\n        theme:\\n          type: string\\n          description: 'The visual theme mode'\\n          example: 'light'\\n        language:\\n          type: string\\n          description: 'The ISO language code'\\n          example: 'fr-FR'\\n    UserSettingsResponse:\\n      type: object\\n      description: 'Response containing user identification and preferences'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'usr_9910'\\n        preferences:\\n          $ref: '#/components/schemas/UserPreferences'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_4432\",\n        \"preferences\": {\n          \"theme\": \"system\",\n          \"language\": \"ja-JP\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Settings API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    UserPreferences:\\n      type: object\\n      description: 'User interface and localization settings'\\n      properties:\\n        theme:\\n          type: string\\n          description: 'The visual theme mode'\\n          example: 'system'\\n        language:\\n          type: string\\n          description: 'The ISO language code'\\n          example: 'ja-JP'\\n    UserSettingsResponse:\\n      type: object\\n      description: 'Response containing user identification and preferences'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'usr_4432'\\n        preferences:\\n          $ref: '#/components/schemas/UserPreferences'\"\n    }\n  ]\n}"
