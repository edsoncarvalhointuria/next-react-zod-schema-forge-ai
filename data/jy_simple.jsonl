"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"status\": \"verified\",\n        \"message\": \"Authentication successful\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"2FA Verification API\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"VerificationResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response returned after a successful 2FA code submission\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"The outcome of the verification process\\\", \\\"example\\\": \\\"verified\\\" },\\n          \\\"message\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"A human-readable confirmation message\\\", \\\"example\\\": \\\"Authentication successful\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"status\": \"success\",\n        \"session_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9\",\n        \"user_id\": \"usr_882194\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"2FA Session API\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SessionResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response containing session details after 2FA verification\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"The status of the authentication request\\\", \\\"example\\\": \\\"success\\\" },\\n          \\\"session_token\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"The generated JWT session token for the user\\\", \\\"example\\\": \\\"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9\\\" },\\n          \\\"user_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"The unique identifier of the authenticated user\\\", \\\"example\\\": \\\"usr_882194\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"status\": \"error\",\n        \"error_code\": \"INVALID_CODE\",\n        \"attempts_remaining\": 2\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"2FA Error API\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"AuthErrorResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response returned when the 2FA code submission fails\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"The status of the request\\\", \\\"example\\\": \\\"error\\\" },\\n          \\\"error_code\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"The machine-readable error identifier\\\", \\\"example\\\": \\\"INVALID_CODE\\\" },\\n          \\\"attempts_remaining\\\": { \\\"type\\\": \\\"integer\\\", \\\"description\\\": \\\"The number of remaining attempts before the account is locked\\\", \\\"example\\\": 2 }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Operação realizada com sucesso\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Generic Success API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    SuccessResponse:\\n      type: object\\n      description: 'Resposta padrão para operações bem sucedidas'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'Indica se a operação foi concluída com sucesso'\\n          example: true\\n        message:\\n          type: string\\n          description: 'Mensagem descritiva do resultado da operação'\\n          example: 'Operação realizada com sucesso'\"\n    },\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"O registro foi criado corretamente no sistema\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Generic Success API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    GenericResponse:\\n      type: object\\n      description: 'Resposta genérica de confirmação de sistema'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'Flag booleana indicando o status de sucesso'\\n          example: true\\n        message:\\n          type: string\\n          description: 'Texto informativo sobre a ação executada'\\n          example: 'O registro foi criado corretamente no sistema'\"\n    },\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"OK\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Generic Success API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ApiResponse:\\n      type: object\\n      description: 'Resposta simplificada de API'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'Status de sucesso da requisição'\\n          example: true\\n        message:\\n          type: string\\n          description: 'Mensagem curta de confirmação'\\n          example: 'OK'\"\n    }\n  ]\n}"
