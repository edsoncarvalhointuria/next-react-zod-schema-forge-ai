"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_88291\",\n        \"items\": [\n          \"SKU-APPLE-001\",\n          \"SKU-BANANA-002\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'A summary of the current shopping cart'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Unique identifier for the shopping cart'\\n          example: 'cart_88291'\\n        items:\\n          type: array\\n          description: 'List of product SKUs in the cart'\\n          items:\\n            type: string\\n          example: ['SKU-APPLE-001', 'SKU-BANANA-002']\"\n    },\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_55012\",\n        \"items\": [\n          \"SKU-LAPTOP-X1\",\n          \"SKU-MOUSE-BT\",\n          \"SKU-KEYBOARD-MECH\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'A summary of the current shopping cart'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Unique identifier for the shopping cart'\\n          example: 'cart_55012'\\n        items:\\n          type: array\\n          description: 'List of product SKUs in the cart'\\n          items:\\n            type: string\\n          example: ['SKU-LAPTOP-X1', 'SKU-MOUSE-BT', 'SKU-KEYBOARD-MECH']\"\n    },\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_99304\",\n        \"items\": [\n          \"SKU-SHIRT-L-BLU\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'A summary of the current shopping cart'\\