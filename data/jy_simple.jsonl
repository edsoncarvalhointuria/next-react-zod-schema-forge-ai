"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"user_id\": \"user_12345\",\n        \"auth_code\": \"554433\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"2FA Submission API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TwoFactorAuth\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Dados para submissão de código de autenticação de dois fatores\\\",\\n        \\\"properties\\\": {\\n          \\\"user_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"O identificador único do usuário\\\",\\n            \\\"example\\\": \\\"user_12345\\\"\\n          },\\n          \\\"auth_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"O código de 6 dígitos fornecido ao usuário\\\",\\n            \\\"example\\\": \\\"554433\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"uuid-9876-5432\",\n        \"verification_code\": \"123456\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"2FA Verification API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"VerificationRequest\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Solicitação de verificação de código de segurança\\\",\\n        \\\"properties\\\": {\\n          \\\"user_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"ID do usuário para validação de identidade\\\",\\n            \\\"example\\\": \\\"uuid-9876-5432\\\"\\n          },\\n          \\\"verification_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Código de verificação de seis dígitos\\\",\\n            \\\"example\\\": \\\"123456\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"admin_01\",\n        \"otp_code\": \"998877\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"OTP Validation API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"OtpValidation\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Objeto contendo o código OTP para validação\\\",\\n        \\\"properties\\\": {\\n          \\\"user_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador do cliente\\\",\\n            \\\"example\\\": \\\"admin_01\\\"\\n          },\\n          \\\"otp_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Código de senha de uso único\\\",\\n            \\\"example\\\": \\\"998877\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Operation completed successfully\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Generic Success API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    SuccessResponse:\\n      type: object\\n      description: A standard response indicating a successful operation.\\n      properties:\\n        success:\\n          type: boolean\\n          description: Indicates if the request was successful.\\n          example: true\\n        message:\\n          type: string\\n          description: A human-readable message describing the result.\\n          example: \\\"Operation completed successfully\\\"\"\n    },\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Request processed\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Generic Success API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    SimpleSuccessResponse:\\n      type: object\\n      description: A minimal success response.\\n      properties:\\n        success:\\n          type: boolean\\n          description: Status of the operation.\\n          example: true\\n        message:\\n          type: string\\n          description: Short status message.\\n          example: \\\"Request processed\\\"\"\n    },\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Changes saved\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Generic Success API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ActionSuccessResponse:\\n      type: object\\n      description: Response for an action-based success.\\n      properties:\\n        success:\\n          type: boolean\\n          description: Whether the action was successful.\\n          example: true\\n        message:\\n          type: string\\n          description: Feedback message for the user.\\n          example: \\\"Changes saved\\\"\"\