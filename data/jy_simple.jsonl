"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_8829\",\n        \"preferences\": {\n          \"theme\": \"dark\",\n          \"language\": \"en-US\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Settings API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Preferences:\\n      type: object\\n      description: 'User interface and localization settings'\\n      properties:\\n        theme:\\n          type: string\\n          description: 'The visual theme mode'\\n          example: 'dark'\\n        language:\\n          type: string\\n          description: 'The ISO locale code'\\n          example: 'en-US'\\n    UserSettingsResponse:\\n      type: object\\n      description: 'Root object for user settings'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'usr_8829'\\n        preferences:\\n          $ref: '#/components/schemas/Preferences'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_9910\",\n        \"preferences\": {\n          \"theme\": \"light\",\n          \"language\": \"fr-FR\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Settings API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Preferences:\\n      type: object\\n      description: 'User interface and localization settings'\\n      properties:\\n        theme:\\n          type: string\\n          description: 'The visual theme mode'\\n          example: 'light'\\n        language:\\n          type: string\\n          description: 'The ISO locale code'\\n          example: 'fr-FR'\\n    UserSettingsResponse:\\n      type: object\\n      description: 'Root object for user settings'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'usr_9910'\\n        preferences:\\n          $ref: '#/components/schemas/Preferences'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_4432\",\n        \"preferences\": {\n          \"theme\": \"system\",\n          \"language\": \"ja-JP\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Settings API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Preferences:\\n      type: object\\n      description: 'User interface and localization settings'\\n      properties:\\n        theme:\\n          type: string\\n          description: 'The visual theme mode'\\n          example: 'system'\\n        language:\\n          type: string\\n          description: 'The ISO locale code'\\n          example: 'ja-JP'\\n    UserSettingsResponse:\\n      type: object\\n      description: 'Root object for user settings'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'usr_4432'\\n        preferences:\\n          $ref: '#/components/schemas/Preferences'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"deviceId\": \"dev-998877\",\n        \"software\": {\n          \"osVersion\": \"14.2.0\",\n          \"appVersion\": \"2.1.5\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Device Registration API\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SoftwareInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações sobre o sistema operacional e a versão do aplicativo\\\",\\n        \\\"properties\\\": {\\n          \\\"osVersion\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Versão do sistema operacional instalado\\\", \\\"example\\\": \\\"14.2.0\\\" },\\n          \\\"appVersion\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Versão atual do aplicativo\\\", \\\"example\\\": \\\"2.1.5\\\" }\\n        }\\n      },\\n      \\\"DeviceRegistration\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Payload de registro de dispositivo\\\",\\n        \\\"properties\\\": {\\n          \\\"deviceId\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Identificador único do dispositivo\\\", \\\"example\\\": \\\"dev-998877\\\" },\\n          \\\"software\\\": { \\\"$ref\\\": \\\"#/components/schemas/SoftwareInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"deviceId\": \"mobile-445566\",\n        \"software\": {\n          \"osVersion\": \"Android 13\",\n          \"appVersion\": \"3.0.1-beta\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Device Registration API\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SoftwareInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detalhes técnicos do software do dispositivo\\\",\\n        \\\"properties\\\": {\\n          \\\"osVersion\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Versão do sistema operacional\\\", \\\"example\\\": \\\"Android 13\\\" },\\n          \\\"appVersion\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Versão da aplicação instalada\\\", \\\"example\\\": \\\"3.0.1-beta\\\" }\\n        }\\n      },\\n      \\\"DeviceRegistration\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Objeto de registro contendo ID e dados de software\\\",\\n        \\\"properties\\\": {\\n          \\\"deviceId\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"ID único do hardware\\\", \\\"example\\\": \\\"mobile-445566\\\" },\\n          \\\"software\\\": { \\\"$ref\\\": \\\"#/components/schemas/SoftwareInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"deviceId\": \"iot-sensor-001\",\n        \"software\": {\n          \"osVersion\": \"Firmware-v2.0\",\n          \"appVersion\": \"1.0.0\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Device Registration API\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SoftwareInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Versões de firmware e aplicação\\\",\\n        \\\"properties\\\": {\\n          \\\"osVersion\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Versão do firmware do dispositivo\\\", \\\"example\\\": \\\"Firmware-v2.0\\\" },\\n          \\\"appVersion\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Versão do software de controle\\\", \\\"example\\\": \\\"1.0.0\\\" }\\n        }\\n      },\\n      \\\"DeviceRegistration\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Est