"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_8821\",\n        \"skus\": [\"PROD-001\", \"PROD-005\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'Resumo simples do carrinho de compras contendo identificador e lista de produtos'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Identificador único da sessão do carrinho'\\n          example: 'cart_8821'\\n        skus:\\n          type: array\\n          description: 'Lista de códigos SKU dos produtos adicionados'\\n          items:\\n            type: string\\n            example: 'PROD-001'\"\n    },\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_9942\",\n        \"skus\": [\"LAPTOP-X1\", \"MOUSE-BT\", \"KEYBOARD-MECH\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'Resumo do carrinho de compras com múltiplos itens'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'ID exclusivo do carrinho de compras'\\n          example: 'cart_9942'\\n        skus:\\n          type: array\\n          description: 'Coleção de SKUs dos itens selecionados'\\n          items:\\n            type: string\\n            example: 'LAPTOP-X1'\"\n    },\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_1023\",\n        \"skus\": [\"BOOK-01\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'Resumo do carrinho contendo um único item'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Identificador do carrinho de compras'\\n          example: 'cart_1023'\\n        skus:\\n          type: array\\n          description: 'Lista contendo os SKUs dos produtos'\\n          items:\\n            type: string\\n            example: 'BOOK-01'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"product_id\": \"PROD-9921\",\n        \"pricing\": {\n          \"amount\": 150.5,\n          \"currency\": \"BRL\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Product Price Update\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PriceDetails\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"amount\\\": { \\\"type\\\": \\\"number\\\", \\\"description\\\": \\\"Valor monetário do produto\\\", \\\"example\\\": 150.5 },\\n          \\\"currency\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código da moeda (ISO 4217)\\\", \\\"example\\\": \\\"BRL\\\" }\\n        }\\n      },\\n      \\\"PriceUpdate\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"product_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Identificador único do produto\\\", \\\"example\\\": \\\"PROD-9921\\\" },\\n          \\\"pricing\\\": { \\\"$ref\\\": \\\"#/components/schemas/PriceDetails\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"product_id\": \"SKU-8842\",\n        \"pricing\": {\n          \"amount\": 29.99,\n          \"currency\": \"USD\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Product Price Update\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PriceDetails\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"amount\\\": { \\\"type\\\": \\\"number\\\", \\\"description\\\": \\\"Preço atualizado do item\\\", \\\"example\\\": 29.99 },\\n          \\\"currency\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Moeda de transação\\\", \\\"