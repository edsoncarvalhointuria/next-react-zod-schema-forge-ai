"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"city\": \"São Paulo\",\n        \"weather\": {\n          \"temperature\": 22.5,\n          \"humidity\": 65\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherDetails:\\n      type: object\\n      description: 'Dados climáticos atuais'\\n      properties:\\n        temperature:\\n          type: number\\n          format: float\\n          description: 'Temperatura atual em graus Celsius'\\n          example: 22.5\\n        humidity:\\n          type: integer\\n          description: 'Percentual de umidade relativa do ar'\\n          example: 65\\n    WeatherResponse:\\n      type: object\\n      description: 'Resposta do widget de clima'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Nome da cidade consultada'\\n          example: 'São Paulo'\\n        weather:\\n          $ref: '#/components/schemas/WeatherDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"Lisboa\",\n        \"weather\": {\n          \"temperature\": 18.0,\n          \"humidity\": 40\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherDetails:\\n      type: object\\n      description: 'Dados climáticos atuais'\\n      properties:\\n        temperature:\\n          type: number\\n          format: float\\n          description: 'Temperatura atual em graus Celsius'\\n          example: 18.0\\n        humidity:\\n          type: integer\\n          description: 'Percentual de umidade relativa do ar'\\n          example: 40\\n    WeatherResponse:\\n      type: object\\n      description: 'Resposta do widget de clima'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Nome da cidade consultada'\\n          example: 'Lisboa'\\n        weather:\\n          $ref: '#/components/schemas/WeatherDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"Tóquio\",\n        \"weather\": {\n          \"temperature\": 12.3,\n          \"humidity\": 80\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherDetails:\\n      type: object\\n      description: 'Dados climáticos atuais'\\n      properties:\\n        temperature:\\n          type: number\\n          format: float\\n          description: 'Temperatura atual em graus Celsius'\\n          example: 12.3\\n        humidity:\\n          type: integer\\n          description: 'Percentual de umidade relativa do ar'\\n          example: 80\\n    WeatherResponse:\\n      type: object\\n      description: 'Resposta do widget de clima'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Nome da cidade consultada'\\n          example: 'Tóquio'\\n        weather:\\n          $ref: '#/components/schemas/WeatherDetails'\"\n    }\n  ]\n}"
