 o bloqueio temporário\\\",\\n            \\\"example\\\": \\\"Você atingiu a cota máxima de requisições por minuto para o seu plano.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Quantidade de segundos que o cliente deve esperar antes de realizar uma nova chamada\\\",\\n            \\\"example\\\": 30\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"message\": \"Muitas requisições detectadas. Acesso temporariamente restringido.\",\n        \"retry_after\": 3600\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Rate Limit API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"RateLimitWarning\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta de aviso quando o limite de taxa de requisições é atingido\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Mensagem informativa sobre o bloqueio temporário\\\",\\n            \\\"example\\\": \\\"Muitas requisições detectadas. Acesso temporariamente restringido.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Quantidade de segundos que o cliente deve esperar antes de realizar uma nova chamada\\\",\\n            \\\"example\\\": 3600\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": 1024,\n        \"is_liked\": true\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Like Toggle API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LikeRequest:\\n      type: object\\n      description: 'Requisição para alternar o status de curtida de um post'\\n      properties:\\n        post_id:\\n          type: integer\\n          description: 'O identificador único do post'\\n          example: 1024\\n        is_liked:\\n          type: boolean\\n          description: 'Indica se o post foi curtido (true) ou descurtido (false)'\\n          example: true\"\n    },\n    {\n      \"raw_json\": {\n        \"postId\": \"uuid-789-xyz\",\n        \"liked\": false\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Like Toggle API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PostLikeToggle:\\n      type: object\\n      description: 'Objeto para atualizar a preferência de curtida do usuário'\\n      properties:\\n        postId:\\n          type: string\\n          description: 'O UUID do post alvo da ação'\\n          example: 'uuid-789-xyz'\\n        liked:\\n          type: boolean\\n          description: 'Estado final da curtida após a operação'\\n          example: false\"\n    },\n    {\n      \"raw_json\": {\n        \"content_id\": \"post_550\",\n        \"status\": true\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Like Toggle API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LikeStatusUpdate:\\n      type: object\\n      description: 'Dados para atualização de status de interação de curtida'\\n      properties:\\n        content_id:\\n          type: string\\n          description: 'Identificador alfanumérico do conteúdo'\\n          example: 'post_550'\\n        status:\\n          type: boolean\\n          description: 'Define se a interação de curtida está ativa ou inativa'\\n          example: true\"\n    }\n  ]\n}"
