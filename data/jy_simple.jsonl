"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"product_id\": \"PROD-1001\",\n        \"pricing\": {\n          \"amount\": 29.99,\n          \"currency\": \"BRL\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Product Price Update\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PriceDetails\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detalhes do novo preço e moeda\\\",\\n        \\\"properties\\\": {\\n          \\\"amount\\\": { \\\"type\\\": \\\"number\\\", \\\"description\\\": \\\"Valor numérico do preço\\\", \\\"example\\\": 29.99 },\\n          \\\"currency\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código da moeda (ISO 4217)\\\", \\\"example\\\": \\\"BRL\\\" }\\n        }\\n      },\\n      \\\"PriceUpdatePayload\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Payload para atualização de preço de produto\\\",\\n        \\\"properties\\\": {\\n          \\\"product_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Identificador único do produto\\\", \\\"example\\\": \\\"PROD-1001\\\" },\\n          \\\"pricing\\\": { \\\"$ref\\\": \\\"#/components/schemas/PriceDetails\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"product_id\": \"SKU-992\",\n        \"pricing\": {\n          \"amount\": 150.0,\n          \"currency\": \"USD\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Product Price Update\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PriceDetails\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Estrutura contendo o valor e a moeda\\\",\\n        \\\"properties\\\": {\\n          \\\"amount\\\": { \\\"type\\\": \\\"number\\\", \\\"description\\\": \\\"Preço atualizado\\\", \\\"example\\\": 150.0 },\\n          \\\"currency\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Moeda internacional\\\", \\\"example\\\": \\\"USD\\\" }\\n        }\\n      },\\n      \\\"PriceUpdatePayload\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Objeto de atualização de preço\\\",\\n        \\\"properties\\\": {\\n          \\\"product_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"ID do SKU do produto\\\", \\\"example\\\": \\\"SKU-992\\\" },\\n          \\\"pricing\\\": { \\\"$ref\\\": \\\"#/components/schemas/PriceDetails\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"product_id\": \"ITEM-554\",\n        \"pricing\": {\n          \"amount\": 5.5,\n          \"currency\": \"EUR\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Product Price Update\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PriceDetails\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações financeiras do produto\\\",\\n        \\\"properties\\\": {\\n          \\\"amount\\\": { \\\"type\\\": \\\"number\\\", \\\"description\\\": \\\"Novo valor unitário\\\", \\\"example\\\": 5.5 },\\n          \\\"currency\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Sigla da moeda\\\", \\\"example\\\": \\\"EUR\\\" }\\n        }\\n      },\\n      \\\"PriceUpdatePayload\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Requisição de alteração de preço\\\",\\n        \\\"properties\\\": {\\n          \\\"product_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código de identificação do item\\\", \\\"example\\\": \\\"ITEM