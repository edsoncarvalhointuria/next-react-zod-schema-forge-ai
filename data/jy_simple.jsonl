"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_8821\",\n        \"skus\": [\"PROD-001\", \"PROD-005\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'Resumo simples do carrinho de compras contendo o ID e a lista de SKUs'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Identificador único da sessão do carrinho'\\n          example: 'cart_8821'\\n        skus:\\n          type: array\\n          description: 'Lista de códigos de estoque dos produtos'\\n          items:\\n            type: string\\n            example: 'PROD-001'\"\n    },\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_9932\",\n        \"skus\": [\"BOOK-99\", \"PEN-12\", \"NOTE-01\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'Estrutura de dados contendo o identificador do carrinho e seus itens'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Código de referência do carrinho'\\n          example: 'cart_9932'\\n        skus:\\n          type: array\\n          description: 'Coleção de SKUs dos produtos selecionados'\\n          items:\\n            type: string\\n            example: 'BOOK-99'\"\n    },\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_4450\",\n        \"skus\": [\"ELEC-55\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'Objeto de resposta para o resumo do carrinho'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'ID exclusivo do carrinho de compras'\\n          example: 'cart_4450'\\n        skus:\\n          type: array\\n          description: 'Lista contendo os SKUs dos itens'\\n          items:\\n            type: string\\n            example: 'ELEC-55'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"product_id\": \"PROD-9921\",\n        \"pricing\": {\n          \"amount\": 150.5,\n          \"currency\": \"BRL\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Product Price Update\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PriceDetails\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"amount\\\": { \\\"type\\\": \\\"number\\\", \\\"description\\\": \\\"Valor monetário do produto\\\", \\\"example\\\": 150.5 },\\n          \\\"currency\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código da moeda (ISO 4217)\\\", \\\"example\\\": \\\"BRL\\\" }\\n        }\\n      },\\n      \\\"PriceUpdate\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"product_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Identificador único do produto\\\", \\\"example\\\": \\\"PROD-9921\\\" },\\n          \\\"pricing\\\": { \\\"$ref\\\": \\\"#/components/schemas/PriceDetails\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"product_id\": \"SKU-8842\",\n        \"pricing\": {\n          \"amount\": 29.99,\n          \"currency\": \"USD\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Product Price Update\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PriceDetails\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"amount\\\": { \\\"type\\\": \\\"number\\\", \\\"description\\\": \\\"Preço atualizado do item\\\", \\\"example\\\": 29.99 },\\n          \\\"currency\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Moeda de transação internacional\\\", \\\"example\\\": \\\"USD\\\" }\\n        }\\n      },\\n      \\\"PriceUpdate\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"product_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"ID de referência do estoque\\\", \\\"example\\\": \\\"SKU-8842\\\" },\\n          \\\"pricing\\\": { \\\"$ref\\\": \\\"#/components/schemas/PriceDetails\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"product_id\": \"ITEM-001\",\n        \"pricing\": {\n          \"amount\": 5000,\n          \"currency\": \"EUR\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Product Price Update\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PriceDetails\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"amount\\\": { \\\"type\\\": \\\"number\\\", \\\"description\\\": \\\"Montante do preço\\\", \\\"example\\\": 5000 },\\n          \\\"currency\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Moeda europeia\\\", \\\"example\\\": \\\"EUR\\\" }\\n        }\\n      },\\n      \\\"PriceUpdate\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"product_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Identificador do item\\\", \\\"example\\\": \\\"ITEM-001\\\" },\\n          \\\"pricing\\\": { \\\"$ref\\\": \\\"#/components/schemas/PriceDetails\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"city\": \"London\",\n        \"weather\": {\n          \"temperature\": 15,\n          \"humidity\": 82\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherData:\\n      type: object\\n      description: 'Current meteorological readings'\\n      properties:\\n        temperature:\\n          type: integer\\n          description: 'Current temperature in Celsius'\\n          example: 15\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 82\\n    WeatherResponse:\\n      type: object\\n      description: 'Weather data for a specific city'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'London'\\n        weather:\\n          $ref: '#/components/schemas/WeatherData'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"Tokyo\",\n        \"weather\": {\n          \"temperature\": 22,\n          \"humidity\": 60\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherData:\\n      type: object\\n      description: 'Current meteorological readings'\\n      properties:\\n        temperature:\\n          type: integer\\n          description: 'Current temperature in Celsius'\\n          example: 22\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 60\\n    WeatherResponse:\\n      type: object\\n      description: 'Weather data for a specific city'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'Tokyo'\\n        weather:\\n          $ref: '#/components/schemas/WeatherData'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"New York\",\n        \"weather\": {\n          \"temperature\": 18,\n          \"humidity\": 45\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherData:\\n      type: object\\n      description: 'Current meteorological readings'\\n      properties:\\n        temperature:\\n          type: integer\\n          description: 'Current temperature in Celsius'\\n          example: 18\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 45\\n    WeatherResponse:\\n      type: object\\n      description: 'Weather data for a specific city'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'New York'\\n        weather:\\n          $ref: '#/components/schemas/WeatherData'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"code\": \"ERR_400\",\n        \"details\": {\n          \"messages\": [\"Invalid input\", \"Missing required field\"]\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Error Response\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorDetail\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"messages\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of error messages\\\",\\n            \\\"items\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Error message text\\\", \\\"example\\\": \\\"Invalid input\\\" }\\n          }\\n        }\\n      },\\n      \\\"ErrorResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"code\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Unique error identifier\\\", \\\"example\\\": \\\"ERR_400\\\" },\\n          \\\"details\\\": { \\\"$ref\\\": \\\"#/components/schemas/ErrorDetail\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"error_code\": \"AUTH_FAILURE\",\n        \"error_data\": {\n          \"reasons\": [\"Token expired\", \"Invalid signature\"]\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Auth Error Response\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ReasonList\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"reasons\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Array of failure reasons\\\",\\n            \\\"items\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Specific failure cause\\