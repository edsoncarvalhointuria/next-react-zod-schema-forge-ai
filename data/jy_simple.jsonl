cription\\\": \\\"ISO 8601 timestamp for expected delivery\\\", \\\"example\\\": \\\"2023-12-01T18:00:00Z\\\" }\\n        }\\n      },\\n      \\\"OrderStatusResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Root response object for order status\\\",\\n        \\\"properties\\\": {\\n          \\\"order_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Unique identifier for the order\\\", \\\"example\\\": \\\"ORD-1145\\\" },\\n          \\\"tracking\\\": { \\\"$ref\\\": \\\"#/components/schemas/TrackingInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"user_id\": \"user_8821\",\n        \"preferences\": {\n          \"theme\": \"dark\",\n          \"language\": \"pt-BR\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Settings Fetch\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Preferences:\\n      type: object\\n      description: 'Configurações de preferência do usuário'\\n      properties:\\n        theme:\\n          type: string\\n          description: 'Tema visual da interface'\\n          example: 'dark'\\n        language:\\n          type: string\\n          description: 'Código do idioma preferido'\\n          example: 'pt-BR'\\n    UserSettings:\\n      type: object\\n      description: 'Resposta contendo configurações do usuário'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Identificador único do usuário'\\n          example: 'user_8821'\\n        preferences:\\n          $ref: '#/components/schemas/Preferences'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"user_4492\",\n        \"preferences\": {\n          \"theme\": \"light\",\n          \"language\": \"en-US\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Settings Fetch\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Preferences:\\n      type: object\\n      description: 'Configurações de preferência do usuário'\\n      properties:\\n        theme:\\n          type: string\\n          description: 'Tema visual da interface'\\n          example: 'light'\\n        language:\\n          type: string\\n          description: 'Código do idioma preferido'\\n          example: 'en-US'\\n    UserSettings:\\n      type: object\\n      description: 'Resposta contendo configurações do usuário'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Identificador único do usuário'\\n          example: 'user_4492'\\n        preferences:\\n          $ref: '#/components/schemas/Preferences'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"user_1029\",\n        \"preferences\": {\n          \"theme\": \"system\",\n          \"language\": \"es-ES\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Settings Fetch\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Preferences:\\n      type: object\\n      description: 'Configurações de preferência do usuário'\\n      properties:\\n        theme:\\n          type: string\\n          description: 'Tema visual da interface'\\n          example: 'system'\\n        language:\\n          type: string\\n          description: 'Código do idioma preferido'\\n          example: 'es-ES'\\n    UserSettings:\\n      type: object\\n      description: 'Resposta contendo configurações do usuário'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Identificador único do usuário'\\n          example: 'user_1029'\\n        preferences:\\n          $ref: '#/components/schemas/Preferences'\"\n    }\n  ]\n}"
