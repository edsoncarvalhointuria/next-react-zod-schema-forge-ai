"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"flight_id\": \"FL-8829\",\n        \"available_classes\": [\n          \"Economy\",\n          \"Business\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'A simple flight search result object'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Unique identifier for the flight'\\n          example: 'FL-8829'\\n        available_classes:\\n          type: array\\n          description: 'List of available seat classes'\\n          items:\\n            type: string\\n          example: ['Economy', 'Business']\"\n    },\n    {\n      \"raw_json\": {\n        \"flight_id\": \"FL-1042\",\n        \"available_classes\": [\n          \"First\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'A simple flight search result object'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Unique identifier for the flight'\\n          example: 'FL-1042'\\n        available_classes:\\n          type: array\\n          description: 'List of available seat classes'\\n          items:\\n            type: string\\n          example: ['First']\"\n    },\n    {\n      \"raw_json\": {\n        \"flight_id\": \"FL-5501\",\n        \"available_classes\": [\n          \"Economy\",\n          \"Premium Economy\",\n          \"Business\",\n          \"First\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'A simple flight search result object'\\n      properties:\\