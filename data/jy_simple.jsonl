"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"city\": \"São Paulo\",\n        \"weather_data\": {\n          \"temperature\": 22.5,\n          \"humidity\": 65\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherData:\\n      type: object\\n      description: 'Dados detalhados de clima'\\n      properties:\\n        temperature:\\n          type: number\\n          description: 'Temperatura atual em graus Celsius'\\n          example: 22.5\\n        humidity:\\n          type: integer\\n          description: 'Percentual de umidade relativa do ar'\\n          example: 65\\n    WeatherResponse:\\n      type: object\\n      description: 'Resposta do widget de clima'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Nome da cidade consultada'\\n          example: 'São Paulo'\\n        weather_data:\\n          $ref: '#/components/schemas/WeatherData'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"Rio de Janeiro\",\n        \"weather_data\": {\n          \"temperature\": 30.2,\n          \"humidity\": 80\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherData:\\n      type: object\\n      description: 'Dados detalhados de clima'\\n      properties:\\n        temperature:\\n          type: number\\n          description: 'Temperatura atual em graus Celsius'\\n          example: 30.2\\n        humidity:\\n          type: integer\\n          description: 'Percentual de umidade relativa do ar'\\n          example: 80\\n    WeatherResponse:\\n      type: object\\n      description: 'Resposta do widget de clima'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Nome da cidade consultada'\\n          example: 'Rio de Janeiro'\\n        weather_data:\\n          $ref: '#/components/schemas/WeatherData'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"Curitiba\",\n        \"weather_data\": {\n          \"temperature\": 12.0,\n          \"humidity\": 92\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherData:\\n      type: object\\n      description: 'Dados detalhados de clima'\\n      properties:\\n        temperature:\\n          type: number\\n          description: 'Temperatura atual em graus Celsius'\\n          example: 12.0\\n        humidity:\\n          type: integer\\n          description: 'Percentual de umidade relativa do ar'\\n          example: 92\\n    WeatherResponse:\\n      type: object\\n      description: 'Resposta do widget de clima'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Nome da cidade consultada'\\n          example: 'Curitiba'\\n        weather_data:\\n          $ref: '#/components/schemas/WeatherData'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"code\": \"ERR_001\",\n        \"messages\": [\n          \"O campo nome é obrigatório\",\n          \"O formato do e-mail é inválido\"\n        ]\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Error Response API\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Estrutura padrão de resposta para erros do servidor\\\",\\n        \\\"properties\\\": {\\n          \\\"code\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código identificador único do erro\\\", \\\"example\\\": \\\"ERR_001\\\" },\\n          \\\"messages\\\": { \\\"type\\\": \\\"array\\\", \\\"description\\\": \\\"Lista de mensagens explicativas sobre o erro\\\", \\\"items\\\": { \\\"type\\\": \\\"string\\\" }, \\\"example\\\": [\\\"O campo nome é obrigatório\\\", \\\"O formato do e-mail é inválido\\\"] }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"code\": \"AUTH_403\",\n        \"messages\": [\n          \"Token expirado\",\n          \"Acesso negado ao recurso solicitado\"\n        ]\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Auth Error Response\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta de erro para falhas de autenticação\\\",\\n        \\\"properties\\\": {\\n          \\\"code\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código de erro de autenticação\\\", \\\"example\\\": \\\"AUTH_403\\\" },\\n          \\\"messages\\\": { \\\"type\\\": \\\"array\\\", \\\"description\\\": \\\"Detalhes sobre a falha de acesso\\\", \\\"items\\\": { \\\"type\\\": \\\"string\\\" }, \\\"example\\\": [\\\"Token expirado\\\", \\\"Acesso negado ao recurso solicitado\\\"] }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"code\": \"DB_CONN_500\",\n        \"messages\": [\n          \"Falha na conexão com o banco de dados\",\n          \"Tente novamente mais tarde\"\n        ]\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Database Error Response\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta de erro para problemas de infraestrutura\\\",\\n        \\\"properties\\\": {\\n          \\\"code\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código de erro interno do sistema\\\", \\\"example\\\": \\\"DB_CONN_500\\\" },\\n          \\\"messages\\\": { \\\"type\\\": \\\"array\\\", \\\"description\\\": \\\"Mensagens de erro técnico\\\", \\\"items\\\": { \\\"type\\\": \\\"string\\\" }, \\\"example\\\": [\\\"Falha na conexão com o banco de dados\\\", \\\"Tente novamente mais tarde\\\"] }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_882\",\n        \"comment_details\": {\n          \"author_name\": \"Jane Doe\",\n          \"content\": \"Great article, very insightful!\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'The author and body of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The display name of the commenter'\\n          example: 'Jane Doe'\\n        content:\\n          type: string\\n          description: 'The text body of the comment'\\n          example: 'Great article, very insightful!'\\n    CommentSubmission:\\n      type: object\\n      description: 'Root object for comment submission'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_882'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_991\",\n        \"comment_details\": {\n          \"author_name\": \"John Smith\",\n          \"content\": \"I disagree with the second point.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'The author and body of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The display name of the commenter'\\n          example: 'John Smith'\\n        content:\\n          type: string\\n          description: 'The text body of the comment'\\n          example: 'I disagree with the second point.'\\n    CommentSubmission:\\n      type: object\\n      description: 'Root object for comment submission'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_991'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_105\",\n        \"comment_details\": {\n          \"author_name\": \"Alice Wong\",\n          \"content\": \"Thanks for sharing this tutorial.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'The author and body of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The display name of the commenter'\\n          example: 'Alice Wong'\\n        content:\\n          type: string\\n          description: 'The text body of the comment'\\n          example: 'Thanks for sharing this tutorial.'\\n    CommentSubmission:\\n      type: object\\n      description: 'Root object for comment submission'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_105'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"order_id\": \"ORD-7721\",\n        \"tracking\": {\n          \"status\": \"in_transit\",\n          \"estimated_delivery\": \"2023-11-15T14:00:00Z\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Order Status API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TrackingInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details regarding the shipment status and delivery timing\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Current shipment status\\\", \\\"example\\\": \\\"in_transit\\\" },\\n          \\\"estimated_delivery\\\": { \\\"type\\\": \\\"string\\\", \\\"format\\\": \\\"date-time\\\", \\\"description\\\": \\\"ISO 8601 timestamp for expected delivery\\\", \\\"example\\\": \\\"2023-11-15T14:00:00Z\\\" }\\n        }\\n      },\\n      \\\"OrderStatusResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response containing order identification and tracking details\\\",\\n        \\\"properties\\\": {\\n          \\\"order_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Unique identifier for the order\\\", \\\"example\\\": \\\"ORD-7721\\\" },\\n          \\\"tracking\\\": { \\\"$ref\\\": \\\"#/components/schemas/TrackingInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"order_id\": \"ORD-9902\",\n        \"tracking\": {\n          \"status\": \"delivered\",\n          \"estimated_delivery\": \"2023-10-20T09:30:00Z\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Order Status API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TrackingInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details regarding the shipment status and delivery timing\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Current shipment status\\\", \\\"example\\\": \\\"delivered\\\" },\\n          \\\"estimated_delivery\\\": { \\\"type\\\": \\\"string\\\", \\\"format\\\": \\\"date-time\\\", \\\"description\\\": \\\"ISO 8601 timestamp for expected delivery\\\", \\\"example\\\": \\\"2023-10-20T09:30:00Z\\\" }\\n        }\\n      },\\n      \\\"OrderStatusResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response containing order identification and tracking details\\\",\\n        \\\"properties\\\": {\\n          \\\"order_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Unique identifier for the order\\\", \\\"example\\\": \\\"ORD-9902\\\" },\\n          \\\"tracking\\\": { \\\"$ref\\\": \\\"#/components/schemas/TrackingInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"order_id\": \"ORD-1154\",\n        \"tracking\": {\n          \"status\": \"pending\",\n          \"estimated_delivery\": \"2023-12-01T18:00:00Z\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Order Status API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TrackingInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details regarding the shipment status and delivery timing\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Current shipment status\\\", \\\"example\\\": \\\"pending\\\" },\\n          \\\"estimated_delivery\\\": { \\\"type\\\": \\\"string\\\", \\\"format\\\": \\\"date-time\\\", \\\"description\\\": \\\"ISO 8601 timestamp for expected delivery\\\", \\\"example\\\": \\\"2023-12-01T18:00:00Z\\\" }\\n        }\\n      },\\n      \\\"OrderStatusResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response containing order identification and tracking details\\\",\\n        \\\"properties\\\": {\\n          \\\"order_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Unique identifier for the order\\\", \\\"example\\\": \\\"ORD-1154\\\" },\\n          \\\"tracking\\\": { \\\"$ref\\\": \\\"#/components/schemas/TrackingInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_998877\",\n        \"preferences\": {\n          \"theme\": \"dark\",\n          \"language\": \"en-US\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Settings API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Preferences:\\n      type: object\\n      description: 'User interface and localization settings'\\n      properties:\\n        theme:\\n          type: string\\n          description: 'The visual theme mode'\\n          example: 'dark'\\n        language:\\n          type: string\\n          description: 'The ISO locale code for the user'\\n          example: 'en-US'\\n    UserSettingsResponse:\\n      type: object\\n      description: 'Container for user profile settings'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'usr_998877'\\n        preferences:\\n          $ref: '#/components/schemas/Preferences'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_112233\",\n        \"preferences\": {\n          \"theme\": \"light\",\n          \"language\": \"fr-FR\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Settings API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Preferences:\\n      type: object\\n      description: 'User interface and localization settings'\\n      properties:\\n        theme:\\n          type: string\\n          description: 'The visual theme mode'\\n          example: 'light'\\n        language:\\n          type: string\\n          description: 'The ISO locale code for the user'\\n          example: 'fr-FR'\\n    UserSettingsResponse:\\n      type: object\\n      description: 'Container for user profile settings'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'usr_1122