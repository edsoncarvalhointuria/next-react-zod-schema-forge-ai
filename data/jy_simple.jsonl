"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"session_token\": \"abc-123-def-456\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LogoutRequest:\\n      type: object\\n      description: 'Requisição de logout contendo o token da sessão'\\n      properties:\\n        session_token:\\n          type: string\\n          description: 'O token de sessão único para invalidar'\\n          example: 'abc-123-def-456'\"\n    },\n    {\n      \"raw_json\": {\n        \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    TokenLogout:\\n      type: object\\n      description: 'Requisição de logout usando um token genérico'\\n      properties:\\n        token:\\n          type: string\\n          description: 'O token de autenticação fornecido'\\n          example: 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9'\"\n    },\n    {\n      \"raw_json\": {\n        \"access_token\": \"sess_987654321\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AccessLogout:\\n      type: object\\n      description: 'Requisição de logout usando o token de acesso'\\n      properties:\\n        access_token:\\n          type: string\\n          description: 'O token de acesso que deve ser revogado'\\n          example: 'sess_987654321'\"\n    }\n  ]\n}"
