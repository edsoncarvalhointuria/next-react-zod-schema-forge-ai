ect\\n      description: 'Root object for blog comment submission'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Unique identifier of the blog post'\\n          example: 'post_991'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_105\",\n        \"comment_details\": {\n          \"author_name\": \"Charlie Brown\",\n          \"content\": \"Thanks for sharing this tutorial.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'The content and author information of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The display name of the commenter'\\n          example: 'Charlie Brown'\\n        content:\\n          type: string\\n          description: 'The text body of the comment'\\n          example: 'Thanks for sharing this tutorial.'\\n    CommentSubmission:\\n      type: object\\n      description: 'Root object for blog comment submission'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Unique identifier of the blog post'\\n          example: 'post_105'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    }\n  ]\n}"
