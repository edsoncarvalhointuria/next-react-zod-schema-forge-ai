"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"email\": \"user@example.com\",\n        \"reset_code\": \"482910\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Password Reset API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PasswordResetRequest:\\n      type: object\\n      description: 'Request payload for resetting a user password'\\n      properties:\\n        email:\\n          type: string\\n          description: 'The email address of the user requesting the password reset'\\n          example: 'user@example.com'\\n        reset_code:\\n          type: string\\n          description: 'The temporary numeric code sent to the user email'\\n          example: '482910'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_email\": \"admin@company.org\",\n        \"verification_token\": \"a1b2c3d4e5f6\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Account Recovery API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ResetTokenRequest:\\n      type: object\\n      description: 'Payload containing user identity and verification token'\\n      properties:\\n        user_email:\\n          type: string\\n          description: 'Registered email address of the account owner'\\n          example: 'admin@company.org'\\n        verification_token:\\n          type: string\\n          description: 'Alphanumeric temporary token for identity verification'\\n          example: 'a1b2c3d4e5f6'\"\n    },\n    {\n      \"raw_json\": {\n        \"email\": \"customer.service@webmail.com\",\n        \"code\": \"998877\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Security Reset API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ResetCodeRequest:\\n      type: object\\n      description: 'Simple request to validate a password reset code'\\n      properties:\\n        email:\\n          type: string\\n          description: 'User email used for authentication'\\n          example: 'customer.service@webmail.com'\\n        code:\\n          type: string\\n          description: 'The 6-digit security code provided via email'\\n          example: '998877'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"message\": \"Limite de requisições excedido. Por favor, aguarde antes de tentar novamente.\",\n        \"retry_after\": 60\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"API Rate Limit Warning\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"RateLimitWarning\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta de aviso quando o limite de taxa de requisições é atingido\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Mensagem detalhando o motivo do bloqueio temporário\\\",\\n            \\\"example\\\": \\\"Limite de requisições excedido. Por favor, aguarde antes de tentar novamente.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Quantidade de segundos que o cliente deve esperar antes de realizar uma nova requisição\\\",\\n            \\\"example\\\": 60\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"message\": \"Cota de API esgotada para o período atual.\",\n        \"retry_after\": 3600\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"API Rate Limit Warning\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"QuotaExceeded\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta indicando que a cota de uso foi totalmente consumida\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Texto explicativo sobre a exaustão da cota\\\",\\n            \\\"example\\\": \\\"Cota de API esgotada para o período atual.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Tempo de espera em segundos até a renovação da cota\\\",\\n            \\\"example\\\": 3600\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"message\": \"Muitas requisições detectadas em um curto intervalo de tempo.\",\n        \"retry_after\": 15\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"API Rate Limit Warning\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TooManyRequests\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta de erro para excesso de requisições rápidas (burst)\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Aviso sobre a frequência excessiva de chamadas\\\",\\n            \\\"example\\\": \\\"Muitas requisições detectadas em um curto intervalo de tempo.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Segundos necessários para a estabilização do fluxo de requisições\\\",\\n            \\\"example\\\": 15\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"postId\": \"post_12345\",\n        \"isLiked\": true\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Like Toggle API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LikeRequest:\\n      type: object\\n      description: 'Requisição para alternar a curtida de um post'\\n      properties:\\n        postId:\\n          type: string\\n          description: 'O identificador único da postagem'\\n          example: 'post_12345'\\n        isLiked:\\n          type: boolean\\n          description: 'Define se o post deve ser marcado como curtido ou não'\\n          example: true\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": 98765,\n        \"liked\": false\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Post Interaction API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PostLikeToggle:\\n      type: object\\n      description: 'Objeto para atualizar o estado de curtida de uma publicação'\\n      properties:\\n        post_id:\\n          type: integer\\n          description: 'ID numérico da publicação'\\n          example: 98765\\n        liked:\\n          type: boolean\\n          description: 'Estado booleano indicando se a curtida foi removida ou adicionada'\\n          example: false\"\n    },\n    {\n      \"raw_json\": {\n        \"id\": \"abc-def-ghi\",\n        \"status\": true\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Social Engagement API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ToggleLike:\\n      type: object\\n      description: 'Payload para alternar a interação de like em um conteúdo'\\n      properties:\\n        id:\\n          type: string\\n          description: 'Código de referência UUID da postagem'\\n          example: 'abc-def-ghi'\\n        status:\\n          type: boolean\\n          description: 'Valor booleano representando a ação de curtir'\\n          example: true\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_789abc123\",\n        \"auth_code\": \"452189\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Autenticação de Dois Fatores\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TwoFactorAuth\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Requisição para validação de código de autenticação de dois fatores\\\",\\n        \\\"properties\\\": {\\n          \\\"user_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador único do usuário no sistema\\\",\\n            \\\"example\\\": \\\"usr_789abc123\\\"\\n          },\\n          \\\"auth_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Código numérico de 6 dígitos enviado ao usuário\\\",\\n            \\\"example\\\": \\\"452189\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"userId\": 102938,\n        \"verification_code\": \"883012\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Verificação de Identidade\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"VerificationRequest\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Dados necessários para verificar a identidade do usuário via código\\\",\\n        \\\"properties\\\": {\\n          \\\"userId\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"ID numérico do usuário\\\",\\n            \\\"example\\\": 102938\\n          },\\n          \\\"verification_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Código de verificação composto por 6 dígitos\\\",\\n            \\\"example\\\": \\\"883012\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"identifier\": \"usuario@email.com\",\n        \"otp_code\": \"112233\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Submissão de OTP\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"OtpSubmission\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Envio de senha de uso único (OTP) para autenticação\\\",\\n        \\\"properties\\\": {\\n          \\\"identifier\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Identificador do usuário, como e-mail ou telefone\\\",\\n            \\\"example\\\": \\\"usuario@email.com\\\"\\n          },\\n          \\\"otp_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Código OTP de 6 dígitos para validação de acesso\\\",\\n            \\\"example\\\": \\\"112233\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Operation completed successfully\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Generic Success API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    SuccessResponse:\\n      type: object\\n      description: Standard success response for general operations\\n      properties:\\n        success:\\n          type: boolean\\n          description: Indicates if the request was processed successfully\\n          example: true\\n        message:\\n          type: string\\n          description: A human-readable message describing the outcome\\n          example: Operation completed successfully\"\n    },\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Data processed successfully\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Process Success API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ProcessResponse:\\n      type: object\\n      description: Response indicating successful data processing\\n      properties:\\n        success:\\n          type: boolean\\n          description: Flag indicating the processing status\\n          example: true\\n        message:\\n          type: string\\n          description: Detailed message about the processing result\\n          example: Data processed successfully\"\n    },\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Resource created successfully\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Resource Creation API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CreateResponse:\\n      type: object\\n      description: Response confirming the creation of a resource\\n      properties:\\n        success:\\n          type: boolean\\n          description: Indicates if the resource was created\\n          example: true\\n        message:\\n          type: string\\n          description: Confirmation message for the creation event\\n          example: Resource created successfully\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"email\": \"jane.doe@example.com\",\n        \"newsletter\": true\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Email Subscription API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"EmailSubscription\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Payload for subscribing a user to a newsletter\\\",\\n        \\\"properties\\\": {\\n          \\\"email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The email address of the subscriber\\\",\\n            \\\"example\\\": \\\"jane.doe@example.com\\\"\\n          },\\n          \\\"newsletter\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Whether the user opts into the newsletter\\\",\\n            \\\"example\\\": true\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"email_address\": \"support@techcorp.io\",\n        \"opt_in\": false\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Subscription Management API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SubscriptionRequest\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Request body for email subscription status\\\",\\n        \\\"properties\\\": {\\n          \\\"email_address\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The primary contact email address\\\",\\n            \\\"example\\\": \\\"support@techcorp.io\\\"\\n          },\\n          \\\"opt_in\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Indicates if the user has consented to receive emails\\\",\\n            \\\"example\\\": false\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"user_email\": \"alex.smith@webmail.com\",\n        \"marketing_consent\": true\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Marketing Opt-in API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"NewsletterSignup\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Data for signing up to marketing communications\\\",\\n        \\\"properties\\\": {\\n          \\\"user_email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The email address provided by the user\\\",\\n            \\\"example\\\": \\\"alex.smith@webmail.com\\\"\\n          },\\n          \\\"marketing_consent\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Consent flag for marketing materials\\\",\\n            \\\"example\\\": true\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"session_token\": \"abc123xyz789_session_id\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LogoutRequest:\\n      type: object\\n      description: 'Requisição para encerrar a sessão do usuário'\\n      properties:\\n        session_token:\\n          type: string\\n          description: 'Token de sessão único utilizado para identificar e invalidar a conexão atual'\\n          example: 'abc123xyz789_session_id'\"\n    },\n    {\n      \"raw_json\": {\n        \"auth_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VyX2lkIjoyfQ\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Authentication API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AuthLogout:\\n      type: object\\n      description: 'Objeto de autenticação para processar o logout'\\n      properties:\\n        auth_token:\\n          type: string\\n          description: 'Token de autenticação JWT a ser revogado no servidor'\\n          example: 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VyX2lkIjoyfQ'\"\n    },\n    {\n      \"raw_json\": {\n        \"token\": \"sess_9876543210_token_val\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Session Manager\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    SessionTermination:\\n      type: object\\n      description: 'Dados necessários para a terminação de sessão'\\n      properties:\\n        token:\\n          type: string\\n          description: 'Identificador da sessão que deve ser removida do cache de autenticação'\\n          example: 'sess_9876543210_token_val'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"feature_name\": \"beta_dashboard\",\n        \"is_enabled\": true\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Feature Flag API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"FeatureFlag\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response indicating the status of a specific feature flag\\\",\\n        \\\"properties\\\": {\\n          \\\"feature_name\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The unique identifier of the feature\\\",\\n            \\\"example\\\": \\\"beta_dashboard\\\"\\n          },\\n          \\\"is_enabled\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Whether the feature is currently active\\\",\\n            \\\"example\\\": true\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"flag_id\": \"new_payment_gateway\",\n        \"active\": false\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Feature Toggle API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"FeatureToggle\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Status of a feature toggle flag\\\",\\n        \\\"properties\\\": {\\n          \\\"flag_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The internal ID of the toggle flag\\\",\\n            \\\"example\\\": \\\"new_payment_gateway\\\"\\n          },\\n          \\\"active\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"The current activation state of the flag\\\",\\n            \\\"example\\\": false\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"feature_key\": \"dark_mode_v2\",\n        \"enabled\": true\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Feature Status API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"FeatureStatus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"The enabled status of a specific feature key\\\",\\n        \\\"properties\\\": {\\n          \\\"feature_key\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The key used to look up the feature status\\\",\\n            \\\"example\\\": \\\"dark_mode_v2\\\"\\n          },\\n          \\\"enabled\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"Indicates if the feature is enabled for the user\\\",\\n            \\\"example\\\": true\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_772194\",\n        \"reason\": \"Não utilizo mais as funcionalidades da plataforma.\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Account Deletion API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AccountDeletionRequest:\\n      type: object\\n      description: 'Payload para solicitação de exclusão de conta'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Identificador único do usuário que solicita a exclusão'\\n          example: 'usr_772194'\\n        reason:\\n          type: string\\n          description: 'Motivo textual fornecido pelo usuário para a exclusão'\\n          example: 'Não utilizo mais as funcionalidades da plataforma.'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"9928341\",\n        \"reason\": \"Preocupações com a privacidade dos meus dados.\",\n        \"confirmation_timestamp\": \"2023-11-15T14:30:00Z\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Account Deletion API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    DeletionConfirmation:\\n      type: object\\n      description: 'Confirmação de exclusão de conta com carimbo de tempo'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'ID numérico do usuário'\\n          example: '9928341'\\n        reason:\\n          type: string\\n          description: 'Justificativa para a remoção da conta'\\n          example: 'Preocupações com a privacidade dos meus dados.'\\n        confirmation_timestamp:\\n          type: string\\n          format: date-time\\n          description: 'Data e hora exata da confirmação da exclusão'\\n          example: '2023-11-15T14:30:00Z'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"uuid-882-abc-123\",\n        \"reason\": \"Encontrei um serviço concorrente com melhor custo-benefício.\",\n        \"reason_category\": \"competitor\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Account Deletion API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AccountDeletionPayload:\\n      type: object\\n      description: 'Payload de exclusão categorizado para análise de churn'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Identificador único (UUID) do usuário'\\n          example: 'uuid-882-abc-123'\\n        reason:\\n          type: string\\n          description: 'Descrição detalhada do motivo da saída'\\n          example: 'Encontrei um serviço concorrente com melhor custo-benefício.'\\n        reason_category:\\n          type: string\\n          description: 'Categoria simplificada do motivo para fins estatísticos'\\n          example: 'competitor'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"status\": \"ok\",\n        \"uptime\": 3600\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Health Check API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"HealthCheck\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Basic health check response\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The current operational status of the service\\\",\\n            \\\"example\\\": \\\"ok\\\"\\n          },\\n          \\\"uptime\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"The system uptime measured in seconds\\\",\\n            \\\"example\\\": 3600\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"status\": \"healthy\",\n        \"uptime\": 86400\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"System Status API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SystemHealth\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"System health status response\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The health state of the application\\\",\\n            \\\"example\\\": \\\"healthy\\\"\\n          },\\n          \\\"uptime\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Total uptime in seconds since last boot\\\",\\n            \\\"example\\\": 86400\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"status\": \"degraded\",\n        \"uptime\": 120\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Ping API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"PingResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Ping response for service availability\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The availability status of the endpoint\\\",\\n            \\\"example\\\": \\\"degraded\\\"\\n          },\\n          \\\"uptime\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Uptime since last restart in seconds\\\",\\n            \\\"example\\\": 120\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"email\": \"user@example.com\",\n        \"reset_code\": \"123456\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Password Reset API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PasswordResetRequest:\\n      type: object\\n      description: Request payload for resetting a user password\\n      properties:\\n        email:\\n          type: string\\n          description: The registered email address of the user\\n          example: user@example.com\\n        reset_code:\\n          type: string\\n          description: The temporary 6-digit verification code\\n          example: '123456'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_email\": \"admin@company.org\",\n        \"verification_code\": \"XP-9921\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Account Recovery API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ResetVerification:\\n      type: object\\n      description: Verification details for password recovery\\n      properties:\\n        user_email:\\n          type: string\\n          description: The email address associated with the account\\n          example: admin@company.org\\n        verification_code:\\n          type: string\\n          description: The alphanumeric temporary reset token\\n          example: XP-9921\"\n    },\n    {\n      \"raw_json\": {\n        \"email\": \"customer@service.net\",\n        \"code\": \"887766\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Password Recovery API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PasswordRecovery:\\n      type: object\\n      description: Minimal payload for password reset verification\\n      properties:\\n        email:\\n          type: string\\n          description: User's email address\\n          example: customer@service.net\\n        code:\\n          type: string\\n          description: Temporary numeric reset code\\n          example: '887766'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"message\": \"Rate limit exceeded. Please try again later.\",\n        \"retry_after\": 60\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Rate Limit API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"RateLimitWarning\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response returned when the API rate limit is reached\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Human-readable warning message\\\",\\n            \\\"example\\\": \\\"Rate limit exceeded. Please try again later.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Number of seconds to wait before retrying the request\\\",\\n            \\\"example\\\": 60\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"message\": \"Too many requests. Your hourly quota has been exhausted.\",\n        \"retry_after\": 3600\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Quota Management API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"QuotaExceededResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response returned when the user quota is exhausted\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Detailed explanation of the quota limit breach\\\",\\n            \\\"example\\\": \\\"Too many requests. Your hourly quota has been exhausted.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Seconds until the quota window resets\\\",\\n            \\\"example\\\": 3600\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"message\": \"Slow down! You are sending requests too quickly.\",\n        \"retry_after\": 10\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Throttling API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ThrottlingResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Response returned during temporary request throttling\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Short warning message regarding request velocity\\\",\\n            \\\"example\\\": \\\"Slow down! You are sending requests too quickly.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Seconds to wait before the next request is permitted\\\",\\n            \\\"example\\\": 10\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"postId\": \"123\",\n        \"isLiked\": true\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Like Toggle API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LikeRequest:\\n      type: object\\n      description: 'Requisição para alternar a curtida de um post'\\n      properties:\\n        postId:\\n          type: string\\n          description: 'O identificador único do post'\\n          example: '123'\\n        isLiked:\\n          type: boolean\\n          description: 'Define se o post está curtido ou não'\\n          example: true\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": 456,\n        \"liked\": false\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Post Interaction API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PostLikePayload:\\n      type: object\\n      description: 'Payload para atualizar o estado de curtida'\\n      properties:\\n        post_id:\\n          type: integer\\n          description: 'ID numérico do post'\\n          example: 456\\n        liked:\\n          type: boolean\\n          description: 'Estado da curtida (verdadeiro para curtido)'\\n          example: false\"\n    },\n    {\n      \"raw_json\": {\n        \"id\": \"abc-123-def\",\n        \"status\": true\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Social Engagement API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ToggleLikeSchema:\\n      type: object\\n      description: 'Esquema para alternar a interação de curtida'\\n      properties:\\n        id:\\n          type: string\\n          description: 'UUID do post a ser alterado'\\n          example: 'abc-123-def'\\n        status:\\n          type: boolean\\n          description: 'Novo status da curtida'\\n          example: true\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"userId\": \"usr_7721940\",\n        \"authCode\": \"482910\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Two-Factor Authentication API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TwoFactorAuthRequest\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Request payload for submitting a 2FA verification code\\\",\\n        \\\"properties\\\": {\\n          \\\"userId\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The unique alphanumeric identifier of the user\\\",\\n            \\\"example\\\": \\\"usr_7721940\\\"\\n          },\\n          \\\"authCode\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The 6-digit security code sent to the user\\\",\\n            \\\"example\\\": \\\"482910\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": 1029384,\n        \"verification_code\": \"993021\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"User Verification API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"VerificationSubmission\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Payload used to verify a user identity via a numeric code\\\",\\n        \\\"properties\\\": {\\n          \\\"user_id\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"The numeric database ID of the user\\\",\\n            \\\"example\\\": 1029384\\n          },\\n          \\\"verification_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The 6-digit verification string\\\",\\n            \\\"example\\\": \\\"993021\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"identifier\": \"dev.architect@example.com\",\n        \"otp_code\": \"115588\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"OTP Validation API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"OtpVerification\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"One-Time Password (OTP) submission payload\\\",\\n        \\\"properties\\\": {\\n          \\\"identifier\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The user's registered email address or username\\\",\\n            \\\"example\\\": \\\"dev.architect@example.com\\\"\\n          },\\n          \\\"otp_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The 6-digit one-time password\\\",\\n            \\\"example\\\": \\\"115588\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Operação realizada com sucesso\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: API de Resposta Genérica\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    SuccessResponse:\\n      type: object\\n      description: 'Resposta padrão de sucesso da API'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'Indica se a operação foi bem sucedida'\\n          example: true\\n        message:\\n          type: string\\n          description: 'Mensagem informativa sobre o resultado da operação'\\n          example: 'Operação realizada com sucesso'\"\n    },\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Dados processados corretamente\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: API de Processamento\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ProcessResponse:\\n      type: object\\n      description: 'Resposta de confirmação de processamento'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'Sinaliza se o processamento foi concluído com êxito'\\n          example: true\\n        message:\\n          type: string\\n          description: 'Descrição do status do processamento'\\n          example: 'Dados processados corretamente'\"\n    },\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Registro criado com êxito\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: API de Cadastro\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CreateResponse:\\n      type: object\\n      description: 'Resposta de confirmação de criação de recurso'\\n      properties:\\n        success:\\n          type: boolean\\n          description: 'Confirma se o recurso foi criado com sucesso'\\n          example: true\\n        message:\\n          type: string\\n          descriptio