therData'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"Curitiba\",\n        \"weather\": {\n          \"temperature\": 15,\n          \"humidity\": 90\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherData:\\n      type: object\\n      description: 'Dados detalhados de clima'\\n      properties:\\n        temperature:\\n          type: integer\\n          description: 'Temperatura atual em graus Celsius'\\n          example: 15\\n        humidity:\\n          type: integer\\n          description: 'Percentual de umidade relativa do ar'\\n          example: 90\\n    WeatherResponse:\\n      type: object\\n      description: 'Resposta do widget de clima'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Nome da cidade consultada'\\n          example: 'Curitiba'\\n        weather:\\n          $ref: '#/components/schemas/WeatherData'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"error_code\": \"ERR_001\",\n        \"details\": {\n          \"messages\": [\"Campo obrigatório ausente\", \"Formato de data inválido\"]\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Complex Error Response\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorDetails\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"messages\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de mensagens de erro detalhadas\\\",\\n            \\\"items\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Descrição específica do erro\\\", \\\"example\\\": \\\"Campo obrigatório ausente\\\" }\\n          }\\n        }\\n      },\\n      \\\"ErrorResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código identificador do erro\\\", \\\"example\\\": \\\"ERR_001\\\" },\\n          \\\"details\\\": { \\\"$ref\\\": \\\"#/components/schemas/ErrorDetails\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"error_code\": \"AUTH_FAILURE\",\n        \"details\": {\n          \"messages\": [\"Token expirado\", \"Sessão encerrada\"]\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Auth Error Response\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"MessageContainer\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"messages\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Coleção de mensagens de falha de autenticação\\\",\\n    