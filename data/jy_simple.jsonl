"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_123\",\n        \"comment_data\": {\n          \"author_name\": \"Alice Smith\",\n          \"content\": \"Great article, very insightful!\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'The author and text content of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The display name of the comment author'\\n          example: 'Alice Smith'\\n        content:\\n          type: string\\n          description: 'The body text of the comment'\\n          example: 'Great article, very insightful!'\\n    CommentSubmission:\\n      type: object\\n      description: 'Payload for submitting a new comment'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_123'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_456\",\n        \"comment_data\": {\n          \"author_name\": \"Bob Johnson\",\n          \"content\": \"I disagree with the second point.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'The author and text content of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The display name of the comment author'\\n          example: 'Bob Johnson'\\n        content:\\n          type: string\\n          description: 'The body text of the comment'\\n          example: 'I disagree with the second point.'\\n    CommentSubmission:\\n      type: object\\n    