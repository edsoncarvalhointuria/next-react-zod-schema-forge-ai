"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_9921\",\n        \"comment_data\": {\n          \"author_name\": \"Alice Johnson\",\n          \"content\": \"This is a very insightful article!\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'The author and text content of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The display name of the comment author'\\n          example: 'Alice Johnson'\\n        content:\\n          type: string\\n          description: 'The body text of the comment'\\n          example: 'This is a very insightful article!'\\n    CommentSubmission:\\n      type: object\\n      description: 'Payload for submitting a new comment'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_9921'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_4452\",\n        \"comment_data\": {\n          \"author_name\": \"Bob Smith\",\n          \"content\": \"I disagree with the third point mentioned.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'The author and text content of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The display name of the comment author'\\n          example: 'Bob Smith'\\n        content:\\n          type: string\\n          description: 'The body text of the comment'\\n          example: 'I disagree with the third point mentioned.'\\n    CommentSubmission:\\n      type: object\\n      description: 'Payload for submitting a new comment'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_4452'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_1023\",\n        \"comment_data\": {\n          \"author_name\": \"Charlie Davis\",\n          \"content\": \"Thanks for sharing this tutorial.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'The author and text content of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The display name of the comment author'\\n          example: 'Charlie Davis'\\n        content:\\n          type: string\\n          description: 'The body text of the comment'\\n          example: 'Thanks for sharing this tutorial.'\\n    CommentSubmission:\\n      type: object\\n      description: 'Payload for submitting a new comment'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_1023'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    }\n  ]\n}"
