"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"user_id\": \"user_88234\",\n        \"reason\": \"Não utilizo mais os serviços da plataforma\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Account Deletion API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AccountDeletionRequest:\\n      type: object\\n      description: 'Payload simples para solicitação de exclusão de conta'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Identificador único do usuário que solicita a exclusão'\\n          example: 'user_88234'\\n        reason:\\n          type: string\\n          description: 'Motivo textual para a exclusão da conta'\\n          example: 'Não utilizo mais os serviços da plataforma'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"user_88234\",\n        \"reason\": \"Preocupações com a privacidade dos dados\",\n        \"confirmation_date\": \"2023-10-27T14:30:00Z\",\n        \"is_permanent\": true\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Account Deletion API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AccountDeletionRequest:\\n      type: object\\n      description: 'Payload detalhado para confirmação de exclusão de conta'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Identificador único do usuário'\\n          example: 'user_88234'\\n        reason:\\n          type: string\\n          description: 'Motivo detalhado para a exclusão da conta'\\n          example: 'Preocupações com a privacidade dos dados'\\n        confirmation_date:\\n          type: string\\n          format: date-time\\n          description: 'Data e hora em que a exclusão foi confirmada'\\n          example: '2023-10-27T14:30:00Z'\\n        is_permanent:\\n          type: boolean\\n          description: 'Indica se a exclusão é definitiva e irreversível'\\n          example: true\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"user_88234\",\n        \"request_metadata\": {\n          \"timestamp\": \"2023-10-27T15:00:00Z\",\n          \"ip_address\": \"192.168.1.45\"\n        },\n        \"deletion_reason\": {\n          \"code\": \"PRIVACY_CONCERNS\",\n          \"text\": \"Não concordo com os novos termos de uso\",\n          \"category\": \"Legal\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Account Deletion API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    AccountDeletionRequest:\\n      type: object\\n      description: 'Payload complexo de exclusão de conta com metadados e categorização'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Identificador único do usuário'\\n          example: 'user_88234'\\n        request_metadata:\\n          type: object\\n          description: 'Informações técnicas sobre a requisição'\\n          $ref: '#/components/schemas/RequestMetadata'\\n        deletion_reason:\\n          type: object\\n          description: 'Detalhes estruturados sobre o motivo da exclusão'\\n          $ref: '#/components/schemas/DeletionReason'\\n    RequestMetadata:\\n      type: object\\n      description: 'Metadados da requisição de exclusão'\\n      properties:\\n        timestamp:\\n          type: string\\n          format: date-time\\n          description: 'Data e hora exata da solicitação'\\n          example: '2023-10-27T15:00:00Z'\\n        ip_address:\\n          type: string\\n          description: 'Endereço IP de onde partiu a requisição'\\n          example: '192.168.1.45'\\n    DeletionReason:\\n      type: object\\n      description: 'Estrutura de motivo de exclusão'\\n      properties:\\n        code:\\n          type: string\\n          description: 'Código interno de categorização do motivo'\\n          example: 'PRIVACY_CONCERNS'\\n        text:\\n          type: string\\n          description: 'Descrição livre fornecida pelo usuário'\\n          example: 'Não concordo com os novos termos de uso'\\n        category:\\n          type: string\\n          description: 'Categoria geral do feedback'\\n          example: 'Legal'\"\n    }\n  ]\n}"
