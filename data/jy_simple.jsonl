"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_8821\",\n        \"skus\": [\"PROD-001\", \"PROD-005\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'Resumo simples do carrinho de compras contendo o ID e os SKUs dos produtos'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Identificador único da sessão do carrinho'\\n          example: 'cart_8821'\\n        skus:\\n          type: array\\n          description: 'Lista de códigos de estoque dos produtos'\\n          items:\\n            type: string\\n            example: 'PROD-001'\"\n    },\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_9932\",\n        \"skus\": [\"BOOK-123\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'Resumo simples do carrinho de compras contendo o ID e os SKUs dos produtos'\\n      properties:\\n        cart_id:\\n          type: string\\n          description: 'Identificador único da sessão do carrinho'\\n          example: 'cart_9932'\\n        skus:\\n          type: array\\n          description: 'Lista de códigos de estoque dos produtos'\\n          items:\\n            type: string\\n            example: 'BOOK-123'\"\n    },\n    {\n      \"raw_json\": {\n        \"cart_id\": \"cart_4455\",\n        \"skus\": [\"ELEC-99\", \"ELEC-88\", \"ELEC-77\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Shopping Cart Summary\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CartSummary:\\n      type: object\\n      description: 'Resumo simples do carrinho de compras contendo o ID e os SKUs dos produtos'\\n      properties:\\n        cart_id:\\n          type: string\\n          descriptio