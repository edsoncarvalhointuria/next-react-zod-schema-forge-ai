"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_9982\",\n        \"comment_details\": {\n          \"author_name\": \"Alice Johnson\",\n          \"content\": \"Great insights on API design!\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'The body and author information of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The display name of the comment author'\\n          example: 'Alice Johnson'\\n        content:\\n          type: string\\n          description: 'The text content of the comment'\\n          example: 'Great insights on API design!'\\n    CommentSubmission:\\n      type: object\\n      description: 'A request to submit a comment to a specific blog post'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_9982'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_4431\",\n        \"comment_details\": {\n          \"author_name\": \"Bob Smith\",\n          \"content\": \"Could you elaborate more on the security aspects?\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'The body and author information of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The display name of the comment author'\\n          example: 'Bob Smith'\\n        content:\\n          type: string\\n          description: 'The text content of the comment'\\n          example: 'Could you elaborate more on the security aspects?'\\n    CommentSubmission:\\n      type: object\\n      description: 'A request to submit a comment to a specific blog post'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_4431'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_1029\",\n        \"comment_details\": {\n          \"author_name\": \"Charlie Davis\",\n          \"content\": \"Very helpful tutorial, thanks for sharing.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'The body and author information of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The display name of the comment author'\\n          example: 'Charlie Davis'\\n        content:\\n          type: string\\n          description: 'The text content of the comment'\\n          example: 'Very helpful tutorial, thanks for sharing.'\\n    CommentSubmission:\\n      type: object\\n      description: 'A request to submit a comment to a specific blog post'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_1029'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"order_id\": \"ORD-1001\",\n        \"tracking\": {\n          \"status\": \"shipped\",\n          \"estimated_delivery\": \"2023-12-25\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Order Status API\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TrackingInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações de rastreamento do pedido\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Status atual do envio\\\", \\\"example\\\": \\\"shipped\\\" },\\n          \\\"estimated_delivery\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Data prevista para entrega\\\", \\\"example\\\": \\\"2023-12-25\\\" }\\n        }\\n      },\\n      \\\"OrderResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta contendo o status do pedido\\\",\\n        \\\"properties\\\": {\\n          \\\"order_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Identificador único do pedido\\\", \\\"example\\\": \\\"ORD-1001\\\" },\\n          \\\"tracking\\\": { \\\"$ref\\\": \\\"#/components/schemas/TrackingInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"order_id\": \"ORD-9928\",\n        \"tracking\": {\n          \"status\": \"processing\",\n          \"estimated_delivery\": \"2023-12-28\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Order Status API\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TrackingInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações de rastreamento do pedido\\