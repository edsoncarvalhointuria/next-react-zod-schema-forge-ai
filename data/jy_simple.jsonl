tion code\\\",\\n            \\\"example\\\": \\\"102938\\\"\\n          },\\n          \\\"device_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The identifier of the device used for authentication\\\",\\n            \\\"example\\\": \\\"iphone_14_pro\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"u_9901\",\n        \"code\": \"556677\",\n        \"session_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9\"\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"2FA Session Submission\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TwoFactorSessionRequest\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Request body for 2FA verification linked to a session\\\",\\n        \\\"properties\\\": {\\n          \\\"user_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The unique identifier of the user\\\",\\n            \\\"example\\\": \\\"u_9901\\\"\\n          },\\n          \\\"code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The 6-digit authentication code\\\",\\n            \\\"example\\\": \\\"556677\\\"\\n          },\\n          \\\"session_token\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The temporary session token generated during login\\\",\\n            \\\"example\\\": \\\"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
