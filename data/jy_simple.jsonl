"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"email\": \"user@example.com\",\n        \"reset_code\": \"482910\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Password Reset API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PasswordResetRequest:\\n      type: object\\n      description: 'Request payload for resetting a user password'\\n      properties:\\n        email:\\n          type: string\\n          format: email\\n          description: 'The registered email address of the user'\\n          example: 'user@example.com'\\n        reset_code:\\n          type: string\\n          description: 'The temporary numeric code sent to the user email'\\n          example: '482910'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_email\": \"admin@company.org\",\n        \"verification_code\": \"XJ-992-LP\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Account Recovery API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ResetPasswordPayload:\\n      type: object\\n      description: 'Payload used to verify identity for password recovery'\\n      properties:\\n        user_email:\\n          type: string\\n          format: email\\n          description: 'The email address associated with the account'\\n          example: 'admin@company.org'\\n        verification_code:\\n          type: string\\n          description: 'The alphanumeric verification token'\\n          example: 'XJ-992-LP'\"\n    },\n    {\n      \"raw_json\": {\n        \"email_address\": \"customer.service@webmail.com\",\n        \"code\": \"883712\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Security Reset API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PasswordRecoveryRequest:\\n      type: object\\n      description: 'Data required to initiate a password change'\\n      properties:\\n        email_address:\\n          type: string\\n          format: email\\n          description: 'User email 