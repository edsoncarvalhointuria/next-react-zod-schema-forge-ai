"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_8821\",\n        \"comment_details\": {\n          \"author_name\": \"Carlos Silva\",\n          \"content\": \"Excelente artigo, muito esclarecedor!\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'Detalhes do autor e o conteúdo do comentário'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'Nome do autor do comentário'\\n          example: 'Carlos Silva'\\n        content:\\n          type: string\\n          description: 'Texto do comentário enviado'\\n          example: 'Excelente artigo, muito esclarecedor!'\\n    CommentSubmission:\\n      type: object\\n      description: 'Estrutura de envio de um novo comentário'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Identificador único da postagem'\\n          example: 'post_8821'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_4492\",\n        \"comment_details\": {\n          \"author_name\": \"Ana Oliveira\",\n          \"content\": \"Poderia detalhar mais sobre a seção de segurança?\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'Informações sobre quem comenta e o que foi escrito'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'Nome completo do autor'\\n          example: 'Ana Oliveira'\\n        content:\\n          type: string\\n          description: 'Corpo do texto do comentário'\\n          example: 'Poderia detalhar mais sobre a seção de segurança?'\\n    CommentSubmission:\\n      type: object\\n      description: 'Payload para submissão de comentários em posts'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'ID da postagem alvo'\\n          example: 'post_4492'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_1023\",\n        \"comment_details\": {\n          \"author_name\": \"Roberto Mendes\",\n          \"content\": \"Concordo plenamente com os pontos levantados.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'Dados do autor e mensagem do comentário'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'Nome do usuário que está comentando'\\n          example: 'Roberto Mendes'\\n        content:\\n          type: string\\n          description: 'Mensagem principal do comentário'\\n          example: 'Concordo plenamente com os pontos levantados.'\\n    CommentSubmission:\\n      type: object\\n      description: 'Objeto de requisição para novos comentários'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Identificador do post original'\\n          example: 'post_1023'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"order_id\": \"ORD-7721\",\n        \"tracking\": {\n          \"status\": \"in_transit\",\n          \"estimated_delivery\": \"2023-11-15T14:00:00Z\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Order Status API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TrackingInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details regarding the shipment status and delivery timing\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Current shipment status\\\", \\\"example\\\": \\\"in_transit\\\" },\\n          \\\"estimated_delivery\\\": { \\\"type\\\": \\\"string\\\", \\\"format\\\": \\\"date-time\\\", \\\"description\\\": \\\"ISO 8601 timestamp for expected delivery\\\", \\\"example\\\": \\\"2023-11-15T14:00:00Z\\\" }\\n        }\\n      },\\n      \\\"OrderStatusResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Root response object for order status\\\",\\n        \\\"properties\\\": {\\n          \\\"order_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Unique identifier for the order\\\", \\\"example\\\": \\\"ORD-7721\\\" },\\n          \\\"tracking\\\": { \\\"$ref\\\": \\\"#/components/schemas/TrackingInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"order_id\": \"ORD-9902\",\n        \"tracking\": {\n          \"status\": \"delivered\",\n          \"estimated_delivery\": \"2023-10-20T09:30:00Z\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Order Status API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {