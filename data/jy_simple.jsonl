n\\\": \\\"Specific auth issue\\\", \\\"example\\\": \\\"Token expired\\\" } }\\n        }\\n      },\\n      \\\"AuthError\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Authentication error code\\\", \\\"example\\\": \\\"AUTH_FAILURE\\\" },\\n          \\\"details\\\": { \\\"$ref\\\": \\\"#/components/schemas/MessageContainer\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"error_code\": \"DATABASE_TIMEOUT\",\n        \"details\": {\n          \"messages\": [\n            \"Connection pool exhausted\",\n            \"Query execution exceeded limit\"\n          ]\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Database Error Response\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorList\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"messages\\\": { \\\"type\\\": \\\"array\\\", \\\"description\\\": \\\"Database error messages\\\", \\\"items\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Error detail\\\", \\\"example\\\": \\\"Connection pool exhausted\\\" } }\\n        }\\n      },\\n      \\\"DatabaseError\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Database error code\\\", \\\"example\\\": \\\"DATABASE_TIMEOUT\\\" },\\n          \\\"details\\\": { \\\"$ref\\\": \\\"#/components/schemas/ErrorList\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_987\",\n        \"comment_data\": {\n          \"author_name\": \"João Silva\",\n          \"text\": \"Excelente artigo, muito esclarecedor!\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentContent:\\n      type: object\\n      description: 'Conteúdo detalhado do comentário e informações do autor'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'Nome do autor que realizou o comentário'\\n          example: 'João Silva'\\n        text:\\n          type: string\\n          description: 'O texto do comentário enviado pelo usuário'\\n          example: 'Excelente artigo, muito esclarecedor!'\\n    CommentSubmission:\\n      type: object\\n      description: 'Objeto principal de submissão de comentário'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Identificador único da postagem do blog'\\n          example: 'post_987'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentContent'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_456\",\n        \"comment_data\": {\n          \"author_name\": \"Maria Oliveira\",\n          \"text\": \"Gostaria de saber mais sobre este tópico.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentContent:\\n      type: object\\n      description: 'Dados do autor e o corpo da mensagem'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'Nome completo do autor'\\n          example: 'Maria Oliveira'\\n        text:\\n          type: string\\n          description: 'Conteúdo textual do comentário'\\n          example: 'Gostaria de saber mais sobre este tópico.'\\n    CommentSubmission:\\n      type: object\\n      description: 'Estrutura de envio de comentário para um post'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'ID da postagem alvo'\\n          example: 'post_456'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentContent'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_101\",\n        \"comment_data\": {\n          \"author_name\": \"Carlos Souza\",\n          \"text\": \"Concordo plenamente com os pontos levantados.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentContent:\\n      type: object\\n      description: 'Informações do autor e o comentário'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'Nome do autor do comentário'\\n          example: 'Carlos Souza'\\n        text:\\n          type: string\\n          description: 'Texto do comentário'\\n          example: 'Concordo plenamente com os pontos levantados.'\\n    CommentSubmission:\\n      type: object\\n      description: 'Payload de submissão de comentário'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Identificador da postagem'\\n          example: 'post_101'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentContent'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"order_id\": \"ORD-99281\",\n        \"tracking\": {\n          \"status\": \"IN_TRANSIT\",\n          \"estimated_delivery\": \"2023-12-25\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Order Status API\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"OrderStatus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"order_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Identificador único do pedido\\\", \\\"example\\\": \\\"ORD-99281\\\" },\\n          \\\"tracking\\\": { \\\"$ref\\\": \\\"#/components/schemas/TrackingInfo\\\" }\\n        }\\n      },\\n      \\\"TrackingInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Status atual do envio\\\", \\\"example\\\": \\\"IN_TRANSIT\\\" },\\n          \\\"estimated_delivery\\\": { \\\"type\\\": \\\"string\\\", \\\"format\\\": \\\"date\\\", \\\"description\\\": \\\"Data prevista para entrega\\\", \\\"example\\\": \\\"2023-12-25\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"order_id\": \"ORD-44502\",\n        \"tracking\": {\n          \"status\": \"DELIVERED\",\n          \"estimated_delivery\": \"2023-11-10\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Order Status API\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"OrderStatus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"order_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Código de identificação do pedido\\\", \\\"example\\\": \\\"ORD-44502\\\" }