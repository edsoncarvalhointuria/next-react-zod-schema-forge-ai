ermits marketing communications\\\",\\n            \\\"example\\\": false\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"subscriber_email\": \"hello@world.com\",\n        \"is_subscribed\": true\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Newsletter Enrollment API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"NewsletterEnrollment\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Payload for enrolling a user in a newsletter\\\",\\n        \\\"properties\\\": {\\n          \\\"subscriber_email\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"The email address used for the subscription\\\",\\n            \\\"example\\\": \\\"hello@world.com\\\"\\n          },\\n          \\\"is_subscribed\\\": {\\n            \\\"type\\\": \\\"boolean\\\",\\n            \\\"description\\\": \\\"The current subscription status flag\\\",\\n            \\\"example\\\": true\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
