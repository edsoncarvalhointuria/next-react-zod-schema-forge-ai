w_json\": {\n        \"city\": \"New York\",\n        \"weather\": {\n          \"temperature\": 18,\n          \"humidity\": 45\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherData:\\n      type: object\\n      description: 'Current meteorological readings'\\n      properties:\\n        temperature:\\n          type: integer\\n          description: 'Temperature in Celsius'\\n          example: 18\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 45\\n    WeatherResponse:\\n      type: object\\n      description: 'Weather widget data for a specific location'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'New York'\\n        weather:\\n          $ref: '#/components/schemas/WeatherData'\"\n    }\n  ]\n}"
