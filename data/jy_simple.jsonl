"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"flight_id\": \"FL-9921\",\n        \"available_classes\": [\n          \"Economy\",\n          \"Business\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'A basic flight search result containing ID and seat classes'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Unique identifier for the flight'\\n          example: 'FL-9921'\\n        available_classes:\\n          type: array\\n          description: 'List of available seat classes for this flight'\\n          items:\\n            type: string\\n            example: 'Economy'\"\n    },\n    {\n      \"raw_json\": {\n        \"flight_id\": \"AA-440\",\n        \"available_classes\": [\n          \"Economy\",\n          \"Premium Economy\",\n          \"First\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'A basic flight search result containing ID and seat classes'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Unique identifier for the flight'\\n          example: 'AA-440'\\n        available_classes:\\n          type: array\\n          description: 'List of available seat classes for this flight'\\n          items:\\n            type: string\\n            example: 'First'\"\n    },\n    {\n      \"raw_json\": {\n        \"flight_id\": \"BA-102\",\n        \"available_classes\": [\n          \"Economy\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'A basic flight search result containing ID and seat classes'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Unique identifier for the flight'\\n          example: 'BA-102'\\n        available_classes:\\n          type: array\\n          description: 'List of available seat classes for this flight'\\n          items:\\n            type: string\\n            example: 'Economy'\"\n    }\n  ]\n}"
