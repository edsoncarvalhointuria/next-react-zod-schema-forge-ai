"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"city\": \"London\",\n        \"weather\": {\n          \"temperature\": 15,\n          \"humidity\": 82\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherDetails:\\n      type: object\\n      description: 'Current atmospheric conditions'\\n      properties:\\n        temperature:\\n          type: integer\\n          description: 'Temperature in Celsius'\\n          example: 15\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 82\\n    WeatherResponse:\\n      type: object\\n      description: 'Weather data for a specific location'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'London'\\n        weather:\\n          $ref: '#/components/schemas/WeatherDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"Tokyo\",\n        \"weather\": {\n          \"temperature\": 22,\n          \"humidity\": 60\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherDetails:\\n      type: object\\n      description: 'Current atmospheric conditions'\\n      properties:\\n        temperature:\\n          type: integer\\n          description: 'Temperature in Celsius'\\n          example: 22\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 60\\n    WeatherResponse:\\n      type: object\\n      description: 'Weather data for a specific location'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'Tokyo'\\n        weather:\\n          $ref: '#/components/schemas/WeatherDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"New York\",\n        \"weather\": {\n          \"temperature\": 18,\n          \"humidity\": 45\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherDetails:\\n      type: object\\n      description: 'Current atmospheric conditions'\\n      properties:\\n        temperature:\\n          type: integer\\n          description: 'Temperature in Celsius'\\n          example: 18\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 45\\n    WeatherResponse:\\n      type: object\\n      description: 'Weather data for a specific location'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'New York'\\n        weather:\\n          $ref: '#/components/schemas/WeatherDetails'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"code\": \"ERR_400\",\n        \"details\": {\n          \"messages\": [\n            \"Field 'username' is required\",\n            \"Field 'email' is invalid\"\n          ]\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Error Response\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorDetail\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"messages\\\": { \\\"type\\\": \\\"array\\\", \\\"description\\\": \\\"List of error messages\\\", \\\"items\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Error message text\\\", \\\"example\\\": \\\"Field 'username' is required\\\" } }\\n        }\\n      },\\n      \\\"ErrorResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"code\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Unique error code\\\", \\\"example\\\": \\\"ERR_400\\\" },\\n          \\\"details\\\": { \\\"$ref\\\": \\\"#/components/schemas/ErrorDetail\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"error_code\": \"AUTH_FAILURE\",\n        \"error_data\": {\n          \"reasons\": [\n            \"Token expired\",\n            \"Invalid signature\"\n          ]\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Auth Error Response\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ReasonList\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"reasons\\\": { \\\"type\\\": \\\"array\\\", \\\"description\\\": \\\"List of failure reasons\\\", \\\"items\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Reason description\\\", \\\"example\\\": \\\"Token expired\\\" } }\\n        }\\n      },\\n      \\\"AuthError\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Authentication error identifier\\\", \\\"example\\\": \\\"AUTH_FAILURE\\\" },\\n          \\\"error_data\\\": { \\\"$ref\\\": \\\"#/components/schemas/ReasonList\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"status\": \"INTERNAL_SERVER_ERROR\",\n        \"payload\": {\n          \"errors\": [\n            \"Database connection timeout\",\n            \"Retry limit exceeded\"\n          ]\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"System Error Response\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorContainer\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"errors\\\": { \\\"type\\\": \\\"array\\\", \\\"description\\\": \\\"List of system errors\\\", \\\"items\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Error detail\\\", \\\"example\\\": \\\"Database connection timeout\\\" } }\\n        }\\n      },\\n      \\\"SystemError\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Status code string\\\", \\\"example\\\": \\\"INTERNAL_SERVER_ERROR\\\" },\\n          \\\"payload\\\": { \\\"$ref\\\": \\\"#/components/schemas/ErrorContainer\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_123\",\n        \"comment_data\": {\n          \"author_name\": \"Alice Smith\",\n          \"text\": \"Great article, very insightful!\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentContent:\\n      type: object\\n      description: 'The content and author details of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The name of the person posting the comment'\\n          example: 'Alice Smith'\\n        text:\\n          type: string\\n          description: 'The body text of the comment'\\n          example: 'Great article, very insightful!'\\n    CommentSubmission:\\n      type: object\\n      description: 'Root object for comment submission'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_123'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentContent'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_998\",\n        \"comment_data\": {\n          \"author_name\": \"Bob Johnson\",\n          \"text\": \"I disagree with the second point.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentContent:\\n      type: object\\n      description: 'The content and author details of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The name of the person posting the comment'\\n          example: 'Bob Johnson'\\n        text:\\n          type: string\\n          description: 'The body text of the comment'\\n          example: 'I disagree with the second point.'\\n    CommentSubmission:\\n      type: object\\n      description: 'Root object for comment submission'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_998'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentContent'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_456\",\n        \"comment_data\": {\n          \"author_name\": \"Charlie Brown\",\n          \"text\": \"Thanks for sharing this information.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentContent:\\n      type: object\\n      description: 'The content and author details of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The name of the person posting the comment'\\n          example: 'Charlie Brown'\\n        text:\\n          type: string\\n          description: 'The body text of the comment'\\n          example: 'Thanks for sharing this information.'\\n    CommentSubmission:\\n      type: object\\n      description: 'Root object for comment submission'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_456'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentContent'\"\n    }\n  ]\n}"
