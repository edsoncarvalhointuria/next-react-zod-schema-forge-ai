"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"flight_id\": \"FL-9921\",\n        \"available_classes\": [\"Economy\", \"Business\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'A basic flight search result containing ID and seat classes'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Unique identifier for the flight'\\n          example: 'FL-9921'\\n        available_classes:\\n          type: array\\n          description: 'List of available seat classes'\\n          items:\\n            type: string\\n          example: ['Economy', 'Business']\"\n    },\n    {\n      \"raw_json\": {\n        \"flight_id\": \"AA-4402\",\n        \"available_classes\": [\"Economy\", \"Premium Economy\", \"First\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'A basic flight search result containing ID and seat classes'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Unique identifier for the flight'\\n          example: 'AA-4402'\\n        available_classes:\\n          type: array\\n          description: 'List of available seat classes'\\n          items:\\n            type: string\\n          example: ['Economy', 'Premium Economy', 'First']\"\n    },\n    {\n      \"raw_json\": {\n        \"flight_id\": \"BA-109\",\n        \"available_classes\": [\"Economy\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'A basic flight search result containing ID and seat classes'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Unique identifier for the flight'\\n          example: 'BA-109'\\n        available_classes:\\n          type: array\\n          description: 'List of available seat classes'\\n          items:\\n            type: string\\n          example: ['Economy']\"\n    }\n  ]\n}"
