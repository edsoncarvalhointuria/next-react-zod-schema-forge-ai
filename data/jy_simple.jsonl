"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"city\": \"São Paulo\",\n        \"weather\": {\n          \"temperature\": 22,\n          \"humidity\": 65\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherData:\\n      type: object\\n      description: 'Dados detalhados de clima'\\n      properties:\\n        temperature:\\n          type: integer\\n          description: 'Temperatura atual em graus Celsius'\\n          example: 22\\n        humidity:\\n          type: integer\\n          description: 'Porcentagem de umidade relativa do ar'\\n          example: 65\\n    WeatherResponse:\\n      type: object\\n      description: 'Resposta do widget de clima'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Nome da cidade consultada'\\n          example: 'São Paulo'\\n        weather:\\n          $ref: '#/components/schemas/WeatherData'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"Rio de Janeiro\",\n        \"weather\": {\n          \"temperature\": 30,\n          \"humidity\": 80\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherData:\\n      type: object\\n      description: 'Dados detalhados de clima'\\n      properties:\\n        temperature:\\n          type: integer\\n          description: 'Temperatura atual em graus Celsius'\\n          example: 30\\n        humidity:\\n          type: integer\\n          description: 'Porcentagem de umidade relativa do ar'\\n          example: 80\\n    WeatherResponse:\\n      type: object\\n      description: 'Resposta do widget de clima'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Nome da cidade consultada'\\n          example: 'Rio de Janeiro'\\n        weather:\\n          $ref: '#/components/schemas/WeatherData'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"Curitiba\",\n        \"weather\": {\n          \"temperature\": 12,\n          \"humidity\": 90\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherData:\\n      type: object\\n      description: 'Dados detalhados de clima'\\n      properties:\\n        temperature:\\n          type: integer\\n          description: 'Temperatura atual em graus Celsius'\\n          example: 12\\n        humidity:\\n          type: integer\\n          description: 'Porcentagem de umidade relativa do ar'\\n          example: 90\\n    WeatherResponse:\\n      type: object\\n      description: 'Resposta do widget de clima'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Nome da cidade consultada'\\n          example: 'Curitiba'\\n        weather:\\n          $ref: '#/components/schemas/WeatherData'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"error_code\": \"ERR_VALIDATION_FAILED\",\n        \"messages\": [\n          \"O campo email é obrigatório.\",\n          \"O formato da senha é inválido.\"\n        ]\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Error Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Código identificador do erro ocorrido\\\",\\n            \\\"example\\\": \\\"ERR_VALIDATION_FAILED\\\"\\n          },\\n          \\\"messages\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de mensagens detalhando os erros\\\",\\n            \\\"items\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"Mensagem individual de erro\\\",\\n              \\\"example\\\": \\\"O campo email é obrigatório.\\\"\\n            }\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"error_code\": \"ERR_AUTH_DENIED\",\n        \"messages\": [\n          \"Token de acesso expirado.\",\n          \"Sessão encerrada pelo servidor.\"\n        ]\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Error Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Código identificador do erro ocorrido\\\",\\n            \\\"example