"Specific auth issue\\\", \\\"example\\\": \\\"Token expired\\\" } }\\n        }\\n      },\\n      \\\"AuthError\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Authentication error code\\\", \\\"example\\\": \\\"AUTH_FAILURE\\\" },\\n          \\\"details\\\": { \\\"$ref\\\": \\\"#/components/schemas/MessageContainer\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"error_code\": \"DB_TIMEOUT\",\n        \"details\": {\n          \"messages\": [\n            \"Connection pool exhausted\",\n            \"Query execution exceeded limit\"\n          ]\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Database Error Response\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorList\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"messages\\\": { \\\"type\\\": \\\"array\\\", \\\"description\\\": \\\"Database error messages\\\", \\\"items\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Error detail\\\", \\\"example\\\": \\\"Connection pool exhausted\\\" } }\\n        }\\n      },\\n      \\\"DatabaseError\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Database error code\\\", \\\"example\\\": \\\"DB_TIMEOUT\\\" },\\n          \\\"details\\\": { \\\"$ref\\\": \\\"#/components/schemas/ErrorList\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_123\",\n        \"comment_data\": {\n          \"author\": \"João Silva\",\n          \"text\": \"Excelente artigo, muito esclarecedor!\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentContent:\\n      type: object\\n      description: 'Conteúdo detalhado do comentário'\\n      properties:\\n        author:\\n          type: string\\n          description: 'Nome do autor do comentário'\\n          example: 'João Silva'\\n        text:\\n          type: string\\n          description: 'O texto do comentário enviado'\\n          example: 'Excelente artigo, muito esclarecedor!'\\n    CommentSubmission:\\n      type: object\\n      description: 'Payload para submissão de comentário em um post'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Identificador único do post'\\n          example: 'post_123'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentContent'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_456\",\n        \"comment_data\": {\n          \"author\": \"Maria Oliveira\",\n          \"text\": \"Poderia detalhar mais sobre a seção de segurança?\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentContent:\\n      type: object\\n      description: 'Conteúdo detalhado do comentário'\\n      properties:\\n        author:\\n          type: string\\n          description: 'Nome do autor do comentário'\\n          example: 'Maria Oliveira'\\n        text:\\n          type: string\\n          description: 'O texto do comentário enviado'\\n          example: 'Poderia detalhar mais sobre a seção de segurança?'\\n    CommentSubmission:\\n      type: object\\n      description: 'Payload para submissão de comentário em um post'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Identificador único do post'\\n          example: 'post_456'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentContent'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_789\",\n        \"comment_data\": {\n          \"author\": \"Carlos Souza\",\n          \"text\": \"Concordo plenamente com os pontos levantados.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentContent:\\n      type: object\\n      description: 'Conteúdo detalhado do comentário'\\n      properties:\\n        author:\\n          type: string\\n          description: 'Nome do autor do comentário'\\n          example: 'Carlos Souza'\\n        text:\\n          type: string\\n          description: 'O texto do comentário enviado'\\n          example: 'Concordo plenamente com os pontos levantados.'\\n    CommentSubmission:\\n      type: object\\n      description: 'Payload para submissão de comentário em um post'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Identificador único do post'\\n          example: 'post_789'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentContent'\"\n    }\n  ]\n}"
