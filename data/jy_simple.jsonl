 of the order\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Current shipping status\\\",\\n            \\\"example\\\": \\\"pending\\\"\\n          },\\n          \\\"estimated_delivery\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Expected arrival timestamp\\\",\\n            \\\"example\\\": \\\"2023-12-01T18:00:00Z\\\"\\n          }\\n        }\\n      },\\n      \\\"OrderStatus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Root object for order status response\\\",\\n        \\\"properties\\\": {\\n          \\\"order_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the order\\\",\\n            \\\"example\\\": \\\"ORD-1145\\\"\\n          },\\n          \\\"tracking\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/TrackingDetails\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_9921\",\n        \"preferences\": {\n          \"theme\": \"dark\",\n          \"language\": \"en-US\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Settings Fetch\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Preferences:\\n      type: object\\n      description: 'User interface and localization settings'\\n      properties:\\n        theme:\\n          type: string\\n          description: 'The visual theme mode'\\n          example: 'dark'\\n        language:\\n          type: string\\n          description: 'The locale code for the user interface'\\n          example: 'en-US'\\n    UserSettings:\\n      type: object\\n      description: 'Root object for user settings'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'usr_9921'\\n        preferences:\\n          $ref: '#/components/schemas/Preferences'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_4402\",\n        \"preferences\": {\n          \"theme\": \"light\",\n          \"language\": \"fr-FR\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Settings Fetch\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Preferences:\\n      type: object\\n      description: 'User interface and localization settings'\\n      properties:\\n        theme:\\n          type: string\\n          description: 'The visual theme mode'\\n          example: 'light'\\n        language:\\n          type: string\\n          description: 'The locale code for the user interface'\\n          example: 'fr-FR'\\n    UserSettings:\\n      type: object\\n      description: 'Root object for user settings'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'usr_4402'\\n        preferences:\\n          $ref: '#/components/schemas/Preferences'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_id\": \"usr_1185\",\n        \"preferences\": {\n          \"theme\": \"system\",\n          \"language\": \"ja-JP\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: User Settings Fetch\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    Preferences:\\n      type: object\\n      description: 'User interface and localization settings'\\n      properties:\\n        theme:\\n          type: string\\n          description: 'The visual theme mode'\\n          example: 'system'\\n        language:\\n          type: string\\n          description: 'The locale code for the user interface'\\n          example: 'ja-JP'\\n    UserSettings:\\n      type: object\\n      description: 'Root object for user settings'\\n      properties:\\n        user_id:\\n          type: string\\n          description: 'Unique identifier for the user'\\n          example: 'usr_1185'\\n        preferences:\\n          $ref: '#/components/schemas/Preferences'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"deviceId\": \"dev-99821\",\n        \"software\": {\n          \"osVersion\": \"14.2.1\",\n          \"appVersion\": \"2.5.0\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Device Registration\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SoftwareInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Informações sobre a versão do sistema operacional e do aplicativo\\\",\\n        \\\"properties\\\": {\\n          \\\"osVersion\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Versão do sistema operacional instalado\\\", \\\"example\\\": \\\"14.2.1\\\" },\\n          \\\"appVersion\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Versão atual do aplicativo\\\", \\\"example\\\": \\\"2.5.0\\\" }\\n        }\\n      },\\n      \\\"DeviceRegistration\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Payload de registro de dispositivo\\\",\\n        \\\"properties\\\": {\\n          \\\"deviceId\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Identificador único do dispositivo\\\", \\\"example\\\": \\\"dev-99821\\\" },\\n          \\\"software\\\": { \\\"$ref\\\": \\\"#/components/schemas/SoftwareInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"deviceId\": \"mobile-x-77\",\n        \"software\": {\n          \"osVersion\": \"Android 13\",\n          \"appVersion\": \"1.0.4-beta\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Device Registration\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SoftwareInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Detalhes da versão de software do dispositivo\\\",\\n        \\\"properties\\\": {\\n          \\\"osVersion\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Versão do sistema operacional\\\", \\\"example\\\": \\\"Android 13\\\" },\\n          \\\"appVersion\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Versão do aplicativo em execução\\\", \\\"example\\\": \\\"1.0.4-beta\\\" }\\n        }\\n      },\\n      \\\"DeviceRegistration\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Objeto de registro contendo ID e dados de software\\\",\\n        \\\"properties\\\": {\\n          \\\"deviceId\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"ID único do hardware\\\", \\\"example\\\": \\\"mobile-x-77\\\" },\\n          \\\"software\\\": { \\\"$ref\\\": \\\"#/components/schemas/SoftwareInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"deviceId\": \"iot-sensor-001\",\n        \"software\": {\n          \"osVersion\": \"RTOS-v4\",\n          \"appVersion\": \"3.1.0\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Device Registration\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SoftwareInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Configurações de versão do firmware e software\\\",\\n        \\\"properties\\\": {\\n          \\\"osVersion\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Versão do sistema operacional embarcado\\\", \\\"example\\\": \\\"RTOS-v4\\\" },\\n          \\\"appVersion\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Versão da aplicação de controle\\\", \\\"example\\\": \\\"3.1.0\\\" }\\n        }\\n      },\\n      \\\"DeviceRegistration\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Estrutura de registro para dispositivos IoT\\\",\\n        \\\"properties\\\": {\\n          \\\"deviceId\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Identificador do sensor\\\", \\\"example\\\": \\\"iot-sensor-001\\\" },\\n          \\\"software\\\": { \\\"$ref\\\": \\\"#/components/schemas/SoftwareInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"flight_id\": \"FL-9921\",\n        \"available_classes\": [\n          \"Economy\",\n          \"Business\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'A basic flight search result'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Unique identifier for the flight'\\n          example: 'FL-9921'\\n        available_classes:\\n          type: array\\n          description: 'List of available seat classes'\\n          items:\\n            type: string\\n          example: ['Economy', 'Business']\"\n    },\n    {\n      \"raw_json\": {\n        \"flight_id\": \"AA-4402\",\n        \"available_classes\": [\n          \"Economy\",\n          \"Premium Economy\",\n          \"First\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'A basic flight search result'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Unique identifier for the flight'\\n          example: 'AA-4402'\\n        available_classes:\\n          type: array\\n          description: 'List of available seat classes'\\n          items:\\n            type: string\\n          example: ['Economy', 'Premium Economy', 'First']\"\n    },\n    {\n      \"raw_json\": {\n        \"flight_id\": \"BA-109\",\n        \"available_classes\": [\n          \"Economy\"\n        ]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'A basic flight search result'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Unique identifier for the flight'\\n          example: 'BA-109'\\n        available_classes:\\n          type: array\\n          description: 'List of available seat classes'\\n          items:\\n            type: string\\n          example: ['Economy']\"\n    }\n  ]\n}"
