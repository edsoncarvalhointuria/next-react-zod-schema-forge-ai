"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"email\": \"user@example.com\",\n        \"reset_code\": \"123456\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Password Reset API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PasswordResetResponse:\\n      type: object\\n      description: Response containing the reset code for a user.\\n      properties:\\n        email:\\n          type: string\\n          description: The email address of the user requesting the reset.\\n          example: user@example.com\\n        reset_code:\\n          type: string\\n          description: The temporary numeric code used to verify the reset request.\\n          example: '123456'\"\n    },\n    {\n      \"raw_json\": {\n        \"user_email\": \"admin@corp.com\",\n        \"verification_token\": \"abc-123-def\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Account Recovery API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ResetTokenResponse:\\n      type: object\\n      description: Response containing the verification token for account recovery.\\n      properties:\\n        user_email:\\n          type: string\\n          description: The registered email address of the account owner.\\n          example: admin@corp.com\\n        verification_token:\\n          type: string\\n          description: A unique alphanumeric token for password reset verification.\\n          example: abc-123-def\"\n    },\n    {\n      \"raw_json\": {\n        \"email_address\": \"test@mail.org\",\n        \"code\": \"987654\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Security Code API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    PasswordCodeResponse:\\n      type: object\\n      description: Response containing the security code for password change.\\n      properties:\\n        email_address:\\n          type: string\\n          description: The email address associated with the reset request.\\n          example: test@mail.org\\n        code:\\n          type: string\\n          description: The short-lived security code for authentication.\\n          example: '987654'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"message\": \"Limite de requisições excedido. Por favor, aguarde antes de tentar novamente.\",\n        \"retry_after\": 60\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"API de Controle de Taxa\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"RateLimitResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta de aviso de limite de taxa de requisições\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Mensagem detalhando o motivo do bloqueio temporário\\\",\\n            \\\"example\\\": \\\"Limite de requisições excedido. Por favor, aguarde antes de tentar novamente.\\\"\\n          },\\n          \\\"retry_after\\\": {\\n            \\\"type\\\": \\\"integer\\\",\\n            \\\"description\\\": \\\"Tempo de espera necessário em segundos antes de realizar uma nova requisição\\\",\\n            \\\"example\\\": 60\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"message\": \"Cota diária de API atingida. O acesso será restaurado em 24 horas.\",\n        \"retry_after\": 86400\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"API de Controle de Taxa\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"RateLimitResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Resposta de aviso de limite de taxa de requisições\\\",\\n        \\\"properties\\\": {\\n          \\\"message\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Mensagem detalhando o motivo do bloqueio tempo