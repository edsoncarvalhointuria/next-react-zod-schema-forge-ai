"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"city\": \"London\",\n        \"weather\": {\n          \"temperature\": 15.5,\n          \"humidity\": 72\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherMetrics:\\n      type: object\\n      description: 'Current atmospheric conditions'\\n      properties:\\n        temperature:\\n          type: number\\n          format: float\\n          description: 'Temperature in Celsius'\\n          example: 15.5\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 72\\n    WeatherResponse:\\n      type: object\\n      description: 'Root weather widget response'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'London'\\n        weather:\\n          $ref: '#/components/schemas/WeatherMetrics'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"Tokyo\",\n        \"weather\": {\n          \"temperature\": 22.0,\n          \"humidity\": 55\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherMetrics:\\n      type: object\\n      description: 'Current atmospheric conditions'\\n      properties:\\n        temperature:\\n          type: number\\n          format: float\\n          description: 'Temperature in Celsius'\\n          example: 22.0\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 55\\n    WeatherResponse:\\n      type: object\\n      description: 'Root weather widget response'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'Tokyo'\\n        weather:\\n          $ref: '#/components/schemas/WeatherMetrics'\"\n    },\n    {\n      \"raw_json\": {\n        \"city\": \"New York\",\n        \"weather\": {\n          \"temperature\": 8.2,\n          \"humidity\": 40\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Weather Widget API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    WeatherMetrics:\\n      type: object\\n      description: 'Current atmospheric conditions'\\n      properties:\\n        temperature:\\n          type: number\\n          format: float\\n          description: 'Temperature in Celsius'\\n          example: 8.2\\n        humidity:\\n          type: integer\\n          description: 'Relative humidity percentage'\\n          example: 40\\n    WeatherResponse:\\n      type: object\\n      description: 'Root weather widget response'\\n      properties:\\n        city:\\n          type: string\\n          description: 'Name of the city'\\n          example: 'New York'\\n        weather:\\n          $ref: '#/components/schemas/WeatherMetrics'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"error_code\": \"ERR_400\",\n        \"messages\": [\n          \"O campo email é obrigatório\",\n          \"O formato do telefone está inválido\"\n        ]\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Error Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Código identificador do erro ocorrido\\\",\\n            \\\"example\\\": \\\"ERR_400\\\"\\n          },\\n          \\\"messages\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de mensagens detalhando os erros encontrados\\\",\\n            \\\"items\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"Descrição individual do erro\\\",\\n              \\\"example\\\": \\\"O campo email é obrigatório\\\"\\n            }\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"error_code\": \"AUTH_FAILED\",\n        \"messages\": [\n          \"Token expirado\",\n          \"Sessão encerrada pelo servidor\"\n        ]\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Auth Error Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Código de erro específico de autenticação\\\",\\n            \\\"example\\\": \\\"AUTH_FAILED\\\"\\n          },\\n          \\\"messages\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de mensagens explicativas sobre a falha de acesso\\\",\\n            \\\"items\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"Detalhe da falha de segurança\\\",\\n              \\\"example\\\": \\\"Token expirado\\\"\\n            }\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"error_code\": \"DB_TIMEOUT\",\n        \"messages\": [\n          \"A conexão com o banco de dados falhou\",\n          \"Tente novamente em alguns minutos\"\n        ]\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"System Error Response\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Código de erro interno do sistema\\\",\\n            \\\"example\\\": \\\"DB_TIMEOUT\\\"\\n          },\\n          \\\"messages\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"Lista de mensagens de erro do sistema\\\",\\n            \\\"items\\\": {\\n              \\\"type\\\": \\\"string\\\",\\n              \\\"description\\\": \\\"Mensagem de erro técnico\\\",\\n              \\\"example\\\": \\\"A conexão com o banco de dados falhou\\\"\\n            }\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_9921\",\n        \"comment_data\": {\n          \"author_name\": \"Alice Johnson\",\n          \"content\": \"This is a very insightful article!\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'The author and text content of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The name of the person posting the comment'\\n          example: 'Alice Johnson'\\n        content:\\n          type: string\\n          description: 'The body text of the comment'\\n          example: 'This is a very insightful article!'\\n    CommentSubmission:\\n      type: object\\n      description: 'Payload for submitting a new comment to a blog post'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_9921'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_4402\",\n        \"comment_data\": {\n          \"author_name\": \"Bob Smith\",\n          \"content\": \"I disagree with the third point mentioned.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'The author and text content of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The name of the person posting the comment'\\n          example: 'Bob Smith'\\n        content:\\n          type: string\\n          description: 'The body text of the comment'\\n          example: 'I disagree with the third point mentioned.'\\n    CommentSubmission:\\n      type: object\\n      description: 'Payload for submitting a new comment to a blog post'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_4402'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_1055\",\n        \"comment_data\": {\n          \"author_name\": \"Charlie Davis\",\n          \"content\": \"Thanks for sharing this guide.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'The author and text content of the comment'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'The name of the person posting the comment'\\n          example: 'Charlie Davis'\\n        content:\\n          type: string\\n          description: 'The body text of the comment'\\n          example: 'Thanks for sharing this guide.'\\n    CommentSubmission:\\n      type: object\\n      description: 'Payload for submitting a new comment to a blog post'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_1055'\\n        comment_data:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"order_id\": \"ORD-7721\",\n        \"tracking\": {\n          \"status\": \"in_transit\",\n          \"estimated_delivery\": \"2023-11-15T14:00:00Z\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": {\\n    \\\"title\\\": \\\"Order Status API\\\",\\n    \\\"version\\\": \\\"1.0.0\\\"\\n  },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TrackingDetails\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Current logistics status of the order\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Current shipping status\\\",\\n            \\\"example\\\": \\\"in_transit\\\"\\n          },\\n          \\\"estimated_delivery\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"format\\\": \\\"date-time\\\",\\n            \\\"description\\\": \\\"Expected arrival timestamp\\\",\\n            \\\"example\\\": \\\"2023-11-15T14:00:00Z\\\"\\n          }\\n        }\\n      },\\n      \\\"OrderStatus\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Root object for order status response\\\",\\n        \\\"properties\\\": {\\n          \\\"order_id\\\": {\\n            \\\"type\\\": \\\"string\\\",\\n            \\\"description\\\": \\\"Unique identifier for the order\\\",\\n            \\\"example\\\": \\\"ORD-7721\\\"\\n          },\\n          \\\"tracking\\\": {\\n            \\\"$ref\\\": \\\"#/components/schemas/TrackingDetails\\\"\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"order_id\": \"ORD-9902\",\n        \"tracking\": {\n          \"status\": \"delivered\",\n          \"estimated_delivery\": \"2023-10-20T09:30:00Z\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\