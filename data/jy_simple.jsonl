"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"Operação realizada com sucesso\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Success Response API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    SuccessResponse:\\n      type: object\\n      properties:\\n        success:\\n          type: boolean\\n          description: Indica se a operação foi concluída com sucesso.\\n          example: true\\n        message:\\n          type: string\\n          description: Mensagem descritiva sobre o resultado da operação.\\n          example: Operação realizada com sucesso\"\n    },\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"O registro foi criado corretamente\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Generic Response API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    GenericResponse:\\n      type: object\\n      properties:\\n        success:\\n          type: boolean\\n          description: Flag booleana indicando o êxito da requisição.\\n          example: true\\n        message:\\n          type: string\\n          description: Texto informativo retornado pelo servidor.\\n          example: O registro foi criado corretamente\"\n    },\n    {\n      \"raw_json\": {\n        \"success\": true,\n        \"message\": \"OK\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: API Response Status\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    ApiResponse:\\n      type: object\\n      properties:\\n        success:\\n          type: boolean\\n          description: Status de sucesso da transação.\\n          example: true\\n        message:\\n          type: string\\n          description: Mensagem curta de confirmação.\\n          example: OK\"\n    }\n  ]\n}"
