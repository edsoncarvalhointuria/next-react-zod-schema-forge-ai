regarding the device software environment\\\",\\n        \\\"properties\\\": {\\n          \\\"os_version\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"The operating system version\\\", \\\"example\\\": \\\"Android 13\\\" },\\n          \\\"app_version\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"The current application version\\\", \\\"example\\\": \\\"5.0.2-beta\\\" }\\n        }\\n      },\\n      \\\"DeviceRegistration\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Payload for registering a new device\\\",\\n        \\\"properties\\\": {\\n          \\\"device_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Unique identifier for the device\\\", \\\"example\\\": \\\"mobile-prod-001\\\" },\\n          \\\"software\\\": { \\\"$ref\\\": \\\"#/components/schemas/SoftwareInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"device_id\": \"iot-sensor-99\",\n        \"software\": {\n          \"os_version\": \"RTOS-v4\",\n          \"app_version\": \"1.0.0\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Device Registration\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"SoftwareInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Details regarding the device software environment\\\",\\n        \\\"properties\\\": {\\n          \\\"os_version\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"The operating system version\\\", \\\"example\\\": \\\"RTOS-v4\\\" },\\n          \\\"app_version\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"The current application version\\\", \\\"example\\\": \\\"1.0.0\\\" }\\n        }\\n      },\\n      \\\"DeviceRegistration\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"Payload for registering a new device\\\",\\n        \\\"properties\\\": {\\n          \\\"device_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Unique identifier for the device\\\", \\\"example\\\": \\\"iot-sensor-99\\\" },\\n          \\\"software\\\": { \\\"$ref\\\": \\\"#/components/schemas/SoftwareInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"flight_id\": \"FL-9921\",\n        \"available_classes\": [\"Economy\", \"Business\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'A basic flight search result containing ID and seat classes'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Unique identifier for the flight'\\n          example: 'FL-9921'\\n        available_classes:\\n          type: array\\n          description: 'List of available seat classes for this flight'\\n          items:\\n            type: string\\n            example: 'Economy'\"\n    },\n    {\n      \"raw_json\": {\n        \"flight_id\": \"AA-440\",\n        \"available_classes\": [\"Economy\", \"Premium Economy\", \"First\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'A basic flight search result containing ID and seat classes'\\n      properties:\\n        flight_id:\\n          type: string\\n          description: 'Unique identifier for the flight'\\n          example: 'AA-440'\\n        available_classes:\\n          type: array\\n          description: 'List of available seat classes for this flight'\\n          items:\\n            type: string\\n            example: 'Premium Economy'\"\n    },\n    {\n      \"raw_json\": {\n        \"flight_id\": \"BA-102\",\n        \"available_classes\": [\"Economy\"]\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Flight Search Result\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    FlightSearchResult:\\n      type: object\\n      description: 'A basic flight search result containing ID and seat classes'\\n      properties:\\n        flight_id:\\n    