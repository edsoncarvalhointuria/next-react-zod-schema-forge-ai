"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_8821\",\n        \"comment_details\": {\n          \"author_name\": \"João Silva\",\n          \"content\": \"Excelente artigo, muito esclarecedor!\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'Detalhes do autor e o conteúdo do comentário'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'Nome do autor do comentário'\\n          example: 'João Silva'\\n        content:\\n          type: string\\n          description: 'Texto do comentário enviado'\\n          example: 'Excelente artigo, muito esclarecedor!'\\n    CommentSubmission:\\n      type: object\\n      description: 'Estrutura de envio de comentário para um post'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Identificador único do post'\\n          example: 'post_8821'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_4492\",\n        \"comment_details\": {\n          \"author_name\": \"Maria Oliveira\",\n          \"content\": \"Poderia detalhar mais sobre a seção de segurança?\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'Informações sobre o autor e o corpo do comentário'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'Nome completo do autor'\\n          example: 'Maria Oliveira'\\n        content:\\n          type: string\\n          description: 'O texto principal do comentário'\\n          example: 'Poderia detalhar mais sobre a seção de segurança?'\\n    CommentSubmission:\\n      type: object\\n      description: 'Payload para submissão de comentários'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'ID do post alvo'\\n          example: 'post_4492'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_1023\",\n        \"comment_details\": {\n          \"author_name\": \"Carlos Souza\",\n          \"content\": \"Concordo plenamente com os pontos levantados.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'Dados do autor e mensagem'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'Nome do usuário que comenta'\\n          example: 'Carlos Souza'\\n        content:\\n          type: string\\n          description: 'Conteúdo da mensagem'\\n          example: 'Concordo plenamente com os pontos levantados.'\\n    CommentSubmission:\\n      type: object\\n      description: 'Objeto de submissão de comentário'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Identificador do post'\\n          example: 'post_1023'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"order_id\": \"ORD-99281\",\n        \"tracking\": {\n          \"status\": \"IN_TRANSIT\",\n          \"estimated_delivery\": \"2023-11-15T14:00:00Z\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Order Status API\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TrackingInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Current shipment status\\\", \\\"example\\\": \\\"IN_TRANSIT\\\" },\\n          \\\"estimated_delivery\\\": { \\\"type\\\": \\\"string\\\", \\\"format\\\": \\\"date-time\\\", \\\"description\\\": \\\"ISO 8601 delivery date\\\", \\\"example\\\": \\\"2023-11-15T14:00:00Z\\\" }\\n        }\\n      },\\n      \\\"OrderResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"order_id\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Unique order identifier\\\", \\\"example\\\": \\\"ORD-99281\\\" },\\n          \\\"tracking\\\": { \\\"$ref\\\": \\\"#/components/schemas/TrackingInfo\\\" }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"order_id\": \"ORD-44520\",\n        \"tracking\": {\n          \"status\": \"DELIVERED\",\n          \"estimated_delivery\": \"2023-10-01T09:30:00Z\"\n        }\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"Order Status API\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"TrackingInfo\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"properties\\\": {\\n          \\\"status\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"Current shipment status\\\", \\\"example\\\": \