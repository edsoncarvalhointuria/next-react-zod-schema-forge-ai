"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_9982\",\n        \"author\": {\n          \"name\": \"Alice Johnson\",\n          \"text\": \"This is a very insightful article, thank you for sharing!\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentAuthor:\\n      type: object\\n      description: 'Details about the person posting the comment'\\n      properties:\\n        name:\\n          type: string\\n          description: 'The display name of the author'\\n          example: 'Alice Johnson'\\n        text:\\n          type: string\\n          description: 'The content of the comment'\\n          example: 'This is a very insightful article, thank you for sharing!'\\n    CommentSubmission:\\n      type: object\\n      description: 'A submitted comment linked to a specific post'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_9982'\\n        author:\\n          $ref: '#/components/schemas/CommentAuthor'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_4431\",\n        \"author\": {\n          \"name\": \"Bob Smith\",\n          \"text\": \"I disagree with the second point, could you clarify?\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentAuthor:\\n      type: object\\n      description: 'Details about the person posting the comment'\\n      properties:\\n        name:\\n          type: string\\n          description: 'The display name of the author'\\n          example: 'Bob Smith'\\n        text:\\n          type: string\\n          description: 'The content of the comment'\\n          example: 'I disagree with the second point, could you clarify?'\\n    CommentSubmission:\\n      type: object\\n      description: 'A submitted comment linked to a specific post'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_4431'\\n        author:\\n          $ref: '#/components/schemas/CommentAuthor'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_1029\",\n        \"author\": {\n          \"name\": \"Charlie Davis\",\n          \"text\": \"Great read! Looking forward to the next update.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentAuthor:\\n      type: object\\n      description: 'Details about the person posting the comment'\\n      properties:\\n        name:\\n          type: string\\n          description: 'The display name of the author'\\n          example: 'Charlie Davis'\\n        text:\\n          type: string\\n          description: 'The content of the comment'\\n          example: 'Great read! Looking forward to the next update.'\\n    CommentSubmission:\\n      type: object\\n      description: 'A submitted comment linked to a specific post'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'The unique identifier of the blog post'\\n          example: 'post_1029'\\n        author:\\n          $ref: '#/components/schemas/CommentAuthor'\"\n    }\n  ]\n}"
