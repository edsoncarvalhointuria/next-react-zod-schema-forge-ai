"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"session_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoyNTE2MjM5MDIyfQ\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Logout API\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    LogoutRequest:\\n      type: object\\n      description: 'Requisição para encerrar a sessão do usuário'\\n      properties:\\n        session_token:\\n          type: string\\n          description: 'O token de sessão único do usuário para autenticação do logout'\\n          example: 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoyNTE2MjM5MDIyfQ'\"\n    },\n    {\n      \"raw_json\": {\n        \"token\": \"sess_abc123xyz789\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Session Manager\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    TokenLogout:\\n      type: object\\n      description: 'Objeto contendo o token de autenticação para logout'\\n      properties:\\n        token:\\n          type: string\\n          description: 'Token de autenticação utilizado para invalidar a sessão atual'\\n          example: 'sess_abc123xyz789'\"\n    },\n    {\n      \"raw_json\": {\n        \"auth_token\": \"98765-43210-abcde\"\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Auth Service\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    SessionTermination:\\n      type: object\\n      description: 'Dados necessários para a terminação da sessão do usuário'\\n      properties:\\n        auth_token:\\n          type: string\\n          description: 'Token de autorização do usuário a ser revogado'\\n          example: '98765-43210-abcde'\"\n    }\n  ]\n}"
