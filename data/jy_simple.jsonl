ges\\\",\\n            \\\"items\\\": { \\\"type\\\": \\\"string\\\", \\\"example\\\": \\\"Token expired\\\" }\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    },\n    {\n      \"raw_json\": {\n        \"error_code\": \"DB_TIMEOUT\",\n        \"messages\": [\n          \"Database connection timed out\",\n          \"Retry after 30 seconds\"\n        ]\n      },\n      \"json_schema_code\": \"{\\n  \\\"openapi\\\": \\\"3.0.0\\\",\\n  \\\"info\\\": { \\\"title\\\": \\\"System Error Response\\\", \\\"version\\\": \\\"1.0.0\\\" },\\n  \\\"components\\\": {\\n    \\\"schemas\\\": {\\n      \\\"ErrorResponse\\\": {\\n        \\\"type\\\": \\\"object\\\",\\n        \\\"description\\\": \\\"System-level error response\\\",\\n        \\\"properties\\\": {\\n          \\\"error_code\\\": { \\\"type\\\": \\\"string\\\", \\\"description\\\": \\\"System error code\\\", \\\"example\\\": \\\"DB_TIMEOUT\\\" },\\n          \\\"messages\\\": {\\n            \\\"type\\\": \\\"array\\\",\\n            \\\"description\\\": \\\"List of system error messages\\\",\\n            \\\"items\\\": { \\\"type\\\": \\\"string\\\", \\\"example\\\": \\\"Database connection timed out\\\" }\\n          }\\n        }\\n      }\\n    }\\n  }\\n}\"\n    }\n  ]\n}"
"{\n  \"examples\": [\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_8821\",\n        \"comment_details\": {\n          \"author_name\": \"Carlos Silva\",\n          \"content\": \"Excelente artigo, muito esclarecedor!\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'Detalhes do autor e o corpo do comentário'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'Nome do autor do comentário'\\n          example: 'Carlos Silva'\\n        content:\\n          type: string\\n          description: 'Texto do comentário enviado'\\n          example: 'Excelente artigo, muito esclarecedor!'\\n    CommentSubmission:\\n      type: object\\n      description: 'Estrutura de envio de comentário para um post'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Identificador único do post'\\n          example: 'post_8821'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_4492\",\n        \"comment_details\": {\n          \"author_name\": \"Ana Oliveira\",\n          \"content\": \"Poderia detalhar mais sobre a seção de segurança?\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'Informações sobre quem comenta e o texto'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'Nome completo do autor'\\n          example: 'Ana Oliveira'\\n        content:\\n          type: string\\n          description: 'Conteúdo da mensagem'\\n          example: 'Poderia detalhar mais sobre a seção de segurança?'\\n    CommentSubmission:\\n      type: object\\n      description: 'Payload para submissão de comentários'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'ID do post alvo'\\n          example: 'post_4492'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    },\n    {\n      \"raw_json\": {\n        \"post_id\": \"post_1023\",\n        \"comment_details\": {\n          \"author_name\": \"Marcos Souza\",\n          \"content\": \"Concordo plenamente com os pontos levantados.\"\n        }\n      },\n      \"yaml_code\": \"openapi: 3.0.0\\ninfo:\\n  title: Blog Comment Submission\\n  version: 1.0.0\\ncomponents:\\n  schemas:\\n    CommentDetails:\\n      type: object\\n      description: 'Dados do autor e texto do comentário'\\n      properties:\\n        author_name:\\n          type: string\\n          description: 'Nome do usuário que comenta'\\n          example: 'Marcos Souza'\\n        content:\\n          type: string\\n          description: 'Texto do comentário'\\n          example: 'Concordo plenamente com os pontos levantados.'\\n    CommentSubmission:\\n      type: object\\n      description: 'Objeto de submissão de comentário'\\n      properties:\\n        post_id:\\n          type: string\\n          description: 'Identificador do post'\\n          example: 'post_1023'\\n        comment_details:\\n          $ref: '#/components/schemas/CommentDetails'\"\n    }\n  ]\n}"
